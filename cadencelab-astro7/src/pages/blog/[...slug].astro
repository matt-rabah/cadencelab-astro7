---
import BlogPost from "../../layouts/BlogPost.astro";
import TinaIsland from "@tinacms/astro/TinaIsland.astro";
import BlogBody from "../../components/islands/BlogBody.astro";
import { getBlog, listBlogs } from "../../lib/data";
import { islands } from "../../lib/islands";

export async function getStaticPaths() {
  type BlogListItem = { _sys: { filename: string } };
  const posts: BlogListItem[] = await listBlogs();
  return posts.map((node: BlogListItem) => ({
    params: { slug: node._sys.filename },
  }));
}

const slug = (Astro.params.slug ?? "").toString();
const blog = await getBlog(slug);
const data = (blog as any)?.data?.blog as Record<string, any> | undefined;
if (!data) return new Response("Not Found", { status: 404 });

const layoutProps = {
  title: data.title ?? "",
  description: data.description ?? "",
  pubDate: data.pubDate ? new Date(data.pubDate) : new Date(),
  updatedDate: data.updatedDate ? new Date(data.updatedDate) : undefined,
  heroImage: data.heroImage ?? null,
};
---

<BlogPost {...layoutProps}>
  <TinaIsland
    name="blog"
    wrapper={islands.blog.wrapper}
    params={{ slug }}
    primary
  >
    <BlogBody data={data} />
  </TinaIsland>
</BlogPost>
