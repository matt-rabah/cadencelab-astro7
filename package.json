{
  "name": "cadencelab-astro7",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "tinacms dev -c \"astro dev\"",
    "build": "tinacms build --content=local --skip-cloud-checks --skip-indexing && astro build",
    "check": "tinacms build --content=local --skip-cloud-checks --skip-indexing && astro check",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/vite": "^4.3.3",
    "@tinacms/astro": "^0.6.1",
    "astro": "^7.1.1",
    "astro-font": "^1.1.0",
    "fs-extra": "11.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.3.3",
    "tinacms": "^3.11.0",
    "wrangler": "^4.112.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true,
    "better-sqlite3@12.11.1": true,
    "core-js@3.49.0": true,
    "esbuild@0.24.2": true,
    "esbuild@0.18.20": true,
    "workerd@1.20260714.1": true
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tinacms/cli": "^2.5.6",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
