---
// src/components/Footer.astro
// Correctly importing the asset from src/assets to prevent build errors
import logoLightText from "../assets/cadencelab-wordmark_cadencelab-logo-color-lt.svg";
---

<footer class="gh-footer-zone">
  <div class="footer-container">
    <div class="footer-top-grid">
      <div class="footer-brand-column">
        <a href="/" class="footer-logo-link" title="Return to Homepage">
          <img
            src={logoLightText.src ?? logoLightText}
            alt="CadenceLab"
            height="26"
            width="133"
            loading="lazy"
            class="footer-brand-logo"
          />
        </a>
        <p class="footer-abstract">
          Architecting workflow adoption, system integration trust, and
          cross-functional measurement layers for enterprise customer experience
          ecosystems.
        </p>
      </div>

      <div class="footer-links-column">
        <h4>Workflows</h4>
        <nav aria-label="Footer Workflows Navigation">
          <a href="/workflows/salesforce">Salesforce Tracing</a>
          <a href="/workflows/cross-functional">Cross-Functional Links</a>
          <a href="/workflows/escalation">SLA Escalation Maps</a>
          <a href="/workflows/agent-routing">AI-to-Human Routing</a>
        </nav>
      </div>

      <div class="footer-links-column">
        <h4>Solutions</h4>
        <nav aria-label="Footer Solutions Navigation">
          <a href="/solutions/adoption-fatigue">User Adoption Fatigue</a>
          <a href="/solutions/dirty-data">Siloed & Dirty CRM Pipelines</a>
          <a href="/solutions/misalignment">Executive Misalignment</a>
          <a href="/solutions/enterprise">Enterprise Frameworks</a>
        </nav>
      </div>

      <div class="footer-links-column">
        <h4>AI Tooling</h4>
        <nav aria-label="Footer AI Tooling Navigation">
          <a href="/ai-tooling/prompt-guard">Prompt Firewalls</a>
          <a href="/ai-tooling/hallucination">Variance Tracing</a>
          <a href="/ai-tooling/compliance">PII Scrubbing Nodes</a>
          <a href="/ai-tooling/co-pilot">Agent Co-Pilots</a>
        </nav>
      </div>
    </div>

    <div class="footer-bottom-tier">
      <div class="legal-left">
        <span
          >&copy; {new Date().getFullYear()} CadenceLab. All rights reserved.</span
        >
      </div>
      <div class="legal-right">
        <a href="/privacy">Privacy Policy</a>
        <span class="legal-divider">•</span>
        <a href="/terms">Terms of Service</a>
        <span class="legal-divider">•</span>
        <a href="/governance">System Governance</a>
      </div>
    </div>
  </div>
</footer>

<style>
  /* --- ENTERPRISE DARK MODE FOOTER FRAMEWORK --- */
  .gh-footer-zone {
    width: 100%;
    background-color: #000000 !important; /* Forces the deep ink-black theme backdrop */
    color: #cbd6e2;
    padding: 80px 24px 40px 24px;
    border-top: 1px solid #1e242c;
    font-family:
      -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* --- TOP GRID COLUMN LAYOUT --- */
  .footer-top-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 48px;
  }

  .footer-brand-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .footer-logo-link {
    display: inline-flex;
    align-items: center;
  }

  .footer-brand-logo {
    width: auto;
    object-fit: contain;
  }

  .footer-abstract {
    font-size: 13.5px;
    line-height: 1.6;
    color: #88a0ba;
    max-width: 320px;
  }

  /* --- LINK DIRECTORIES --- */
  .footer-links-column {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .footer-links-column h4 {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: #ffffff;
    letter-spacing: 0.08em;
  }

  .footer-links-column nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links-column a {
    font-size: 13.5px;
    color: #cbd6e2;
    text-decoration: none;
    transition: color 0.15s ease;
    align-self: flex-start;
  }

  .footer-links-column a:hover {
    color: #1a73e2;
  }

  /* --- BOTTOM COMPLIANCE TIER --- */
  .footer-bottom-tier {
    border-top: 1px solid #1e242c;
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12.5px;
    color: #576579;
  }

  .legal-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .legal-right a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .legal-right a:hover {
    color: #ffffff;
  }

  .legal-divider {
    user-select: none;
    color: #1e242c;
  }

  /* --- 📱 RESPONSIVE MEDIA ADAPTATION LAYER --- */
  @media (max-width: 850px) {
    .gh-footer-zone {
      padding: 60px 24px 32px 24px;
    }

    .footer-top-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .footer-abstract {
      max-width: 100%;
    }

    .footer-bottom-tier {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .legal-right {
      flex-wrap: wrap;
      gap: 8px 12px;
    }
  }
</style>
