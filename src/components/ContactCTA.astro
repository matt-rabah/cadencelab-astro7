---
// src/components/ContactCTA.astro
---

<section class="contact-cta" aria-labelledby="contact-cta-title">
  <div class="contact-cta-container">
    <div class="contact-cta-card">
      <div class="contact-cta-intro">
        <p class="contact-cta-eyebrow">Engagement intake</p>

        <h2 id="contact-cta-title" class="contact-cta-title">
          Start with a practical fit assessment.
        </h2>

        <p class="contact-cta-description">
          We begin by understanding the operating environment, the customer
          friction you are trying to solve, and the organizational conditions
          that could support or limit adoption.
        </p>
      </div>

      <ol class="contact-cta-steps" aria-label="Fit assessment process">
        <li class="contact-cta-step">
          <span class="contact-cta-step-number" aria-hidden="true">01</span>

          <div>
            <h3>Share the operating context</h3>
            <p>
              Describe the customer experience problem, affected teams, current
              systems, and the outcome you need to improve.
            </p>
          </div>
        </li>

        <li class="contact-cta-step">
          <span class="contact-cta-step-number" aria-hidden="true">02</span>

          <div>
            <h3>Review readiness and constraints</h3>
            <p>
              We assess workflow ownership, CRM data, stakeholder alignment,
              adoption risk, and implementation dependencies.
            </p>
          </div>
        </li>

        <li class="contact-cta-step">
          <span class="contact-cta-step-number" aria-hidden="true">03</span>

          <div>
            <h3>Define the right next step</h3>
            <p>
              You receive a direct recommendation on whether an engagement makes
              sense and what should happen next.
            </p>
          </div>
        </li>
      </ol>

      <div class="contact-cta-actions">
        <a href="/fit-check/" class="contact-cta-button"> Start a fit check </a>

        <a href="/contact/" class="contact-cta-text-link">
          Contact Cadence Lab
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    width: 100%;
    padding-block: clamp(4rem, 9vw, 7rem);
    border-top: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .contact-cta-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .contact-cta-card {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    padding: clamp(2rem, 6vw, 4.5rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-pure);
    box-shadow: var(--shadow-sm);
  }

  .contact-cta-intro {
    display: flex;
    max-width: 50rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact-cta-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
  }

  .contact-cta-title {
    max-width: 17ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: clamp(2rem, 1.55rem + 1.8vw, 3.5rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  .contact-cta-description {
    max-width: 45rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1rem + 0.25vw, 1.25rem);
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .contact-cta-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    list-style: none;
  }

  .contact-cta-step {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    padding: 2rem;
  }

  .contact-cta-step + .contact-cta-step {
    border-left: 1px solid var(--color-border);
  }

  .contact-cta-step-number {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .contact-cta-step div {
    min-width: 0;
  }

  .contact-cta-step h3 {
    margin: 0 0 0.75rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }

  .contact-cta-step p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .contact-cta-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .contact-cta-button {
    display: inline-flex;
    width: fit-content;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-blue);
    border-radius: var(--radius-sm);
    background: var(--color-blue);
    color: var(--color-light);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .contact-cta-button:hover {
    border-color: color-mix(in srgb, var(--color-blue) 82%, var(--color-ink));
    background: color-mix(in srgb, var(--color-blue) 82%, var(--color-ink));
    color: var(--color-light);
    text-decoration: none;
  }

  .contact-cta-button:active {
    transform: translateY(1px);
  }

  .contact-cta-text-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .contact-cta-text-link:hover {
    color: var(--color-blue);
  }

  @media (max-width: 56rem) {
    .contact-cta-steps {
      grid-template-columns: 1fr;
    }

    .contact-cta-step + .contact-cta-step {
      border-top: 1px solid var(--color-border);
      border-left: 0;
    }
  }

  @media (max-width: 40rem) {
    .contact-cta {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .contact-cta-card {
      padding: 1.5rem;
    }

    .contact-cta-title {
      max-width: 15ch;
      font-size: clamp(2rem, 8vw, 2.75rem);
    }

    .contact-cta-step {
      grid-template-columns: 1fr;
      gap: 0.625rem;
      padding: 1.5rem 0;
    }

    .contact-cta-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .contact-cta-button,
    .contact-cta-text-link {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-cta-button {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .contact-cta-card,
    .contact-cta-steps,
    .contact-cta-step {
      border-color: CanvasText;
    }

    .contact-cta-button {
      border-color: ButtonText;
    }
  }
</style>
