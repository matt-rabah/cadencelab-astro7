---
// src/components/ContactCTA.astro
---
<section class="cta-section">
  <div class="cta-container">
    <div class="cta-card">
      <span class="cta-tag">Engagement Intake</span>
      <h2 class="cta-heading">Initiate a Strategic Fit Assessment</h2>
      
      <p class="cta-text">
        We limit our practice to a select number of enterprise engagements each quarter. This ensures the operational depth required to translate complex stakeholder architecture into un-compromised workflow adoption.
      </p>

      <div class="process-steps">
        <div class="step">
          <span class="step-num">Step 1</span>
          <p>Submit a high-level operational baseline profile.</p>
        </div>
        <div class="step">
          <span class="step-num">Step 2</span>
          <p>Review legacy technical architecture and CRM mapping.</p>
        </div>
        <div class="step">
          <span class="step-num">Step 3</span>
          <p>Execute a 30-minute cross-functional alignment session.</p>
        </div>
      </div>

      <div class="cta-actions">
        <a href="/fit-check" class="btn-primary">Begin the Application Process</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* --- DESIGN TOKENS (Spectrum 2 Elite Minimalist Vibe) --- */
  .cta-section {
    width: 100%;
    padding: 100px 24px;
    background-color: var(--spectrum-background-layer-1, #ffffff);
    border-top: 1px solid rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 10%);
  }

  .cta-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .cta-card {
    background-color: var(--spectrum-background-layer-1, #ffffff);
    border: 1px solid rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 20%);
    border-radius: 8px;
    padding: 64px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.02);
  }

  .cta-tag {
    font-family: adobe-clean, sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: var(--spectrum-global-color-accent, #0265dc);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .cta-heading {
    font-family: adobe-clean, sans-serif;
    font-size: 40px;
    font-weight: 800;
    line-height: 1.2;
    color: var(--spectrum-heading-color, CanvasText);
    letter-spacing: -0.02em;
    max-width: 700px;
  }

  .cta-text {
    font-family: adobe-clean, sans-serif;
    font-size: 18px;
    line-height: 1.6;
    color: var(--spectrum-body-color, #4b4b4b);
    max-width: 650px;
    margin-bottom: 16px;
  }

  /* --- MINIMAL PROCESS OVERVIEW --- */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    width: 100%;
    max-width: 900px;
    text-align: left;
    margin: 24px 0;
    border-top: 1px solid rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 10%);
    border-bottom: 1px solid rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 10%);
    padding: 32px 0;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .step-num {
    font-family: adobe-clean, sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 60%);
    letter-spacing: 0.05em;
  }

  .step p {
    font-family: adobe-clean, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--spectrum-body-color, #333333);
  }

  /* --- ACTION BUTTON --- */
  .cta-actions {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .btn-primary {
    font-family: adobe-clean, sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    padding: 16px 36px;
    background-color: var(--spectrum-global-color-accent, #0265dc);
    color: #ffffff;
    border-radius: 4px;
    box-shadow: 0 4px 12px rgba(2, 101, 220, 0.15);
    transition: all 0.2s ease-in-out;
  }

  .btn-primary:hover {
    background-color: #014da3;
    transform: translateY(-1px);
  }

  /* --- 📱 RESPONSIVE SINGLE-TREE MEDIA QUERIES --- */
  @media (max-width: 900px) {
    .process-steps {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 24px 0;
    }
    
    .cta-card {
      padding: 40px 24px;
    }
  }

  @media (max-width: 768px) {
    .cta-heading {
      font-size: 30px;
    }
    
    .btn-primary {
      width: 100%;
      text-align: center;
    }
  }
</style>
