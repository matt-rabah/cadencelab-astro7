---
// src/components/Hero.astro
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="hero-container">
    <div class="hero-content">
      <p class="hero-eyebrow">Customer experience systems</p>

      <h1 id="hero-title" class="hero-title">
        AI isn't your customer experience problem.
        <span class="hero-accent">Adoption is.</span>
      </h1>

      <p class="hero-subtitle">
        Most customer-facing AI initiatives fail because of implementation,
        trust, and measurement—not the model. We translate stakeholder needs,
        operational constraints, and CRM data into workflows people can
        understand, adopt, and improve.
      </p>

      <div class="hero-actions">
        <a href="/fit-check/" class="hero-button hero-button-primary">
          Start a fit check
        </a>

        <a href="#framework" class="hero-button hero-button-secondary">
          Explore the adoption framework
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    padding-block: clamp(5rem, 11vw, 9rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .hero-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .hero-content {
    display: flex;
    max-width: 62rem;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  .hero-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-style: normal;
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--ls-eyebrow);
    font-feature-settings: var(--fea-eyebrow);
    text-transform: uppercase;
  }

  .hero-title {
    max-width: 18ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-style: normal;
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .hero-accent {
    color: var(--color-blue);
  }

  .hero-subtitle {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-style: normal;
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.875rem;
    margin-top: 0.5rem;
  }

  .hero-button {
    display: inline-flex;
    width: fit-content;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: var(--fs-cta);
    font-style: normal;
    font-weight: var(--fw-medium);
    line-height: 1.2;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-align: center;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .hero-button:hover {
    text-decoration: none;
  }

  .hero-button:active {
    transform: translateY(1px);
  }

  .hero-button-primary {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-light);
  }

  .hero-button-primary:hover {
    border-color: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));

    background: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));

    color: var(--color-light);
  }

  .hero-button-secondary {
    border-color: var(--color-border-strong);
    background: transparent;
    color: var(--color-ink);
  }

  .hero-button-secondary:hover {
    border-color: var(--color-ink);
    background: var(--color-surface-pure);
    color: var(--color-ink);
  }

  .hero-button:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 40rem) {
    .hero-section {
      padding-block: clamp(4rem, 18vw, 6rem);
    }

    .hero-title {
      max-width: 14ch;
    }

    .hero-subtitle {
      max-width: 36rem;
    }

    .hero-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }

    .hero-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-button {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .hero-button {
      border-color: ButtonText;
    }
  }
</style>
