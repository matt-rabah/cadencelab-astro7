---
// src/components/Hero.astro
---
<section class="hero-section">
  <div class="hero-content">
    <h1 class="hero-title">
      AI isn't your customer experience problem. <span class="highlight-accent">Adoption is.</span>
    </h1>
    
    <p class="hero-subtitle">
      Most customer-facing AI initiatives fail because of implementation, trust, and measurement—not the model. We translate complex stakeholder needs and CRM data into high-performing, human-adopted workflows. 
    </p>
    
    <div class="hero-actions">
      <a href="/fit-check" class="btn-primary">Start a Fit Check</a>
      <a href="#framework" class="btn-secondary">The Adoption Framework</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    padding: 120px 24px;
    background-color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .hero-content {
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .hero-title {
    font-size: 56px;
    font-weight: 900;
    line-height: 1.15;
    color: #161616;
    letter-spacing: -0.03em;
  }

  /* Fix #3: Dynamically references central brand token while maintaining automatic fallbacks */
  .highlight-accent {
    color: var(--color-accent, #1a73e2);
  }

  .hero-subtitle {
    font-size: 20px;
    line-height: 1.6;
    color: #4b4b4b;
    max-width: 750px;
    letter-spacing: -0.01em;
  }

  .hero-actions {
    display: flex;
    gap: 20px;
    margin-top: 12px;
  }

  .btn-primary, .btn-secondary {
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    padding: 16px 32px;
    border-radius: 4px;
    transition: all 0.15s ease-in-out;
  }

  .btn-primary {
    background-color: #161616;
    color: #fcfcf9;
    box-shadow: 0 4px 12px rgba(22, 22, 22, 0.08);
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-secondary {
    background-color: transparent;
    color: #161616;
    border: 2px solid rgba(22, 22, 22, 0.15);
  }

  .btn-secondary:hover {
    background-color: rgba(22, 22, 22, 0.02);
    border-color: rgba(22, 22, 22, 0.4);
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 80px 16px;
    }

    .hero-title {
      font-size: 38px;
    }

    .hero-subtitle {
      font-size: 18px;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      gap: 16px;
    }

    .btn-primary, .btn-secondary {
      width: 100%;
      text-align: center;
      padding: 14px 24px;
    }
  }
</style>
