---
// src/components/ResponsiveHero.astro
---

<section class="responsive-hero" aria-labelledby="responsive-hero-title">
  <div class="responsive-hero-container">
    <div class="responsive-hero-content">
      <p class="responsive-hero-eyebrow">Customer experience operations</p>

      <h1 id="responsive-hero-title" class="responsive-hero-title">
        Design systems people can actually use.
      </h1>

      <p class="responsive-hero-lead">
        Cadence Lab connects customer experience strategy, CRM data, workflow
        design, and responsible AI implementation into practical operating
        systems.
      </p>

      <div class="responsive-hero-body">
        <p>
          The goal is not to add more technology. It is to reduce friction,
          clarify ownership, improve adoption, and make performance measurable
          across teams.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .responsive-hero {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .responsive-hero-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .responsive-hero-content {
    display: flex;
    max-width: 58rem;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .responsive-hero-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
  }

  .responsive-hero-title {
    max-width: 13ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: clamp(2.75rem, 1.75rem + 4vw, 6rem);
    font-style: normal;
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .responsive-hero-lead {
    max-width: 44rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: clamp(1.125rem, 1rem + 0.35vw, 1.375rem);
    font-style: normal;
    font-weight: 400;
    line-height: 1.55;
    letter-spacing: -0.01em;
    text-wrap: pretty;
  }

  .responsive-hero-body {
    max-width: 42rem;
    padding-top: 0.25rem;
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 1rem + 0.2vw, 1.1875rem);
    font-weight: 400;
    line-height: 1.65;
  }

  .responsive-hero-body p {
    margin: 0;
  }

  @media (max-width: 40rem) {
    .responsive-hero {
      padding-block: clamp(3.5rem, 16vw, 5.5rem);
    }

    .responsive-hero-title {
      max-width: 12ch;
      font-size: clamp(2.5rem, 11vw, 4rem);
      line-height: 1;
      letter-spacing: -0.035em;
    }

    .responsive-hero-lead {
      font-size: 1.0625rem;
      line-height: 1.6;
    }

    .responsive-hero-body {
      font-size: 1.0625rem;
      line-height: 1.65;
    }
  }
</style>
