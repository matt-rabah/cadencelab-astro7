---
// src/components/ResponsiveHero.astro
---

<section class="responsive-hero" aria-labelledby="responsive-hero-title">
  <div class="responsive-hero-container">
    <div class="responsive-hero-content">
      <p class="responsive-hero-eyebrow">Customer experience operations</p>

      <h1 id="responsive-hero-title" class="responsive-hero-title">
        Design systems people can actually use.
      </h1>

      <p class="responsive-hero-lead">
        Cadence Lab connects customer experience strategy, CRM data, workflow
        design, and responsible AI implementation into practical operating
        systems.
      </p>

      <div class="responsive-hero-body">
        <p>
          The goal is not to add more technology. It is to reduce friction,
          clarify ownership, improve adoption, and make performance measurable
          across teams.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .responsive-hero {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .responsive-hero-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .responsive-hero-content {
    display: flex;
    max-width: 58rem;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .responsive-hero-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-style: normal;
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--ls-eyebrow);
    font-feature-settings: var(--fea-eyebrow);
    text-transform: uppercase;
  }

  .responsive-hero-title {
    max-width: 17ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-style: normal;
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .responsive-hero-lead {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-style: normal;
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .responsive-hero-body {
    max-width: var(--measure-ui);
    padding-top: 0.25rem;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .responsive-hero-body p {
    margin: 0;
  }

  @media (max-width: 40rem) {
    .responsive-hero {
      padding-block: clamp(3.5rem, 16vw, 5.5rem);
    }

    .responsive-hero-title {
      max-width: 15ch;
    }
  }
</style>
