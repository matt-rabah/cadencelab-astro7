<section class="py-20 bg-white space-y-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-5 space-y-6">
        <h2
          class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          Contextual layout rendering
        </h2>
        <p class="text-base sm:text-lg text-slate-600 leading-relaxed">
          Analyze structure at a glance (spanning component dependency mapping
          to active data streams). Maintain continuous line of sight across your
          entire application architecture maps without switching views.
        </p>
      </div>
      <div class="hidden lg:block lg:col-span-1"></div>
      <div class="lg:col-span-6">
        <div
          class="overflow-hidden rounded-xl bg-gradient-to-tr from-violet-500 to-fuchsia-500 p-4 shadow-md"
        >
          <div
            class="rounded-lg bg-slate-900/10 backdrop-blur-sm aspect-[4/3] flex items-center justify-center border border-white/10"
          >
            <span class="text-sm text-white/80 font-mono"
              >[Interactive Interface Asset]</span
            >
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <div class="lg:col-span-6 order-last lg:order-first">
        <div
          class="overflow-hidden rounded-xl bg-gradient-to-tr from-indigo-500 to-blue-500 p-4 shadow-md"
        >
          <div
            class="rounded-lg bg-slate-900/10 backdrop-blur-sm aspect-[4/3] flex items-center justify-center border border-white/10"
          >
            <span class="text-sm text-white/80 font-mono"
              >[Automated Workflow Asset]</span
            >
          </div>
        </div>
      </div>
      <div class="hidden lg:block lg:col-span-1"></div>
      <div class="lg:col-span-5 space-y-6">
        <h2
          class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl"
        >
          Automated code assembly
        </h2>
        <p class="text-base sm:text-lg text-slate-600 leading-relaxed">
          Accelerate iterative production steps via structural template
          compilation. Review syntax updates, dependency tree checks, and
          deployment configuration rules prior to baseline merging cycles.
        </p>
      </div>
    </div>
  </div>
</section>
