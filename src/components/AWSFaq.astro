<section class="py-20 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-8">
          <h2
