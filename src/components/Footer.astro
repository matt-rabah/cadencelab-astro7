---
// src/components/Footer.astro

import logoLightText from "../assets/cadencelab-wordmark_cadencelab-logo-color-lt.svg";

interface FooterLink {
  label: string;
  href: string;
}

interface FooterSection {
  title: string;
  id: string;
  links: FooterLink[];
}

const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;

const footerSections: FooterSection[] = [
  {
    title: "Workflows",
    id: "footer-workflows-label",
    links: [
      {
        label: "Salesforce tracing",
        href: "/workflows/salesforce/",
      },
      {
        label: "Cross-functional links",
        href: "/workflows/cross-functional/",
      },
      {
        label: "SLA escalation maps",
        href: "/workflows/escalation/",
      },
      {
        label: "AI-to-human routing",
        href: "/workflows/agent-routing/",
      },
    ],
  },
  {
    title: "Solutions",
    id: "footer-solutions-label",
    links: [
      {
        label: "User adoption fatigue",
        href: "/solutions/adoption-fatigue/",
      },
      {
        label: "Siloed and dirty CRM pipelines",
        href: "/solutions/dirty-data/",
      },
      {
        label: "Executive misalignment",
        href: "/solutions/misalignment/",
      },
      {
        label: "Enterprise frameworks",
        href: "/solutions/enterprise/",
      },
    ],
  },
  {
    title: "AI tooling",
    id: "footer-ai-tooling-label",
    links: [
      {
        label: "Prompt firewalls",
        href: "/ai-tooling/prompt-guard/",
      },
      {
        label: "Variance tracing",
        href: "/ai-tooling/hallucination/",
      },
      {
        label: "PII scrubbing nodes",
        href: "/ai-tooling/compliance/",
      },
      {
        label: "Agent copilots",
        href: "/ai-tooling/co-pilot/",
      },
    ],
  },
];

const legalLinks: FooterLink[] = [
  {
    label: "Privacy policy",
    href: "/privacy/",
  },
  {
    label: "Terms of service",
    href: "/terms/",
  },
  {
    label: "System governance",
    href: "/governance/",
  },
];

const normalizePath = (path: string): string => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isCurrentPage = (href: string): boolean =>
  normalizePath(currentPath) === normalizePath(href);
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-primary">
      <div class="footer-brand">
        <a
          href="/"
          class="footer-logo-link"
          aria-label="Cadence Lab home"
          aria-current={isCurrentPage("/") ? "page" : undefined}
        >
          <img
            src={logoLightText.src ?? logoLightText}
            alt=""
            width="133"
            height="26"
            loading="lazy"
            decoding="async"
            class="footer-logo"
          />
        </a>

        <p class="footer-description">
          Architecting workflow adoption, system integration trust, and
          cross-functional measurement systems for enterprise customer
          experience.
        </p>
      </div>

      <div class="footer-directory">
        {
          footerSections.map((section) => (
            <nav class="footer-section" aria-labelledby={section.id}>
              <p id={section.id} class="footer-section-label">
                {section.title}
              </p>

              <ul class="footer-link-list">
                {section.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      aria-current={
                        isCurrentPage(link.href) ? "page" : undefined
                      }
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ))
        }
      </div>
    </div>

    <div class="footer-secondary">
      <p class="footer-copyright">
        <span>&copy; {currentYear} Cadence Lab.</span>
        <span>All rights reserved.</span>
      </p>

      <nav class="footer-legal" aria-label="Legal">
        <ul class="legal-link-list">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isCurrentPage(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-background: #000;
    --footer-heading: #fff;
    --footer-text: #cbd6e2;
    --footer-muted: #93a3b5;
    --footer-subtle: #7c8999;
    --footer-border: #252b33;
    --footer-accent: #4fd34a;
    --footer-focus: #fff;

    width: 100%;
    padding: clamp(3.5rem, 7vw, 5rem) clamp(1.25rem, 4vw, 3rem)
      clamp(2rem, 4vw, 2.5rem);

    border-top: 1px solid var(--footer-border);
    background: var(--footer-background);
    color: var(--footer-text);

    font-family: var(--font-sans, "Graphik"), Arial, sans-serif;

    font-synthesis: none;
  }

  .site-footer,
  .site-footer * {
    font-family: var(--font-sans, "Graphik"), Arial, sans-serif;
  }

  .footer-container {
    width: min(100%, 75rem);
    margin-inline: auto;
  }

  .footer-primary {
    display: grid;
    gap: clamp(3rem, 6vw, 5rem);
  }

  .footer-brand {
    min-width: 0;
  }

  .footer-logo-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 2.75rem;
    color: inherit;
    text-decoration: none;
  }

  .footer-logo {
    display: block;
    width: auto;
    height: 1.625rem;
    object-fit: contain;
  }

  .footer-description {
    max-width: 34rem;
    margin: 1.125rem 0 0;
    color: var(--footer-muted);
    font-size: clamp(0.875rem, 0.85rem + 0.1vw, 0.9375rem);
    font-weight: 400;
    line-height: 1.6;
    letter-spacing: 0;
    text-wrap: pretty;
  }

  .footer-directory {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .footer-section {
    min-width: 0;
  }

  .footer-section-label {
    margin: 0 0 1rem;
    padding: 0;
    color: var(--footer-heading);
    font-size: 0.875rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0;
    text-align: left;
    text-transform: none;
    text-wrap: pretty;
  }

  .footer-link-list,
  .legal-link-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-link-list {
    display: grid;
    gap: 0.125rem;
  }

  .footer-link-list li,
  .legal-link-list li {
    margin: 0;
    padding: 0;
  }

  .footer-link-list a {
    display: flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    min-height: 2.75rem;
    padding-block: 0.35rem;

    color: var(--footer-text);
    font-size: 0.875rem;
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: 0;
    text-decoration: none;
    text-transform: none;
    text-wrap: pretty;

    transition: color 150ms ease;
  }

  .footer-link-list a:hover {
    color: var(--footer-accent);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  .footer-link-list a[aria-current="page"] {
    color: var(--footer-heading);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--footer-accent);
    text-decoration-thickness: 0.12em;
    text-underline-offset: 0.25em;
  }

  .footer-secondary {
    display: grid;
    gap: 1rem;
    margin-top: clamp(3rem, 7vw, 4rem);
    padding-top: 1.75rem;
    border-top: 1px solid var(--footer-border);
  }

  .footer-copyright {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.4rem;
    margin: 0;

    color: var(--footer-subtle);
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.5;
    text-transform: none;
  }

  .legal-link-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .legal-link-list li {
    display: inline-flex;
    align-items: center;
  }

  .legal-link-list li:not(:last-child)::after {
    content: "";
    flex: 0 0 auto;
    width: 0.1875rem;
    height: 0.1875rem;
    margin-inline: 0.75rem;
    border-radius: 50%;
    background: var(--footer-subtle);
    opacity: 0.7;
  }

  .legal-link-list a {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;

    color: var(--footer-subtle);
    font-size: 0.8125rem;
    font-weight: 400;
    line-height: 1.4;
    text-decoration: none;
    text-transform: none;

    transition: color 150ms ease;
  }

  .legal-link-list a:hover,
  .legal-link-list a[aria-current="page"] {
    color: var(--footer-heading);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
  }

  .site-footer a:focus-visible {
    outline: 2px solid var(--footer-focus);
    outline-offset: 0.25rem;
  }

  @media (min-width: 40rem) {
    .footer-directory {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 3rem;
      row-gap: 2.75rem;
    }

    .footer-section:last-child {
      grid-column: 1 / -1;
    }

    .footer-secondary {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 2rem;
    }

    .footer-legal {
      justify-self: end;
    }

    .legal-link-list {
      justify-content: flex-end;
    }
  }

  @media (min-width: 64rem) {
    .footer-primary {
      grid-template-columns: minmax(16rem, 1.15fr) minmax(0, 2.85fr);
      gap: clamp(4rem, 7vw, 7rem);
      align-items: start;
    }

    .footer-description {
      max-width: 20rem;
    }

    .footer-directory {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: clamp(2rem, 4vw, 4rem);
    }

    .footer-section:last-child {
      grid-column: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-link-list a,
    .legal-link-list a {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .site-footer,
    .footer-secondary {
      border-color: CanvasText;
    }
  }
</style>
