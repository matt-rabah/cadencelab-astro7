---
import wordmark from "../assets/brand/cadencelab-wordmark-dark-color.svg";

interface FooterLink {
  label: string;
  href: string;
}

interface FooterSection {
  title: string;
  id: string;
  links: FooterLink[];
}

const currentYear = new Date().getFullYear();
const currentPath = Astro.url.pathname;

const footerSections: FooterSection[] = [
  {
    title: "Workflows",
    id: "footer-workflows-label",
    links: [
      {
        label: "Salesforce tracing",
        href: "/workflows/salesforce/",
      },
      {
        label: "Cross-functional links",
        href: "/workflows/cross-functional/",
      },
      {
        label: "SLA escalation maps",
        href: "/workflows/escalation/",
      },
      {
        label: "AI-to-human routing",
        href: "/workflows/agent-routing/",
      },
    ],
  },
  {
    title: "Solutions",
    id: "footer-solutions-label",
    links: [
      {
        label: "User adoption fatigue",
        href: "/solutions/adoption-fatigue/",
      },
      {
        label: "Siloed and dirty CRM pipelines",
        href: "/solutions/dirty-data/",
      },
      {
        label: "Executive misalignment",
        href: "/solutions/misalignment/",
      },
      {
        label: "Enterprise frameworks",
        href: "/solutions/enterprise/",
      },
    ],
  },
  {
    title: "AI tooling",
    id: "footer-ai-tooling-label",
    links: [
      {
        label: "Prompt firewalls",
        href: "/ai-tooling/prompt-guard/",
      },
      {
        label: "Variance tracing",
        href: "/ai-tooling/hallucination/",
      },
      {
        label: "PII scrubbing nodes",
        href: "/ai-tooling/compliance/",
      },
      {
        label: "Agent copilots",
        href: "/ai-tooling/co-pilot/",
      },
    ],
  },
];

const legalLinks: FooterLink[] = [
  {
    label: "Privacy policy",
    href: "/privacy/",
  },
  {
    label: "Terms of service",
    href: "/terms/",
  },
  {
    label: "System governance",
    href: "/governance/",
  },
];

const normalizePath = (path: string): string => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isCurrentPage = (href: string): boolean =>
  normalizePath(currentPath) === normalizePath(href);
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-primary">
      <div class="footer-brand">
        <a
          href="/"
          class="footer-logo-link"
          aria-label="Cadence Lab home"
          aria-current={isCurrentPage("/") ? "page" : undefined}
        >
          <img
            src={wordmark.src ?? wordmark}
            alt=""
            width="3000"
            height="413"
            loading="lazy"
            decoding="async"
            class="footer-logo"
          />
        </a>

        <p class="footer-description">
          Cadence Lab helps organizations improve customer experience by
          aligning workflows, systems, teams, and applied AI.
        </p>

        <a
          href="/contact/"
          class="footer-contact-link"
          aria-current={isCurrentPage("/contact/") ? "page" : undefined}
        >
          <span>Start a conversation</span>
          <svg
            aria-hidden="true"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path d="M2.5 8h10"></path>
            <path d="m8.75 4.25 3.75 3.75-3.75 3.75"></path>
          </svg>
        </a>
      </div>

      {
        footerSections.map((section) => (
          <nav class="footer-section" aria-labelledby={section.id}>
            <h2 id={section.id} class="footer-section-label">
              {section.title}
            </h2>

            <ul class="footer-link-list">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    aria-current={isCurrentPage(link.href) ? "page" : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div class="footer-secondary">
      <p class="footer-copyright">
        <span>&copy; {currentYear} Cadence Lab.</span>
        <span>All rights reserved.</span>
      </p>

      <nav class="footer-legal" aria-label="Legal">
        <ul class="legal-link-list">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={isCurrentPage(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-background: var(--color-ink);
    --footer-heading: var(--color-light);
    --footer-text: var(--color-text-inverse-muted);
    --footer-muted: #98a29f;
    --footer-subtle: #7f8986;
    --footer-border: rgb(252 254 255 / 18%);
    --footer-accent: var(--color-green);
    --footer-focus: var(--color-light);

    width: 100%;
    padding: clamp(3.5rem, 8vw, 6rem) var(--page-gutter)
      clamp(2rem, 5vw, 2.75rem);
    border-top: var(--border-width) solid var(--footer-border);
    background: var(--footer-background);
    color: var(--footer-text);
    font-family: var(--ff-sans);
    font-feature-settings: var(--fea-graphik);
    font-synthesis: none;
  }

  .footer-container {
    width: min(100%, var(--container-page));
    margin-inline: auto;
  }

  .footer-primary {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.75rem;
  }

  .footer-brand,
  .footer-section {
    min-width: 0;
  }

  .footer-logo-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: var(--control-min-size);
    color: inherit;
    text-decoration: none;
  }

  .footer-logo {
    display: block;
    width: clamp(9.5rem, 14vw, 11.25rem);
    height: auto;
  }

  .footer-description {
    max-width: 31rem;
    margin: 1.25rem 0 0;
    color: var(--footer-text);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    min-height: var(--control-min-size);
    margin-top: 1.25rem;
    color: var(--footer-heading);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    line-height: 1.4;
    text-decoration: underline;
    text-decoration-color: var(--footer-accent);
    text-decoration-thickness: 0.1em;
    text-underline-offset: 0.25em;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .footer-contact-link svg {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
    transition: translate var(--transition-fast);
  }

  .footer-contact-link:hover {
    color: var(--footer-accent);
  }

  .footer-contact-link:hover svg {
    translate: 0.2rem 0;
  }

  .footer-section-label {
    margin: 0 0 1rem;
    color: var(--footer-heading);
    font-family: var(--ff-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }

  .footer-link-list,
  .legal-link-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-link-list {
    display: grid;
    gap: 0.125rem;
  }

  .footer-link-list a {
    display: flex;
    align-items: center;
    width: fit-content;
    max-width: 100%;
    min-height: var(--control-min-size);
    padding-block: 0.375rem;
    color: var(--footer-text);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    line-height: 1.45;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
    text-wrap: pretty;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .footer-link-list a:hover {
    color: var(--footer-heading);
    text-decoration-color: var(--footer-accent);
  }

  .footer-link-list a[aria-current="page"] {
    color: var(--footer-heading);
    font-weight: var(--fw-medium);
    text-decoration-color: var(--footer-accent);
    text-decoration-thickness: 0.12em;
  }

  .footer-secondary {
    display: grid;
    gap: 1.25rem;
    margin-top: clamp(3.25rem, 7vw, 5rem);
    padding-top: 1.5rem;
    border-top: var(--border-width) solid var(--footer-border);
  }

  .footer-copyright {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.4rem;
    margin: 0;
    color: var(--footer-subtle);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-regular);
    line-height: 1.5;
  }

  .legal-link-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }

  .legal-link-list li {
    display: inline-flex;
    align-items: center;
  }

  .legal-link-list li:not(:last-child)::after {
    content: "";
    flex: 0 0 auto;
    width: 0.1875rem;
    height: 0.1875rem;
    margin-inline: 0.75rem;
    border-radius: 50%;
    background: var(--footer-subtle);
  }

  .legal-link-list a {
    display: inline-flex;
    align-items: center;
    min-height: var(--control-min-size);
    color: var(--footer-subtle);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-regular);
    line-height: 1.4;
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.22em;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .legal-link-list a:hover,
  .legal-link-list a[aria-current="page"] {
    color: var(--footer-heading);
    text-decoration-color: var(--footer-accent);
  }

  .site-footer a:focus-visible {
    outline: var(--focus-ring-width) solid var(--footer-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (min-width: 40rem) {
    .footer-primary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: clamp(3rem, 7vw, 5rem);
      row-gap: 3rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-secondary {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 2rem;
    }

    .footer-legal {
      justify-self: end;
    }

    .legal-link-list {
      justify-content: flex-end;
    }
  }

  @media (min-width: 70rem) {
    .footer-primary {
      grid-template-columns: minmax(17rem, 1.4fr) repeat(3, minmax(0, 1fr));
      gap: clamp(2rem, 4vw, 4.5rem);
      align-items: start;
    }

    .footer-brand {
      grid-column: auto;
    }

    .footer-description {
      max-width: 22rem;
    }
  }

  @media (pointer: coarse) {
    .footer-logo-link,
    .footer-contact-link,
    .footer-link-list a,
    .legal-link-list a {
      min-height: var(--control-min-size-coarse);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-contact-link,
    .footer-contact-link svg,
    .footer-link-list a,
    .legal-link-list a {
      transition: none;
    }

    .footer-contact-link:hover svg {
      translate: none;
    }
  }

  @media (forced-colors: active) {
    .site-footer,
    .footer-secondary {
      border-color: CanvasText;
    }

    .footer-contact-link,
    .footer-link-list a,
    .legal-link-list a {
      text-decoration-color: currentColor;
    }
  }
</style>
