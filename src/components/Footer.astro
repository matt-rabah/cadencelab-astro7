---
import logoLightText from "../assets/cadencelab-wordmark_cadencelab-logo-color-lt.svg";

const currentYear = new Date().getFullYear();

const primaryLinks = [
  { label: "Home", href: "/" },
  // Add these only when the routes exist:
  // { label: "About", href: "/about/" },
  // { label: "Blog", href: "/blog/" },
  // { label: "Contact", href: "/contact/" },
];

const externalLinks = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/",
  },
];
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" aria-label="Cadence Lab home" class="footer-logo-link">
          <img
            src={logoLightText.src ?? logoLightText}
            alt=""
            width="133"
            height="26"
            loading="lazy"
            decoding="async"
          />
        </a>

        <p>
          Architecting workflow adoption, system integration trust, and
          cross-functional measurement systems for enterprise customer
          experience.
        </p>
      </div>

      <nav aria-label="Footer navigation">
        <ul>
          {
            primaryLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="External links">
        <ul>
          {
            externalLinks.map((link) => (
              <li>
                <a href={link.href} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Cadence Lab. All rights reserved.</p>
    </div>
  </div>
</footer>
