                    </li>
                  </ul>
                </section>

                <section class="link-column">
                  <p class="menu-label">Integration systems</p>

                  <ul>
                    <li>
                      <a href="/workflows/legacy/">
                        Legacy system consolidation
                      </a>
                    </li>

                    <li>
                      <a href="/workflows/omnichannel/">
                        Omnichannel state syncing
                      </a>
                    </li>

                    <li>
                      <a href="/workflows/telephony/">
                        Contact center integration
                      </a>
                    </li>
