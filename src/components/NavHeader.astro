                  </a>
                </section>

                <section class="link-column">
                  <p class="menu-label">By operational friction</p>

                  <ul>
                    <li>
                      <a href="/solutions/adoption-fatigue/">
                        User adoption fatigue
                      </a>
                    </li>

                    <li>
                      <a href="/solutions/dirty-data/">
                        Siloed and dirty CRM data
                      </a>
                    </li>

                    <li>
                      <a href="/solutions/misalignment/">
                        Executive misalignment
                      </a>
                    </li>
                  </ul>
                </section>

                <section class="link-column">
                  <p class="menu-label">By scale and scope</p>

                  <ul>
                    <li>
                      <a href="/solutions/enterprise/">
                        Enterprise architecture
                      </a>
                    </li>

                    <li>
                      <a href="/solutions/mid-market/">
                        Growth-stage consolidation
                      </a>
                    </li>

                    <li>
                      <a href="/solutions/governance/">
                        Regulated-market governance
                      </a>
                    </li>
                  </ul>
                </section>
              </div>
            </div>
          </div>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="ai-tooling-menu"
            >
              <span>AI tooling</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
