              </svg>
            </button>

            <div id="ai-tooling-menu" class="mega-menu" data-mega-menu hidden>
              <div class="mega-menu-inner">
                <section class="featured-column">
                  <p class="menu-label">System safety</p>
                  <h2>Model orchestration</h2>

                  <p>
                    Build controlled AI workflows with clear boundaries,
                    observable decisions, and accountable human oversight.
                  </p>

                  <a href="/ai-tooling/" class="menu-cta">
                    Explore AI tooling
                    <span aria-hidden="true">→</span>
                  </a>
                </section>

                <section class="link-column">
                  <p class="menu-label">Governance systems</p>

                  <ul>
                    <li>
                      <a href="/ai-tooling/prompt-guard/"> Prompt firewalls </a>
                    </li>

                    <li>
                      <a href="/ai-tooling/hallucination/">
                        Variance tracing
                      </a>
                    </li>

                    <li>
                      <a href="/ai-tooling/compliance/"> PII scrubbing </a>
                    </li>
                  </ul>
                </section>

                <section class="link-column">
                  <p class="menu-label">Human-in-the-loop systems</p>

                  <ul>
                    <li>
                      <a href="/ai-tooling/co-pilot/"> Agent copilots </a>
                    </li>

                    <li>
                      <a href="/ai-tooling/feedback/">
                        Behavioral feedback loops
                      </a>
                    </li>
                  </ul>
                </section>
              </div>
            </div>
          </div>

          <a
            href="/governance/"
            class="primary-link"
            aria-current={isCurrentSection("/governance/") ? "page" : undefined}
          >
            Governance
          </a>

          <a
            href="/advisory/"
            class="primary-link"
            aria-current={isCurrentSection("/advisory/") ? "page" : undefined}
          >
            Advisory
          </a>

          <a
            href="/blog/"
            class="primary-link"
            aria-current={isCurrentSection("/blog/") ? "page" : undefined}
          >
            Blog
          </a>
        </nav>

        <a
          href="/contact/"
          class="header-cta"
          aria-current={isCurrentPage("/contact/") ? "page" : undefined}
        >
          Start a conversation
        </a>
      </div>
    </div>
  </div>

  <div class="mobile-header">
    <button
      id="mobile-menu-trigger"
      class="mobile-menu-trigger"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-navigation"
    >
      <svg
        class="menu-icon menu-icon-open"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>

      <svg
        class="menu-icon menu-icon-close"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        style="display: none"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m6 6 12 12M18 6 6 18"></path>
      </svg>
    </button>

    <a
      href="/"
      class="mobile-brand-link"
      aria-label="Cadence Lab home"
      aria-current={isCurrentPage("/") ? "page" : undefined}
    >
      <img
        src={wordmark.src ?? wordmark}
        alt=""
        width="136"
        height="27"
        class="mobile-wordmark"
      />
    </a>

    <a href="/fit-check/" class="mobile-cta"> Fit check </a>
  </div>

  <div
    id="mobile-navigation"
    class="mobile-navigation"
    aria-hidden="true"
    hidden
  >
    <nav class="mobile-navigation-inner" aria-label="Mobile navigation">
      <a href="/fit-check/">Fit check</a>
      <a href="/workflows/">Workflows</a>
      <a href="/solutions/">Solutions</a>
      <a href="/ai-tooling/">AI tooling</a>
      <a href="/governance/">Governance</a>
      <a href="/advisory/">Advisory</a>
      <a href="/blog/">Blog</a>

      <div class="mobile-navigation-footer">
        <a href="/support/">Support</a>
        <a href="/contact/">Contact</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const initializeHeader = () => {
    const header = document.querySelector<HTMLElement>(".site-header");

    if (!header || header.dataset.initialized === "true") {
      return;
    }

    header.dataset.initialized = "true";

    const mobileTrigger = header.querySelector<HTMLButtonElement>(
      "#mobile-menu-trigger",
    );

    const mobileNavigation =
      header.querySelector<HTMLElement>("#mobile-navigation");

    const openIcon = header.querySelector<SVGElement>(".menu-icon-open");

    const closeIcon = header.querySelector<SVGElement>(".menu-icon-close");

    const navigationGroups =
      header.querySelectorAll<HTMLElement>(".navigation-group");

    const closeDesktopMenus = (exception?: HTMLElement) => {
      navigationGroups.forEach((group) => {
        if (group === exception) {
          return;
        }

        const trigger = group.querySelector<HTMLButtonElement>(
          ".navigation-trigger",
        );

        const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

        trigger?.setAttribute("aria-expanded", "false");

        if (menu) {
          menu.hidden = true;
        }
      });
    };

    navigationGroups.forEach((group) => {
      const trigger = group.querySelector<HTMLButtonElement>(
        ".navigation-trigger",
      );

      const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

      if (!trigger || !menu) {
        return;
      }

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();

        const shouldOpen = trigger.getAttribute("aria-expanded") !== "true";

        closeDesktopMenus(group);

        trigger.setAttribute("aria-expanded", String(shouldOpen));
        menu.hidden = !shouldOpen;
      });
    });

    const setMobileMenuState = (isOpen: boolean) => {
      if (!mobileTrigger || !mobileNavigation) {
        return;
      }

      mobileTrigger.setAttribute("aria-expanded", String(isOpen));
      mobileTrigger.setAttribute(
        "aria-label",
        isOpen ? "Close navigation menu" : "Open navigation menu",
      );

      mobileNavigation.hidden = !isOpen;
      mobileNavigation.setAttribute("aria-hidden", String(!isOpen));

      if (openIcon) {
        (openIcon as unknown as HTMLElement).hidden = isOpen;
      }

      if (closeIcon) {
        (closeIcon as unknown as HTMLElement).hidden = !isOpen;
      }

      document.documentElement.classList.toggle(
        "mobile-navigation-open",
        isOpen,
      );
    };

    mobileTrigger?.addEventListener("click", (event) => {
      event.stopPropagation();

      const isOpen = mobileTrigger.getAttribute("aria-expanded") !== "true";

      setMobileMenuState(isOpen);
      closeDesktopMenus();
    });

    mobileNavigation?.addEventListener("click", (event) => {
      event.stopPropagation();

      const target = event.target;

      if (target instanceof HTMLAnchorElement) {
        setMobileMenuState(false);
      }
    });

    document.addEventListener("click", () => {
      closeDesktopMenus();
      setMobileMenuState(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeDesktopMenus();
        setMobileMenuState(false);
        mobileTrigger?.focus();
      }
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 60rem)").matches) {
        setMobileMenuState(false);
      }
    });
  };

  document.addEventListener("astro:page-load", initializeHeader);
  initializeHeader();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    color: var(--color-text);
    font-family: var(--font-sans);
    backdrop-filter: blur(0.75rem);
  }

  .desktop-header {
    display: grid;
    grid-template-columns: minmax(13.5rem, 15rem) minmax(0, 1fr);
    min-height: 6.5rem;
  }

  .brand-zone {
    display: flex;
    align-items: center;
    padding-inline: clamp(1.5rem, 3vw, 2.5rem);
    border-right: 1px solid var(--color-border);
  }

  .brand-link,
  .mobile-brand-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: inherit;
    text-decoration: none;
  }

  .desktop-wordmark {
    width: clamp(8.5rem, 10vw, 11.25rem);
    height: auto;
  }

  .header-navigation {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .utility-row {
    display: flex;
    min-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
    border-bottom: 1px solid var(--color-border);
  }

  .search-form {
    position: relative;
    width: min(100%, 25rem);
  }

  .search-icon {
    position: absolute;
    top: 50%;
    left: 0.875rem;
    width: 1rem;
    height: 1rem;
    color: var(--color-text-subtle);
    pointer-events: none;
    transform: translateY(-50%);
  }

  .search-input {
    width: 100%;
    min-height: 2.25rem;
    padding: 0.5rem 1rem 0.5rem 2.625rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: var(--color-surface-subtle);
    color: var(--color-text);
    font-size: 0.8125rem;
    line-height: 1.3;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .search-input:hover {
    border-color: var(--color-border-strong);
  }

  .search-input:focus {
    border-color: var(--color-blue);
    background: var(--color-surface-pure);
    outline: 2px solid transparent;
  }

  .utility-navigation {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 1.5rem;
  }

  .utility-navigation a {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    text-decoration: none;
  }

  .utility-navigation a:hover,
  .utility-navigation a[aria-current="page"] {
    color: var(--color-blue);
  }

  .primary-row {
    display: flex;
    min-height: 3rem;
    align-items: stretch;
    justify-content: space-between;
  }

  .primary-navigation {
    display: flex;
    min-width: 0;
    align-items: stretch;
    padding-left: clamp(0.75rem, 2vw, 1.75rem);
  }

  .primary-link,
  .navigation-trigger {
    display: inline-flex;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding-inline: clamp(0.7rem, 1.3vw, 1.25rem);
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  .primary-link:hover,
  .primary-link[aria-current="page"],
  .navigation-trigger:hover,
  .navigation-trigger[aria-expanded="true"] {
    background: var(--color-surface-subtle);
    color: var(--color-blue);
  }

  .navigation-group {
    position: static;
    display: flex;
  }

  .expand-icon {
    width: 0.6875rem;
    height: 0.6875rem;
    color: currentColor;
    transition: transform var(--transition-standard);
  }

  .navigation-trigger[aria-expanded="true"] .expand-icon {
    transform: rotate(180deg);
  }

  .header-cta {
    display: inline-flex;
    min-height: 3rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    padding-inline: clamp(1.25rem, 3vw, 3rem);
    background: var(--color-blue);
    color: var(--color-light);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .header-cta:hover {
    background: color-mix(in srgb, var(--color-blue) 82%, var(--color-ink));
    color: var(--color-light);
  }

  .mega-menu {
    position: absolute;
    top: 6.5rem;
    left: 0;
    width: 100%;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-pure);
    box-shadow: var(--shadow-lg);
  }

  .mega-menu[hidden] {
    display: none;
  }

  .mega-menu-inner {
    display: grid;
    grid-template-columns: minmax(16rem, 1.2fr) repeat(2, minmax(12rem, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
    width: min(calc(100% - (2 * var(--page-gutter))), 75rem);
    margin-inline: auto;
    padding-block: 2.5rem;
  }

  .featured-column {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.875rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface-subtle);
  }

  .menu-label {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
  }

  .featured-column h2 {
    margin: 0;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .featured-column > p:not(.menu-label) {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .menu-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    color: var(--color-blue);
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
  }

  .menu-cta:hover {
    text-decoration: underline;
  }

  .link-column {
    min-width: 0;
  }

  .link-column .menu-label {
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }

  .link-column ul {
    display: grid;
    gap: 0.75rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .link-column a {
    color: var(--color-text);
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.4;
    text-decoration: none;
  }

  .link-column a:hover {
    color: var(--color-blue);
  }

  .mobile-header,
  .mobile-navigation {
    display: none;
  }

  @media (max-width: 74rem) and (min-width: 60rem) {
    .desktop-header {
      grid-template-columns: 12rem minmax(0, 1fr);
    }

    .brand-zone {
      padding-inline: 1.25rem;
    }

    .desktop-wordmark {
      width: 9rem;
    }

    .primary-link,
    .navigation-trigger {
      padding-inline: 0.65rem;
      font-size: 0.75rem;
    }

    .header-cta {
      padding-inline: 1.25rem;
    }
  }

  @media (max-width: 59.9375rem) {
    .desktop-header {
      display: none;
    }

    .mobile-header {
      display: grid;
      grid-template-columns: 2.75rem minmax(0, 1fr) auto;
      min-height: 4rem;
      align-items: center;
      gap: 1rem;
      padding-inline: var(--page-gutter);
    }

    .mobile-menu-trigger {
      display: inline-flex;
      width: 2.75rem;
      height: 2.75rem;
      align-items: center;
      justify-content: center;
      padding: 0;
      border: 0;
      background: transparent;
      color: var(--color-text);
    }

    .menu-icon {
      width: 1.5rem;
      height: 1.5rem;
    }

    .mobile-brand-link {
      justify-self: start;
    }

    .mobile-wordmark {
      width: clamp(7.5rem, 28vw, 8.5rem);
      height: auto;
    }

    .mobile-cta {
      display: inline-flex;
