---
import wordmark from "../assets/brand/cadencelab-wordmark-light-color.svg";

interface NavigationItem {
  label: string;
  href: string;
  status?: string;
}

interface NavigationGroup {
  label: string;
  menuId: string;
  eyebrow: string;
  heading: string;
  description: string;
  items: NavigationItem[];
  compact?: boolean;
}

const currentPath = Astro.url.pathname;

const normalizePath = (path: string): string => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isCurrentPage = (href: string): boolean =>
  normalizePath(currentPath) === normalizePath(href);

const isCurrentSection = (href: string): boolean => {
  if (href === "/") return isCurrentPage("/");
  return normalizePath(currentPath).startsWith(normalizePath(href));
};

const navigationGroups: NavigationGroup[] = [
  {
    label: "About",
    menuId: "about-menu",
    eyebrow: "About Cadence Lab",
    heading: "Built around better experiences",
    description:
      "Learn more about the perspective and experience behind Cadence Lab.",
    compact: true,
    items: [
      {
        label: "Bio",
        href: "/about/",
        status: "Coming soon",
      },
    ],
  },
  {
    label: "Product",
    menuId: "product-menu",
    eyebrow: "Product",
    heading: "Build experiences that work in practice",
    description:
      "Explore focused experience offerings designed around the systems, moments, and decisions that shape how people interact with organizations.",
    items: [
      {
        label: "Experience Foundations",
        href: "/product/experience-foundations/",
      },
      {
        label: "AI Experience",
        href: "/product/ai-experience/",
      },
      {
        label: "Digital Experiences",
        href: "/product/digital-experiences/",
      },
      {
        label: "CX on Location",
        href: "/product/cx-on-location/",
      },
    ],
  },
  {
    label: "Solutions",
    menuId: "solutions-menu",
    eyebrow: "Solutions",
    heading: "Start with the problem you need to solve",
    description:
      "Find a path based on where you operate, who owns the experience, or the outcome your organization needs to improve.",
    items: [
      {
        label: "By industry",
        href: "/solutions/industry/",
      },
      {
        label: "By team",
        href: "/solutions/team/",
      },
      {
        label: "By use case",
        href: "/solutions/use-case/",
      },
    ],
  },
  {
    label: "Free resources",
    menuId: "resources-menu",
    eyebrow: "Free resources",
    heading: "Useful tools without the noise",
    description:
      "Practical resources for people working across customer experience, digital systems, and applied AI.",
    compact: true,
    items: [
      {
        label: "List of AI tools",
        href: "/resources/ai-tools/",
        status: "Coming soon",
      },
    ],
  },
];

const groupIsCurrent = (group: NavigationGroup): boolean =>
  group.items.some((item) => isCurrentSection(item.href));
---

<header class="site-header" data-site-header>
  <div class="desktop-header">
    <div class="brand-zone">
      <a
        href="/"
        class="brand-link"
        aria-label="Cadence Lab home"
        aria-current={isCurrentPage("/") ? "page" : undefined}
      >
        <img
          src={wordmark.src ?? wordmark}
          alt=""
          width="3000"
          height="413"
          class="desktop-wordmark"
        />
      </a>
    </div>

    <div class="header-navigation">
      <div class="utility-row">
        <search class="site-search">
          <form class="search-form" action="/search/" method="get">
            <label class="visually-hidden" for="desktop-site-search">
              Search Cadence Lab
            </label>

            <input
              id="desktop-site-search"
              class="search-input"
              type="search"
              name="q"
              placeholder="Search insights and resources"
            />

            <button class="search-submit" type="submit">
              <span class="visually-hidden">Submit search</span>
              <svg
                aria-hidden="true"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m21 21-4.35-4.35m2.35-6.15a8.5 8.5 0 1 1-17 0 8.5 8.5 0 0 1 17 0Z"
                ></path>
              </svg>
            </button>
          </form>
        </search>

        <nav class="utility-navigation" aria-label="Utility">
          <ul role="list">
            <li>
              <a
                href="/support/"
                aria-current={isCurrentPage("/support/") ? "page" : undefined}
              >
                Support
              </a>
            </li>
            <li>
              <a
                href="/contact/"
                aria-current={isCurrentPage("/contact/") ? "page" : undefined}
              >
                Contact
              </a>
            </li>
          </ul>
        </nav>
      </div>

      <div class="primary-row">
        <nav class="primary-navigation" aria-label="Primary">
          <ul class="primary-navigation-list" role="list">
            <li>
              <a
                href="/fit-check/"
                class="primary-link"
                aria-current={
                  isCurrentSection("/fit-check/") ? "page" : undefined
                }
              >
                Fit Check™
              </a>
            </li>

            {
              navigationGroups.slice(0, 3).map((group) => (
                <li
                  class="navigation-group"
                  data-navigation-group
                  data-current-section={groupIsCurrent(group) ? "true" : undefined}
                >
                  <button
                    class="navigation-trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls={group.menuId}
                  >
                    <span>{group.label}</span>
                    {groupIsCurrent(group) && (
                      <span class="visually-hidden">, current section</span>
                    )}
                    <svg
                      class="expand-icon"
                      aria-hidden="true"
                      viewBox="0 0 20 20"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m5 7.5 5 5 5-5"
                      ></path>
                    </svg>
                  </button>

                  <div
                    id={group.menuId}
                    class:list={[
                      "mega-menu",
                      { "mega-menu-compact": group.compact },
                    ]}
                    data-mega-menu
                    hidden
                  >
                    <div
                      class:list={[
                        "mega-menu-inner",
                        { "mega-menu-inner-compact": group.compact },
                      ]}
                    >
                      <div class="featured-column">
                        <p class="menu-label">{group.eyebrow}</p>
                        <p class="menu-heading">{group.heading}</p>
                        <p class="menu-description">{group.description}</p>
                      </div>

                      <div class="link-column">
                        <p class="menu-label">
                          {group.compact ? group.label : `Explore ${group.label.toLowerCase()}`}
                        </p>

                        <ul
                          class:list={[
                            "menu-link-list",
                            { "menu-link-grid": !group.compact },
                          ]}
                          role="list"
                        >
                          {group.items.map((item) => (
                            <li>
                              <a
                                href={item.href}
                                aria-current={
                                  isCurrentSection(item.href)
                                    ? "page"
                                    : undefined
                                }
                              >
                                <span class="menu-link-label">{item.label}</span>

                                {item.status ? (
                                  <span class="menu-status">{item.status}</span>
                                ) : (
                                  <svg
                                    class="menu-link-arrow"
                                    aria-hidden="true"
                                    viewBox="0 0 20 20"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M4 10h11m-4-4 4 4-4 4"
                                    ></path>
                                  </svg>
                                )}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  </div>
                </li>
              ))
            }

            <li>
              <a
                href="/blog/"
                class="primary-link"
                aria-current={isCurrentSection("/blog/") ? "page" : undefined}
              >
                Insights
              </a>
            </li>

            {
              navigationGroups.slice(3).map((group) => (
                <li
                  class="navigation-group"
                  data-navigation-group
                  data-current-section={groupIsCurrent(group) ? "true" : undefined}
                >
                  <button
                    class="navigation-trigger"
                    type="button"
                    aria-expanded="false"
                    aria-controls={group.menuId}
                  >
                    <span>{group.label}</span>
                    {groupIsCurrent(group) && (
                      <span class="visually-hidden">, current section</span>
                    )}
                    <svg
                      class="expand-icon"
                      aria-hidden="true"
                      viewBox="0 0 20 20"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m5 7.5 5 5 5-5"
                      ></path>
                    </svg>
                  </button>

                  <div
                    id={group.menuId}
                    class="mega-menu mega-menu-compact"
                    data-mega-menu
                    hidden
                  >
                    <div class="mega-menu-inner mega-menu-inner-compact">
                      <div class="featured-column">
                        <p class="menu-label">{group.eyebrow}</p>
                        <p class="menu-heading">{group.heading}</p>
                        <p class="menu-description">{group.description}</p>
                      </div>

                      <div class="link-column">
                        <p class="menu-label">{group.label}</p>
                        <ul class="menu-link-list" role="list">
                          {group.items.map((item) => (
                            <li>
                              <a
                                href={item.href}
                                aria-current={
                                  isCurrentSection(item.href)
                                    ? "page"
                                    : undefined
                                }
                              >
                                <span class="menu-link-label">{item.label}</span>
                                {item.status && (
                                  <span class="menu-status">{item.status}</span>
                                )}
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  </div>
                </li>
              ))
            }
          </ul>
        </nav>

        <a
          href="/contact/"
          class="header-cta"
          aria-current={isCurrentPage("/contact/") ? "page" : undefined}
        >
          Start a conversation
        </a>
      </div>
    </div>
  </div>

  <div class="mobile-header">
    <button
      class="mobile-menu-trigger"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-navigation"
      data-mobile-menu-trigger
    >
      <svg
        class="menu-icon menu-icon-open"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"
        ></path>
      </svg>

      <svg
        class="menu-icon menu-icon-close"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m6 6 12 12M18 6 6 18"
        ></path>
      </svg>
    </button>

    <a
      href="/"
      class="mobile-brand-link"
      aria-label="Cadence Lab home"
      aria-current={isCurrentPage("/") ? "page" : undefined}
    >
      <img
        src={wordmark.src ?? wordmark}
        alt=""
        width="3000"
        height="413"
        class="mobile-wordmark"
      />
    </a>

    <a
      href="/fit-check/"
      class="mobile-cta"
      aria-current={isCurrentSection("/fit-check/") ? "page" : undefined}
    >
      Fit Check™
    </a>
  </div>

  <div
    id="mobile-navigation"
    class="mobile-navigation"
    data-mobile-navigation
    hidden
    inert
  >
    <div class="mobile-navigation-inner">
      <search class="mobile-search">
        <form class="mobile-search-form" action="/search/" method="get">
          <label class="visually-hidden" for="mobile-site-search">
            Search Cadence Lab
          </label>
          <input
            id="mobile-site-search"
            class="mobile-search-input"
            type="search"
            name="q"
            placeholder="Search insights and resources"
          />
          <button class="mobile-search-submit" type="submit">
            <span class="visually-hidden">Submit search</span>
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m21 21-4.35-4.35m2.35-6.15a8.5 8.5 0 1 1-17 0 8.5 8.5 0 0 1 17 0Z"
              ></path>
            </svg>
          </button>
        </form>
      </search>

      <nav aria-label="Mobile primary">
        <ul class="mobile-navigation-list" role="list">
          <li>
            <a
              href="/fit-check/"
              class="mobile-primary-link"
              aria-current={
                isCurrentSection("/fit-check/") ? "page" : undefined
              }
            >
              Fit Check™
            </a>
          </li>

          {navigationGroups.slice(0, 3).map((group) => (
            <li>
              <details
                class="mobile-navigation-group"
                data-current-section={groupIsCurrent(group) ? "true" : undefined}
              >
                <summary>
                  <span>{group.label}</span>
                  {groupIsCurrent(group) && (
                    <span class="visually-hidden">, current section</span>
                  )}
                  <svg
                    class="mobile-expand-icon"
                    aria-hidden="true"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m5 7.5 5 5 5-5"
                    ></path>
                  </svg>
                </summary>

                <ul class="mobile-submenu" role="list">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        aria-current={
                          isCurrentSection(item.href) ? "page" : undefined
                        }
                      >
                        <span>{item.label}</span>
                        {item.status && (
                          <span class="mobile-menu-status">{item.status}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          ))}

          <li>
            <a
              href="/blog/"
              class="mobile-primary-link"
              aria-current={isCurrentSection("/blog/") ? "page" : undefined}
            >
              Insights
            </a>
          </li>

          {navigationGroups.slice(3).map((group) => (
            <li>
              <details
                class="mobile-navigation-group"
                data-current-section={groupIsCurrent(group) ? "true" : undefined}
              >
                <summary>
                  <span>{group.label}</span>
                  {groupIsCurrent(group) && (
                    <span class="visually-hidden">, current section</span>
                  )}
                  <svg
                    class="mobile-expand-icon"
                    aria-hidden="true"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="m5 7.5 5 5 5-5"
                    ></path>
                  </svg>
                </summary>

                <ul class="mobile-submenu" role="list">
                  {group.items.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        aria-current={
                          isCurrentSection(item.href) ? "page" : undefined
                        }
                      >
                        <span>{item.label}</span>
                        {item.status && (
                          <span class="mobile-menu-status">{item.status}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            </li>
          ))}
        </ul>
      </nav>

      <nav class="mobile-utility-navigation" aria-label="Mobile utility">
        <ul role="list">
          <li><a href="/support/">Support</a></li>
          <li><a href="/contact/">Contact</a></li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  type CadenceWindow = Window & {
    __cadenceHeaderController?: AbortController;
    __cadenceHeaderLoader?: EventListener;
  };

  const cadenceWindow = window as CadenceWindow;

  const initializeHeader = () => {
    cadenceWindow.__cadenceHeaderController?.abort();

    const controller = new AbortController();
    cadenceWindow.__cadenceHeaderController = controller;
    const { signal } = controller;

    const header = document.querySelector<HTMLElement>("[data-site-header]");

    if (!header) return;

    const mobileTrigger = header.querySelector<HTMLButtonElement>(
      "[data-mobile-menu-trigger]",
    );
    const mobileNavigation = header.querySelector<HTMLElement>(
      "[data-mobile-navigation]",
    );
    const navigationGroups = Array.from(
      header.querySelectorAll<HTMLElement>("[data-navigation-group]"),
    );
    const mobileDetails = Array.from(
      header.querySelectorAll<HTMLDetailsElement>(
        ".mobile-navigation-group",
      ),
    );
    const desktopMediaQuery = window.matchMedia("(min-width: 60rem)");
    const collapseThreshold = 96;
    const expandDistance = 28;

    let activeDesktopTrigger: HTMLButtonElement | null = null;
    let lastScrollY = window.scrollY;
    let upwardDistance = 0;
    let scrollFrameRequested = false;
    let collapseSuppressedUntil = 0;

    const setDesktopHeaderState = (isCollapsed: boolean) => {
      if (!desktopMediaQuery.matches) {
        header.classList.remove("is-collapsed");
        return;
      }

      header.classList.toggle("is-collapsed", isCollapsed);
    };

    const updateDesktopHeaderOnScroll = () => {
      scrollFrameRequested = false;

      if (!desktopMediaQuery.matches) {
        setDesktopHeaderState(false);
        lastScrollY = window.scrollY;
        upwardDistance = 0;
        return;
      }

      const currentScrollY = window.scrollY;
      const delta = currentScrollY - lastScrollY;

      if (currentScrollY <= collapseThreshold) {
        setDesktopHeaderState(false);
        upwardDistance = 0;
      } else if (delta > 0) {
        if (Date.now() >= collapseSuppressedUntil) {
          setDesktopHeaderState(true);
        }
        upwardDistance = 0;
      } else if (delta < 0) {
        upwardDistance += Math.abs(delta);

        if (upwardDistance >= expandDistance) {
          setDesktopHeaderState(false);
          collapseSuppressedUntil = Date.now() + 260;
          upwardDistance = 0;
        }
      }

      lastScrollY = currentScrollY;
    };

    const requestDesktopHeaderUpdate = () => {
      if (scrollFrameRequested) return;

      scrollFrameRequested = true;
      window.requestAnimationFrame(updateDesktopHeaderOnScroll);
    };

    const closeDesktopMenus = (restoreFocus = false) => {
      const triggerToRestore = activeDesktopTrigger;

      navigationGroups.forEach((group) => {
        const trigger = group.querySelector<HTMLButtonElement>(
          ".navigation-trigger",
        );
        const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

        trigger?.setAttribute("aria-expanded", "false");
        if (menu) menu.hidden = true;
      });

      activeDesktopTrigger = null;

      if (restoreFocus) triggerToRestore?.focus();
    };

    const setMobileMenuState = (isOpen: boolean, restoreFocus = false) => {
      if (!mobileTrigger || !mobileNavigation) return;

      mobileTrigger.setAttribute("aria-expanded", String(isOpen));
      mobileTrigger.setAttribute(
        "aria-label",
        isOpen ? "Close navigation menu" : "Open navigation menu",
      );

      mobileNavigation.hidden = !isOpen;
      mobileNavigation.toggleAttribute("inert", !isOpen);
      document.documentElement.classList.toggle(
        "mobile-navigation-open",
        isOpen,
      );

      if (!isOpen) {
        mobileDetails.forEach((details) => details.removeAttribute("open"));
      }

      if (restoreFocus) mobileTrigger.focus();
    };

    navigationGroups.forEach((group) => {
      const trigger = group.querySelector<HTMLButtonElement>(
        ".navigation-trigger",
      );
      const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

      if (!trigger || !menu) return;

      trigger.addEventListener(
        "click",
        () => {
          const shouldOpen = trigger.getAttribute("aria-expanded") !== "true";

          closeDesktopMenus();

          if (shouldOpen) {
            trigger.setAttribute("aria-expanded", "true");
            menu.hidden = false;
            activeDesktopTrigger = trigger;
          }
        },
        { signal },
      );
    });

    mobileTrigger?.addEventListener(
      "click",
      () => {
        const shouldOpen =
          mobileTrigger.getAttribute("aria-expanded") !== "true";

        closeDesktopMenus();
        setMobileMenuState(shouldOpen);
      },
      { signal },
    );

    mobileNavigation?.addEventListener(
      "click",
      (event) => {
        if (
          event.target instanceof Element &&
          event.target.closest("a")
        ) {
          setMobileMenuState(false);
        }
      },
      { signal },
    );

    document.addEventListener(
      "pointerdown",
      (event) => {
        if (!(event.target instanceof Node) || header.contains(event.target)) {
          return;
        }

        closeDesktopMenus();
        setMobileMenuState(false);
      },
      { signal },
    );

    document.addEventListener(
      "focusin",
      (event) => {
        if (!(event.target instanceof Node)) return;

        const activeGroup = event.target.parentElement?.closest(
          "[data-navigation-group]",
        );

        if (!activeGroup) closeDesktopMenus();
      },
      { signal },
    );

    document.addEventListener(
      "keydown",
      (event) => {
        if (event.key !== "Escape") return;

        if (activeDesktopTrigger) {
          event.preventDefault();
          closeDesktopMenus(true);
          return;
        }

        if (mobileTrigger?.getAttribute("aria-expanded") === "true") {
          event.preventDefault();
          setMobileMenuState(false, true);
        }
      },
      { signal },
    );

    const handleViewportChange = () => {
      closeDesktopMenus();
      setMobileMenuState(false);
      setDesktopHeaderState(false);
      lastScrollY = window.scrollY;
      upwardDistance = 0;
      collapseSuppressedUntil = 0;
    };

    desktopMediaQuery.addEventListener("change", handleViewportChange, {
      signal,
    });

    window.addEventListener("scroll", requestDesktopHeaderUpdate, {
      passive: true,
      signal,
    });

    updateDesktopHeaderOnScroll();
  };

  if (cadenceWindow.__cadenceHeaderLoader) {
    document.removeEventListener(
      "astro:page-load",
      cadenceWindow.__cadenceHeaderLoader,
    );
  }

  const headerLoader: EventListener = () => initializeHeader();
  cadenceWindow.__cadenceHeaderLoader = headerLoader;
  document.addEventListener("astro:page-load", headerLoader);
  initializeHeader();
</script>

<style>
  .site-header {
    --desktop-header-height: 6.5rem;
    --desktop-primary-row-height: 3.5rem;

    position: sticky;
    inset-block-start: 0;
    z-index: 100;
    inline-size: 100%;
    border-block-end: var(--border-width) solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    font-family: var(--ff-sans);
    font-feature-settings: var(--fea-graphik);
  }

  .desktop-header {
    display: grid;
    grid-template-columns: minmax(12rem, 14rem) minmax(0, 1fr);
    min-block-size: var(--desktop-header-height);
    transition: min-block-size var(--transition-standard);
  }

  .brand-zone {
    display: flex;
    align-items: center;
    padding-inline: clamp(1.25rem, 2.5vw, 2.25rem);
    border-inline-end: var(--border-width) solid var(--color-border);
  }

  .brand-link,
  .mobile-brand-link {
    display: inline-flex;
    inline-size: fit-content;
    align-items: center;
    color: inherit;
    text-decoration: none;
  }

  .desktop-wordmark {
    inline-size: clamp(8.5rem, 10vw, 10.75rem);
    block-size: auto;
    transition: inline-size var(--transition-standard);
  }

  .header-navigation {
    display: flex;
    min-inline-size: 0;
    flex-direction: column;
  }

  .utility-row {
    display: flex;
    min-block-size: 3rem;
    max-block-size: 3rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    overflow: hidden;
