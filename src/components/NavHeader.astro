---
// src/components/NavHeader.astro
---
<header class="gh-header">
  <!-- Desktop Layout (Matches Monotype Spec) -->
  <div class="desktop-nav">
    
    <!-- Left branding zone -->
    <div class="brand-zone">
      <a href="/" class="brand-logo" title="Go to Homepage">
        Cadence<span class="logo-accent">Lab</span>
      </a>
    </div>

    <!-- Right utility canvas -->
    <div class="utility-canvas">
      
      <!-- Top Tier: Search Core & Global Links -->
      <div class="top-tier">
        <div class="search-wrapper">
          <span class="search-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input 
            id="edit-search" 
            class="search-input" 
            type="text" 
            placeholder="Find solutions (i.e., workflows, automation, data)" 
            name="search" 
          />
        </div>

        <div class="meta-links">
          <a href="/support" class="meta-link">Support</a>
          <span class="meta-divider">|</span>
          <span class="lang-selector">EN</span>
          <button class="login-button">
            Login
            <span class="arrow-icon"></span>
          </button>
        </div>
      </div>

      <!-- Bottom Tier: Navigation Links & Sales CTA -->
      <div class="bottom-tier">
        <nav class="primary-menu" aria-label="Primary navigation">
          <a href="/fit-check" class="menu-link active-link">Fit Check</a>
          <a href="/workflows" class="menu-link">Workflows</a>
          <a href="/solutions" class="menu-link">Solutions</a>
          <a href="/ai-tooling" class="menu-link">AI Tooling</a>
          <a href="/governance" class="menu-link">Governance</a>
          <a href="/advisory" class="menu-link">Advisory</a>
        </nav>

        <div class="cta-zone">
          <a href="/contact" class="sales-cta" title="Speak to sales">Speak to sales</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Mobile Layout -->
  <div class="mobile-nav">
    <div class="mobile-left">
      <button id="mobile-menu-trigger" class="hamburger-btn" aria-label="Toggle navigation menu">
        <svg class="hamburger-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <a href="/" class="brand-logo mobile-logo">
        Cadence<span>Lab</span>
      </a>
    </div>

    <div class="mobile-right">
      <a href="/fit-check" class="mobile-fit-btn">Fit Check</a>
    </div>
  </div>

  <!-- Mobile Dropdown Drawer -->
  <div id="mobile-navigation-drawer" class="mobile-drawer hidden">
    <nav class="drawer-menu">
      <a href="/fit-check">Fit Check</a>
      <a href="/workflows">Workflows</a>
      <a href="/solutions">Solutions</a>
      <a href="/ai-tooling">AI Tooling</a>
      <a href="/governance">Governance</a>
      <a href="/advisory">Advisory</a>
      <div class="drawer-footer">
        <a href="/support">Support</a>
        <a href="/login" class="drawer-login">Client Login</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-trigger');
  const drawer = document.getElementById('mobile-navigation-drawer');

  if (menuBtn && drawer) {
    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      drawer.classList.toggle('hidden');
    });

    document.addEventListener('click', () => {
      drawer.classList.add('hidden');
    });
  }
</script>

<style>
  /* --- PURE STANDARD CSS SCOPING (No external frameworks required) --- */
  .gh-header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 999;
    background-color: #ffffff;
    color: #1e242c;
    border-bottom: 1px solid #cbd6e2;
  }

  /* --- DESKTOP ENGINE GRID --- */
  .desktop-nav {
    display: grid;
    grid-template-columns: 195px 1fr;
    max-width: 1512px;
    margin: 0 auto;
    height: 105px;
  }

  .brand-zone {
    display: flex;
    align-items: center;
    padding-left: 32px;
    border-r: 1px solid #f5f8fa;
  }

  .brand-logo {
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: #000000;
    text-decoration: none;
    letter-spacing: -0.03em;
  }

  .logo-accent {
    color: #1a73e2;
    font-weight: 300;
  }

  .utility-canvas {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* TOP TIER UTILITIES */
  .top-tier {
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    border-bottom: 1px solid #f5f8fa;
  }

  .search-wrapper {
    position: relative;
    width: 100%;
    max-width: 412px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    opacity: 0.4;
  }

  .search-input {
    width: 100%;
    height: 36px;
    padding: 0 16px 0 42px;
    background-color: #f5f8fa;
    border: 1px solid transparent;
    border-radius: 2px;
    font-size: 13px;
    outline: none;
    transition: all 0.15s ease;
  }

  .search-input:focus {
    background-color: #ffffff;
    border-color: #1a73e2;
  }

  .meta-links {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13.5px;
    color: #576579;
  }

  .meta-link {
    color: inherit;
    text-decoration: none;
  }

  .meta-link:hover, .lang-selector:hover {
    color: #1a73e2;
  }

  .meta-divider {
    color: #cbd6e2;
    user-select: none;
  }

  .lang-selector {
    font-weight: 700;
    cursor: pointer;
  }

  .login-button {
    background: none;
    border: none;
    color: inherit;
    font-size: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* BOTTOM TIER PRIMARY NAV */
  .bottom-tier {
    height: 49px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .primary-menu {
    display: flex;
    padding-left: 16px;
  }

  .menu-link {
    padding: 0 20px;
    font-size: 13px;
    font-weight: 600;
    color: #1e242c;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s ease;
  }

  .menu-link:hover {
    color: #1a73e2;
  }

  .sales-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 49px;
    padding: 0 48px;
    background-color: #1a73e2;
    color: #ffffff;
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .sales-cta:hover {
    background-color: #155ec2;
  }

  /* --- RESPONSIVE ENGINE (Hides Desktop, Activates Mobile) --- */
  .mobile-nav, .mobile-drawer {
    display: none;
  }

  @media (max-width: 950px) {
    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 56px;
      padding: 0 24px;
    }

    .mobile-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .hamburger-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
    }

    .hamburger-svg {
      width: 24px;
      height: 24px;
      color: #1e242c;
    }

    .mobile-fit-btn {
      background-color: #1a73e2;
      color: #ffffff;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 2px;
    }

    /* DROPDOWN DRAWER SETUP */
    .mobile-drawer {
      position: absolute;
      top: 56px;
      left: 0;
      width: 100%;
      background-color: #ffffff;
      border-bottom: 1px solid #cbd6e2;
      box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .mobile-drawer.hidden {
      display: none;
    }

    .drawer-menu {
      display: flex;
      flex-direction: column;
    }

    .drawer-menu a {
      padding: 14px 32px;
      font-size: 14px;
      font-weight: 600;
      color: #1e242c;
      text-decoration: none;
      border-bottom: 1px solid #f5f8fa;
    }

    .drawer-footer {
      background-color: #f5f8fa;
      display: flex;
      justify-content: space-around;
      padding: 16px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .drawer-login {
      color: #1a73e2 !important;
      padding: 0 !important;
      border: none !important;
    }
  }
</style>
