---
import wordmark from "../assets/brand/cadencelab-wordmark-dark-color.svg";

const currentPath = Astro.url.pathname;

const normalizePath = (path: string): string => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isCurrentPage = (href: string): boolean =>
  normalizePath(currentPath) === normalizePath(href);

const isCurrentSection = (href: string): boolean => {
  if (href === "/") return isCurrentPage("/");
  return normalizePath(currentPath).startsWith(normalizePath(href));
};
---

<header class="site-header">
  <div class="desktop-header">
    <div class="brand-zone">
      <a
        href="/"
        class="brand-link"
        aria-label="Cadence Lab home"
        aria-current={isCurrentPage("/") ? "page" : undefined}
      >
        <img
          src={wordmark.src ?? wordmark}
          alt=""
          width="180"
          height="35"
          class="desktop-wordmark"
        />
      </a>
    </div>

    <div class="header-navigation">
      <div class="utility-row">
        <form class="search-form" role="search" action="/search/" method="get">
          <label class="visually-hidden" for="site-search">
            Search Cadence Lab
          </label>

          <svg
            class="search-icon"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m21 21-4.35-4.35m2.35-6.15a8.5 8.5 0 1 1-17 0 8.5 8.5 0 0 1 17 0Z"
            ></path>
          </svg>

          <input
            id="site-search"
            class="search-input"
            type="search"
            name="q"
            placeholder="Search workflows, automation, and data"
            autocomplete="off"
          />
        </form>

        <nav class="utility-navigation" aria-label="Utility navigation">
          <a
            href="/support/"
            aria-current={isCurrentPage("/support/") ? "page" : undefined}
          >
            Support
          </a>

          <a
            href="/contact/"
            aria-current={isCurrentPage("/contact/") ? "page" : undefined}
          >
            Contact
          </a>
        </nav>
      </div>

      <div class="primary-row">
        <nav class="primary-navigation" aria-label="Primary navigation">
          <a
            href="/fit-check/"
            class="primary-link"
            aria-current={isCurrentPage("/fit-check/") ? "page" : undefined}
          >
            Fit check
          </a>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="workflows-menu"
            >
              <span>Workflows</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m5 7.5 5 5 5-5"></path>
              </svg>
            </button>

            <div id="workflows-menu" class="mega-menu" data-mega-menu hidden>
              <div class="mega-menu-inner">
                <section class="featured-column">
                  <p class="menu-label">Operational focus</p>
                  <h2>Workflow architecture</h2>

                  <p>
                    Design customer-facing systems around adoption, trust,
                    measurable outcomes, and reliable human escalation.
                  </p>

                  <a href="/workflows/" class="menu-cta">
                    Explore workflows
                    <span aria-hidden="true">→</span>
                  </a>
                </section>

                <section class="link-column">
                  <p class="menu-label">Core workflows</p>

                  <ul>
                    <li>
                      <a href="/workflows/salesforce/">
                        Salesforce data tracing
                      </a>
                    </li>

                    <li>
                      <a href="/workflows/cross-functional/">
                        Cross-functional handoffs
                      </a>
                    </li>

                    <li>
                      <a href="/workflows/escalation/">
                        SLA escalation mapping
                      </a>
                    </li>

                    <li>
                      <a href="/workflows/agent-routing/">
                        AI-to-human routing
