                </section>
              </div>
            </div>
          </div>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="solutions-menu"
            >
              <span>Solutions</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
