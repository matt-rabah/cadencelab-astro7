---
// src/components/NavHeader.astro
---
<header class="nav-header">
  <div class="nav-container">
    <!-- Brand / Logo (Premium deep ink-charcoal) -->
    <a href="/" class="brand-logo">
      Cadence<span>Lab</span>
    </a>

    <!-- Navigation Menu -->
    <nav class="nav-menu">
      <a href="/work" class="nav-link">Work</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/apply" class="nav-link btn-accent">Apply</a>
    </nav>
  </div>
</header>

<style>
  /* --- PREMIUM GALLERY PALETTE (No Stark Black/White) --- */
  .nav-header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 1000;
    
    /* Luxury translucent alabaster chalk tint */
    background-color: rgba(252, 252, 249, 0.75); 
    
    /* High-performance hardware accelerated blur */
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px); 
    
    /* Soft architectural shadow defines the floating elevation plane */
    box-shadow: 0 8px 32px 0 rgba(22, 22, 22, 0.04);
    border-bottom: 1px solid rgba(22, 22, 22, 0.03);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
  }

  /* --- BRANDING (Ink-Charcoal Emphasis) --- */
  .brand-logo {
    font-family: adobe-clean, sans-serif;
    font-size: 22px;
    font-weight: 900;
    color: #161616; /* Deep ink-charcoal replaces harsh pure black */
    text-decoration: none;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .brand-logo span {
    color: var(--spectrum-global-color-accent, #0265dc);
    font-weight: 300;
  }

  /* --- NAV MENU --- */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 40px; 
  }

  .nav-link {
    font-family: adobe-clean, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #161616;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity 0.15s ease-in-out;
  }

  .nav-link:hover {
    opacity: 0.5;
  }

  /* Premium Call-to-action wrapper */
  .btn-accent {
    background-color: #161616;
    color: #fcfcf9;
    padding: 10px 20px;
    border-radius: 4px;
    font-weight: 600;
    transition: opacity 0.15s ease-in-out;
  }

  .btn-accent:hover {
    opacity: 0.8;
  }

  /* --- 📱 RESPONSIVE SINGLE-TREE MEDIA QUERIES --- */
  @media (max-width: 768px) {
    .nav-container {
      padding: 16px; 
    }

    .nav-menu {
      gap: 24px;
    }

    .nav-link:not(.btn-accent) {
      display: none;
    }
  }
</style>
