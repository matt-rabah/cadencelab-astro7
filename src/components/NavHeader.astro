---
import wordmark from "../assets/brand/cadencelab-wordmark-light-color.svg";

const currentPath = Astro.url.pathname;

const normalizePath = (path: string): string => {
  if (path === "/") return "/";
  return path.endsWith("/") ? path : `${path}/`;
};

const isCurrentPage = (href: string): boolean =>
  normalizePath(currentPath) === normalizePath(href);

const isCurrentSection = (href: string): boolean => {
  if (href === "/") return isCurrentPage("/");
  return normalizePath(currentPath).startsWith(normalizePath(href));
};

const productLinks = [
  {
    label: "Experience Foundations",
    href: "/product/experience-foundations/",
  },
  {
    label: "AI Experience",
    href: "/product/ai-experience/",
  },
  {
    label: "Digital Experiences",
    href: "/product/digital-experiences/",
  },
  {
    label: "CX on Location",
    href: "/product/cx-on-location/",
  },
];

const solutionLinks = [
  {
    label: "By industry",
    href: "/solutions/industry/",
  },
  {
    label: "By team",
    href: "/solutions/team/",
  },
  {
    label: "By use case",
    href: "/solutions/use-case/",
  },
];

const aboutLinks = [
  {
    label: "Bio",
    href: "/about/",
    status: "Coming soon",
  },
];

const resourceLinks = [
  {
    label: "List of AI tools",
    href: "/resources/ai-tools/",
    status: "Coming soon",
  },
];
---

<header class="site-header">
  <div class="desktop-header">
    <div class="brand-zone">
      <a
        href="/"
        class="brand-link"
        aria-label="Cadence Lab home"
        aria-current={isCurrentPage("/") ? "page" : undefined}
      >
        <img
          src={wordmark.src ?? wordmark}
          alt=""
          width="180"
          height="35"
          class="desktop-wordmark"
        />
      </a>
    </div>

    <div class="header-navigation">
      <div class="utility-row">
        <form class="search-form" role="search" action="/search/" method="get">
          <label class="visually-hidden" for="site-search">
            Search Cadence Lab
          </label>

          <svg
            class="search-icon"
            aria-hidden="true"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m21 21-4.35-4.35m2.35-6.15a8.5 8.5 0 1 1-17 0 8.5 8.5 0 0 1 17 0Z"
            ></path>
          </svg>

          <input
            id="site-search"
            class="search-input"
            type="search"
            name="q"
            placeholder="Search Cadence Lab"
            autocomplete="off"
          />
        </form>

        <nav class="utility-navigation" aria-label="Utility navigation">
          <a
            href="/support/"
            aria-current={isCurrentPage("/support/") ? "page" : undefined}
          >
            Support
          </a>

          <a
            href="/contact/"
            aria-current={isCurrentPage("/contact/") ? "page" : undefined}
          >
            Contact
          </a>
        </nav>
      </div>

      <div class="primary-row">
        <nav class="primary-navigation" aria-label="Primary navigation">
          <a
            href="/fit-check/"
            class="primary-link"
            aria-current={isCurrentSection("/fit-check/") ? "page" : undefined}
          >
            Fit Check™
          </a>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="about-menu"
            >
              <span>About</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m5 7.5 5 5 5-5"></path>
              </svg>
            </button>

            <div
              id="about-menu"
              class="mega-menu mega-menu-compact"
              data-mega-menu
              hidden
            >
              <div class="mega-menu-inner mega-menu-inner-compact">
                <section class="featured-column">
                  <p class="menu-label">About Cadence Lab</p>
                  <h2>Built around better experiences</h2>

                  <p>
                    Learn more about the perspective and experience behind
                    Cadence Lab.
                  </p>
                </section>

                <section class="link-column">
                  <p class="menu-label">About</p>

                  <ul class="menu-link-list">
                    {
                      aboutLinks.map((item) => (
                        <li>
                          <a
                            href={item.href}
                            aria-current={
                              isCurrentSection(item.href) ? "page" : undefined
                            }
                          >
                            <span class="menu-link-label">{item.label}</span>

                            {item.status && (
                              <span class="menu-status">{item.status}</span>
                            )}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </section>
              </div>
            </div>
          </div>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="product-menu"
            >
              <span>Product</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m5 7.5 5 5 5-5"></path>
              </svg>
            </button>

            <div id="product-menu" class="mega-menu" data-mega-menu hidden>
              <div class="mega-menu-inner">
                <section class="featured-column">
                  <p class="menu-label">Product</p>
                  <h2>Build experiences that work in practice</h2>

                  <p>
                    Explore focused experience offerings designed around the
                    systems, moments, and decisions that shape how people
                    interact with organizations.
                  </p>
                </section>

                <section class="link-column link-column-wide">
                  <p class="menu-label">Experience solutions</p>

                  <ul class="menu-link-list menu-link-grid">
                    {
                      productLinks.map((item) => (
                        <li>
                          <a
                            href={item.href}
                            aria-current={
                              isCurrentSection(item.href) ? "page" : undefined
                            }
                          >
                            <span class="menu-link-label">{item.label}</span>

                            <svg
                              class="menu-link-arrow"
                              aria-hidden="true"
                              viewBox="0 0 20 20"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.75"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 10h11m-4-4 4 4-4 4"
                              />
                            </svg>
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </section>
              </div>
            </div>
          </div>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="solutions-menu"
            >
              <span>Solutions</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m5 7.5 5 5 5-5"></path>
              </svg>
            </button>

            <div id="solutions-menu" class="mega-menu" data-mega-menu hidden>
              <div class="mega-menu-inner">
                <section class="featured-column">
                  <p class="menu-label">Solutions</p>
                  <h2>Start with the problem you need to solve</h2>

                  <p>
                    Find a path based on where you operate, who owns the
                    experience, or the outcome your organization needs to
                    improve.
                  </p>
                </section>

                <section class="link-column link-column-wide">
                  <p class="menu-label">Explore solutions</p>

                  <ul class="menu-link-list menu-link-grid">
                    {
                      solutionLinks.map((item) => (
                        <li>
                          <a
                            href={item.href}
                            aria-current={
                              isCurrentSection(item.href) ? "page" : undefined
                            }
                          >
                            <span class="menu-link-label">{item.label}</span>

                            <svg
                              class="menu-link-arrow"
                              aria-hidden="true"
                              viewBox="0 0 20 20"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.75"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 10h11m-4-4 4 4-4 4"
                              />
                            </svg>
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </section>
              </div>
            </div>
          </div>

          <a
            href="/blog/"
            class="primary-link"
            aria-current={isCurrentSection("/blog/") ? "page" : undefined}
          >
            Blog
          </a>

          <div class="navigation-group">
            <button
              class="navigation-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="resources-menu"
            >
              <span>Free resources</span>

              <svg
                class="expand-icon"
                aria-hidden="true"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="m5 7.5 5 5 5-5"></path>
              </svg>
            </button>

            <div
              id="resources-menu"
              class="mega-menu mega-menu-compact"
              data-mega-menu
              hidden
            >
              <div class="mega-menu-inner mega-menu-inner-compact">
                <section class="featured-column">
                  <p class="menu-label">Free resources</p>
                  <h2>Useful tools without the noise</h2>

                  <p>
                    Practical resources for people working across customer
                    experience, digital systems, and applied AI.
                  </p>
                </section>

                <section class="link-column">
                  <p class="menu-label">Resources</p>

                  <ul class="menu-link-list">
                    {
                      resourceLinks.map((item) => (
                        <li>
                          <a
                            href={item.href}
                            aria-current={
                              isCurrentSection(item.href) ? "page" : undefined
                            }
                          >
                            <span class="menu-link-label">{item.label}</span>

                            {item.status && (
                              <span class="menu-status">{item.status}</span>
                            )}
                          </a>
                        </li>
                      ))
                    }
                  </ul>
                </section>
              </div>
            </div>
          </div>
        </nav>

        <a
          href="/contact/"
          class="header-cta"
          aria-current={isCurrentPage("/contact/") ? "page" : undefined}
        >
          Start a conversation
        </a>
      </div>
    </div>
  </div>

  <div class="mobile-header">
    <button
      id="mobile-menu-trigger"
      class="mobile-menu-trigger"
      type="button"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-navigation"
    >
      <svg
        class="menu-icon menu-icon-open"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>

      <svg
        class="menu-icon menu-icon-close"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        style="display: none;"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m6 6 12 12M18 6 6 18"></path>
      </svg>
    </button>

    <a
      href="/"
      class="mobile-brand-link"
      aria-label="Cadence Lab home"
      aria-current={isCurrentPage("/") ? "page" : undefined}
    >
      <img
        src={wordmark.src ?? wordmark}
        alt=""
        width="136"
        height="27"
        class="mobile-wordmark"
      />
    </a>

    <a href="/fit-check/" class="mobile-cta">Fit Check™</a>
  </div>

  <div
    id="mobile-navigation"
    class="mobile-navigation"
    aria-hidden="true"
    hidden
  >
    <nav class="mobile-navigation-inner" aria-label="Mobile navigation">
      <a
        href="/fit-check/"
        class="mobile-primary-link"
        aria-current={isCurrentSection("/fit-check/") ? "page" : undefined}
      >
        Fit Check™
      </a>

      <details class="mobile-navigation-group">
        <summary>
          <span>About</span>

          <svg
            class="mobile-expand-icon"
            aria-hidden="true"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m5 7.5 5 5 5-5"></path>
          </svg>
        </summary>

        <div class="mobile-submenu">
          {
            aboutLinks.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrentSection(item.href) ? "page" : undefined}
              >
                <span>{item.label}</span>

                {item.status && (
                  <span class="mobile-menu-status">{item.status}</span>
                )}
              </a>
            ))
          }
        </div>
      </details>

      <details class="mobile-navigation-group">
        <summary>
          <span>Product</span>

          <svg
            class="mobile-expand-icon"
            aria-hidden="true"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m5 7.5 5 5 5-5"></path>
          </svg>
        </summary>

        <div class="mobile-submenu">
          {
            productLinks.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrentSection(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </details>

      <details class="mobile-navigation-group">
        <summary>
          <span>Solutions</span>

          <svg
            class="mobile-expand-icon"
            aria-hidden="true"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m5 7.5 5 5 5-5"></path>
          </svg>
        </summary>

        <div class="mobile-submenu">
          {
            solutionLinks.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrentSection(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </details>

      <a
        href="/blog/"
        class="mobile-primary-link"
        aria-current={isCurrentSection("/blog/") ? "page" : undefined}
      >
        Blog
      </a>

      <details class="mobile-navigation-group">
        <summary>
          <span>Free resources</span>

          <svg
            class="mobile-expand-icon"
            aria-hidden="true"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="m5 7.5 5 5 5-5"></path>
          </svg>
        </summary>

        <div class="mobile-submenu">
          {
            resourceLinks.map((item) => (
              <a
                href={item.href}
                aria-current={isCurrentSection(item.href) ? "page" : undefined}
              >
                <span>{item.label}</span>

                {item.status && (
                  <span class="mobile-menu-status">{item.status}</span>
                )}
              </a>
            ))
          }
        </div>
      </details>

      <div class="mobile-navigation-footer">
        <a href="/support/">Support</a>
        <a href="/contact/">Contact</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const initializeHeader = () => {
    const header = document.querySelector<HTMLElement>(".site-header");

    if (!header || header.dataset.initialized === "true") {
      return;
    }

    header.dataset.initialized = "true";

    const mobileTrigger = header.querySelector<HTMLButtonElement>(
      "#mobile-menu-trigger",
    );

    const mobileNavigation =
      header.querySelector<HTMLElement>("#mobile-navigation");

    const openIcon = header.querySelector<SVGElement>(".menu-icon-open");
    const closeIcon = header.querySelector<SVGElement>(".menu-icon-close");

    const navigationGroups =
      header.querySelectorAll<HTMLElement>(".navigation-group");

    const desktopMediaQuery = window.matchMedia("(min-width: 60rem)");

    const collapseThreshold = 96;
    const expandDistance = 28;

    let lastScrollY = window.scrollY;
    let upwardDistance = 0;
    let scrollFrameRequested = false;

    const setDesktopHeaderState = (isCollapsed: boolean) => {
      if (!desktopMediaQuery.matches) {
        header.classList.remove("is-collapsed");
        return;
      }

      header.classList.toggle("is-collapsed", isCollapsed);
    };

    const updateDesktopHeaderOnScroll = () => {
      scrollFrameRequested = false;

      if (!desktopMediaQuery.matches) {
        setDesktopHeaderState(false);
        lastScrollY = window.scrollY;
        upwardDistance = 0;
        return;
      }

      const currentScrollY = window.scrollY;
      const delta = currentScrollY - lastScrollY;

      if (currentScrollY <= collapseThreshold) {
        setDesktopHeaderState(false);
        upwardDistance = 0;
      } else if (delta > 0) {
        setDesktopHeaderState(true);
        upwardDistance = 0;
      } else if (delta < 0) {
        upwardDistance += Math.abs(delta);

        if (upwardDistance >= expandDistance) {
          setDesktopHeaderState(false);
          upwardDistance = 0;
        }
      }

      lastScrollY = currentScrollY;
    };

    const requestDesktopHeaderUpdate = () => {
      if (scrollFrameRequested) {
        return;
      }

      scrollFrameRequested = true;
      window.requestAnimationFrame(updateDesktopHeaderOnScroll);
    };

    const closeDesktopMenus = (exception?: HTMLElement) => {
      navigationGroups.forEach((group) => {
        if (group === exception) {
          return;
        }

        const trigger = group.querySelector<HTMLButtonElement>(
          ".navigation-trigger",
        );

        const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

        trigger?.setAttribute("aria-expanded", "false");

        if (menu) {
          menu.hidden = true;
        }
      });
    };

    navigationGroups.forEach((group) => {
      const trigger = group.querySelector<HTMLButtonElement>(
        ".navigation-trigger",
      );

      const menu = group.querySelector<HTMLElement>("[data-mega-menu]");

      if (!trigger || !menu) {
        return;
      }

      trigger.addEventListener("click", (event) => {
        event.stopPropagation();

        const shouldOpen = trigger.getAttribute("aria-expanded") !== "true";

        closeDesktopMenus(group);

        trigger.setAttribute("aria-expanded", String(shouldOpen));
        menu.hidden = !shouldOpen;
      });

      menu.addEventListener("click", (event) => {
        event.stopPropagation();
      });
    });

    const setMobileMenuState = (isOpen: boolean) => {
      if (!mobileTrigger || !mobileNavigation) {
        return;
      }

      mobileTrigger.setAttribute("aria-expanded", String(isOpen));

      mobileTrigger.setAttribute(
        "aria-label",
        isOpen ? "Close navigation menu" : "Open navigation menu",
      );

      mobileNavigation.hidden = !isOpen;
      mobileNavigation.setAttribute("aria-hidden", String(!isOpen));

      if (openIcon) {
        openIcon.style.display = isOpen ? "none" : "";
      }

      if (closeIcon) {
        closeIcon.style.display = !isOpen ? "none" : "";
      }

      document.documentElement.classList.toggle(
        "mobile-navigation-open",
        isOpen,
      );
    };

    mobileTrigger?.addEventListener("click", (event) => {
      event.stopPropagation();

      const isOpen = mobileTrigger.getAttribute("aria-expanded") !== "true";

      setMobileMenuState(isOpen);
      closeDesktopMenus();
    });

    mobileNavigation?.addEventListener("click", (event) => {
      event.stopPropagation();

      const target = event.target;

      if (target instanceof HTMLAnchorElement) {
        setMobileMenuState(false);
      }
    });

    document.addEventListener("click", () => {
      closeDesktopMenus();
      setMobileMenuState(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeDesktopMenus();
        setMobileMenuState(false);
        mobileTrigger?.focus();
      }
    });

    window.addEventListener("scroll", requestDesktopHeaderUpdate, {
      passive: true,
    });

    desktopMediaQuery.addEventListener("change", () => {
      setDesktopHeaderState(false);
      lastScrollY = window.scrollY;
      upwardDistance = 0;
    });

    window.addEventListener("resize", () => {
      if (desktopMediaQuery.matches) {
        setMobileMenuState(false);
      } else {
        setDesktopHeaderState(false);
        closeDesktopMenus();
      }
    });

    updateDesktopHeaderOnScroll();
  };

  document.addEventListener("astro:page-load", initializeHeader);
  initializeHeader();
</script>

<style>
  .site-header {
    --desktop-header-height: 6.5rem;
    --desktop-primary-row-height: 3rem;

    position: sticky;
    top: 0;
    z-index: 1000;
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-surface) 96%, transparent);
    color: var(--color-text);
    font-family: var(--ff-sans);
    font-feature-settings: var(--fea-graphik);
    backdrop-filter: blur(0.75rem);
  }

  .desktop-header {
    display: grid;
    grid-template-columns: minmax(13.5rem, 15rem) minmax(0, 1fr);
    min-height: var(--desktop-header-height);
    transition: min-height var(--transition-standard);
  }

  .brand-zone {
    display: flex;
    align-items: center;
    padding-inline: clamp(1.5rem, 3vw, 2.5rem);
    border-right: 1px solid var(--color-border);
    transition:
      padding-inline var(--transition-standard),
      min-height var(--transition-standard);
  }

  .brand-link,
  .mobile-brand-link {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: inherit;
    text-decoration: none;
  }

  .desktop-wordmark {
    width: clamp(8.5rem, 10vw, 11.25rem);
    height: auto;
    transform-origin: left center;
    transition: width var(--transition-standard);
  }

  .header-navigation {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .utility-row {
    display: flex;
    min-height: 3.5rem;
    max-height: 3.5rem;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    overflow: hidden;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
    border-bottom: 1px solid var(--color-border);
    opacity: 1;
    transform: translateY(0);
    transition:
      min-height var(--transition-standard),
      max-height var(--transition-standard),
      opacity var(--transition-fast),
      transform var(--transition-standard),
      border-color var(--transition-standard);
  }

  .search-form {
    position: relative;
    width: min(100%, 25rem);
  }

  .search-icon {
    position: absolute;
    top: 50%;
    left: 0.875rem;
    width: 1rem;
    height: 1rem;
    color: var(--color-text-subtle);
    pointer-events: none;
    transform: translateY(-50%);
  }

  .search-input {
    width: 100%;
    min-height: 2.25rem;
    padding: 0.5rem 1rem 0.5rem 2.625rem;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: var(--color-surface-subtle);
    color: var(--color-text);
    font-family: var(--ff-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-regular);
    line-height: 1.3;
    letter-spacing: 0;
