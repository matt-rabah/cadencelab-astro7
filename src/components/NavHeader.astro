---
// src/components/NavHeader.astro
---
<header class="nav-header">
  <div class="nav-container">
    <!-- Brand / Logo (Stark monochrome typography) -->
    <a href="/" class="brand-logo">
      Cadence<span>Lab</span>
    </a>

    <!-- Navigation Menu -->
    <nav class="nav-menu">
      <a href="/work" class="nav-link">Work</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/apply" class="nav-link btn-accent">Apply</a>
    </nav>
  </div>
</header>

<style>
  /* --- DESIGN TOKENS (Inspired by The Futur Minimalist Floating Blur) --- */
  .nav-header {
    width: 100%;
    /* Semi-transparent white to let background colors bleed through */
    background-color: rgba(255, 255, 255, 0.8); 
    
    /* The core scroll-blur effect */
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px); 
    
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px; /* Slightly more spacious padding scale */
  }

  /* --- BRANDING (Stark & Heavy) --- */
  .brand-logo {
    font-family: adobe-clean, sans-serif;
    font-size: 22px;
    font-weight: 900; /* Ultra-bold emphasis */
    color: #000000; /* Crisp pure black */
    text-decoration: none;
    letter-spacing: -0.04em;
    text-transform: uppercase; /* Lean into industrial typography */
  }

  .brand-logo span {
    color: var(--spectrum-global-color-accent, #0265dc);
    font-weight: 300;
  }

  /* --- NAV MENU --- */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 40px; 
  }

  .nav-link {
    font-family: adobe-clean, sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: #000000;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: opacity 0.15s ease-in-out;
  }

  .nav-link:hover {
    opacity: 0.6; /* Clean minimalist fade on hover rather than changing colors */
  }

  /* Premium Call-to-action wrapper */
  .btn-accent {
    background-color: #000000;
    color: #ffffff;
    padding: 10px 20px;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.15s ease-in-out, opacity 0.15s ease-in-out;
  }

  .btn-accent:hover {
    background-color: #222222;
    opacity: 1;
  }

  /* --- 📱 RESPONSIVE SINGLE-TREE MEDIA QUERIES --- */
  @media (max-width: 768px) {
    .nav-container {
      padding: 16px; 
    }

    .nav-menu {
      gap: 24px;
    }

    .nav-link:not(.btn-accent) {
      display: none; /* Safely hides secondary links on mobile viewports */
    }
  }
</style>
