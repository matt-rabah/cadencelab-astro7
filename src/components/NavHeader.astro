---
// src/components/NavHeader.astro
import { Image } from 'astro:assets';

// Import your raw assets directly into the component metadata tree
import logoDarkText from '../assets/cadencelab-logo-color-dk.png';
import logoLightText from '../assets/cadencelab-logo-color-lt.png';
---
<header class="gh-header">
  <!-- Desktop Layout -->
  <div class="desktop-nav">
    
    <!-- Left branding zone -->
    <div class="brand-zone">
      <a href="/" class="brand-logo-container" title="Go to Homepage">
        <!-- Astro optimizes the PNG automatically, transforming it into a high-density asset -->
        <Image 
          src={logoDarkText} 
          alt="CadenceLab Logo" 
          height={28} 
          quality="max"
          class="desktop-brand-logo"
        />
      </a>
    </div>

    <!-- Right utility canvas -->
    <div class="utility-canvas">
      
      <!-- Top Tier: Search Core & Global Links -->
      <div class="top-tier">
        <div class="search-wrapper">
          <span class="search-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </span>
          <input 
            id="edit-search" 
            class="search-input" 
            type="text" 
            placeholder="Find solutions (i.e., workflows, automation, data)" 
            name="search" 
          />
        </div>

        <div class="meta-links">
          <a href="/support" class="meta-link">Support</a>
          <span class="meta-divider">|</span>
          <span class="lang-selector">EN</span>
          <button class="login-button">
            Login
            <span class="arrow-icon"></span>
          </button>
        </div>
      </div>

      <!-- Bottom Tier: Navigation Links & Sales CTA -->
      <div class="bottom-tier">
        <nav class="primary-menu" aria-label="Primary navigation">
          <div class="nav-item"><a href="/fit-check" class="menu-link">Fit Check</a></div>

          <!-- Mega Menu 1: Workflows -->
          <div class="nav-item has-mega">
            <button class="menu-trigger-btn">
              Workflows
              <svg class="expand-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="mega-menu-dropdown">
              <div class="mega-menu-inner">
                <div class="mega-column featured">
                  <span class="column-tag">Operational Focus</span>
                  <h3>Workflow Architecture</h3>
                  <p>How we engineer un-compromised human utilization loops around enterprise automated customer service environments.</p>
                  <a href="/workflows" class="column-cta">Explore Framework &rarr;</a>
                </div>
                <div class="mega-column">
                  <h4>Core Workflows</h4>
                  <ul>
                    <li><a href="/workflows/salesforce">Salesforce Data Tracing</a></li>
                    <li><a href="/workflows/cross-functional">Cross-Functional Hand-offs</a></li>
                    <li><a href="/workflows/escalation">SLA Escalation Mapping</a></li>
                    <li><a href="/workflows/agent-routing">AI-to-Human Live Routing</a></li>
                  </ul>
                </div>
                <div class="mega-column">
                  <h4>Integration Ecosystems</h4>
                  <ul>
                    <li><a href="/workflows/legacy">Legacy Core Consolidation</a></li>
                    <li><a href="/workflows/omnichannel">Omnichannel State Syncing</a></li>
                    <li><a href="/workflows/telephony">Contact Center Telecom Pipes</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Mega Menu 2: Solutions -->
          <div class="nav-item has-mega">
            <button class="menu-trigger-btn">
              Solutions
              <svg class="expand-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="mega-menu-dropdown">
              <div class="mega-menu-inner">
                <div class="mega-column featured">
                  <span class="column-tag">Advisory Playbooks</span>
                  <h3>Targeted Engagements</h3>
                  <p>Rigorous multi-stage systems alignment built exclusively to neutralize systemic implementation friction points.</p>
                  <a href="/solutions" class="column-cta">View All Solutions &rarr;</a>
                </div>
                <div class="mega-column">
                  <h4>By Corporate Friction</h4>
                  <ul>
                    <li><a href="/solutions/adoption-fatigue">User Adoption Fatigue</a></li>
                    <li><a href="/solutions/dirty-data">Siloed & Dirty CRM Pipelines</a></li>
                    <li><a href="/solutions/misalignment">Executive Misalignment</a></li>
                  </ul>
                </div>
                <div class="mega-column">
                  <h4>By Scale & Scope</h4>
                  <ul>
                    <li><a href="/solutions/enterprise">Global Enterprise Architecture</a></li>
                    <li><a href="/solutions/mid-market">High-Growth Consolidation</a></li>
                    <li><a href="/solutions/governance">Regulated Market Compliance</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- Mega Menu 3: AI Tooling -->
          <div class="nav-item has-mega">
            <button class="menu-trigger-btn">
              AI Tooling
              <svg class="expand-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="mega-menu-dropdown">
              <div class="mega-menu-inner">
                <div class="mega-column featured">
                  <span class="column-tag">System Safety</span>
                  <h3>Model Orchestration</h3>
                  <p>Overseeing safe real-time execution environments without compromising operational velocity or accuracy matrices.</p>
                  <a href="/ai-tooling" class="column-cta">System Capabilities &rarr;</a>
                </div>
                <div class="mega-column">
                  <h4>Governance Systems</h4>
                  <ul>
                    <li><a href="/ai-tooling/prompt-guard">Automated Prompt Firewalls</a></li>
                    <li><a href="/ai-tooling/hallucination">Hallucination Variance Tracing</a></li>
                    <li><a href="/ai-tooling/compliance">PII Scrubbing Nodes</a></li>
                  </ul>
                </div>
                <div class="mega-column">
                  <h4>Human-in-the-Loop</h4>
                  <ul>
                    <li><a href="/ai-tooling/co-pilot">Agent Co-Pilot Enhancements</a></li>
                    <li><a href="/ai-tooling/feedback">Behavioral Feedback Pipelines</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <div class="nav-item"><a href="/governance" class="menu-link">Governance</a></div>
          <div class="nav-item"><a href="/advisory" class="menu-link">Advisory</a></div>
        </nav>

        <div class="cta-zone">
          <a href="/contact" class="sales-cta" title="Speak to sales">Speak to sales</a>
        </div>
      </div>

    </div>
  </div>

  <!-- Mobile Layout -->
  <div class="mobile-nav">
    <div class="mobile-left">
      <button id="mobile-menu-trigger" class="hamburger-btn" aria-label="Toggle navigation menu">
        <svg class="hamburger-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <a href="/" class="mobile-brand-logo-container">
        <Image src={logoDarkText} alt="CadenceLab Logo" height={22} quality="max" />
      </a>
    </div>

    <div class="mobile-right">
      <a href="/fit-check" class="mobile-fit-btn">Fit Check</a>
    </div>
  </div>

  <!-- Mobile Dropdown Drawer -->
  <div id="mobile-navigation-drawer" class="mobile-drawer hidden">
    <nav class="drawer-menu">
      <a href="/fit-check">Fit Check</a>
      <a href="/workflows">Workflows</a>
      <a href="/solutions">Solutions</a>
      <a href="/ai-tooling">AI Tooling</a>
      <a href="/governance">Governance</a>
      <a href="/advisory">Advisory</a>
      <div class="drawer-footer">
        <a href="/support">Support</a>
        <a href="/login" class="drawer-login">Client Login</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-trigger');
  const drawer = document.getElementById('mobile-navigation-drawer');

  if (menuBtn && drawer) {
    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      drawer.classList.toggle('hidden');
    });

    document.addEventListener('click', () => {
      drawer.classList.add('hidden');
    });
  }
</script>

<style>
  /* --- BASE NAV ARCHITECTURE --- */
  .gh-header {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 999;
    background-color: #ffffff;
    color: #1e242c;
    border-bottom: 1px solid #cbd6e2;
  }

  .desktop-nav {
    display: grid;
    grid-template-columns: 195px 1fr;
    max-width: 100%;
    margin: 0 auto;
    height: 105px;
  }

  .brand-zone {
    display: flex;
    align-items: center;
    padding-left: 32px;
    border-right: 1px solid #f5f8fa;
  }

  .brand-logo-container, .mobile-brand-logo-container {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .desktop-brand-logo {
    width: auto; /* Lets the aspect ratio preserve natively based on height scale */
    object-fit: contain;
  }

  .utility-canvas {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* --- TOP TIER ARCHITECTURE --- */
  .top-tier {
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    border-bottom: 1px solid #f5f8fa;
  }

  .search-wrapper {
    position: relative;
    width: 100%;
    max-width: 412px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    opacity: 0.4;
  }

  .search-input {
    width: 100%;
    height: 36px;
    padding: 0 16px 0 42px;
    background-color: #f5f8fa;
    border: 1px solid transparent;
    border-radius: 2px;
    font-size: 13px;
    outline: none;
    transition: all 0.15s ease;
  }

  .search-input:focus {
    background-color: #ffffff;
    border-color: #1a73e2;
  }

  .meta-links {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13.5px;
    color: #576579;
  }

  .meta-link {
    color: inherit;
    text-decoration: none;
  }

  .meta-link:hover, .lang-selector:hover {
    color: #1a73e2;
  }

  .meta-divider {
    color: #cbd6e2;
    user-select: none;
  }

  .lang-selector {
    font-weight: 700;
    cursor: pointer;
  }

  .login-button {
    background: none;
    border: none;
    color: inherit;
    font-size: inherit;
    cursor: pointer;
  }

  /* --- BOTTOM TIER LINKS MAP --- */
  .bottom-tier {
    height: 49px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .primary-menu {
    display: flex;
    padding-left: 16px;
    height: 100%;
  }

  .nav-item {
    display: flex;
    align-items: center;
    height: 100%;
  }

  .menu-link, .menu-trigger-btn {
    padding: 0 20px;
    font-size: 13px;
    font-weight: 600;
    color: #1e242c;
    text-decoration: none;
    letter-spacing: 0.02em;
    background: none;
    border: none;
    cursor: pointer;
    height: 100%;
    display: inline-flex;
    align-items: center;
    gap: 6px; 
    font-family: inherit;
    transition: color 0.15s ease;
  }

  .menu-link:hover, .menu-trigger-btn:hover {
    color: #1a73e2;
  }

  .sales-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 49px;
    padding: 0 48px;
    background-color: #1a73e2;
    color: #ffffff;
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .sales-cta:hover {
    background-color: #155ec2;
  }

  .expand-icon {
    width: 10px;
    height: 10px;
    color: #576579; 
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), color 0.15s ease;
  }

  /* --- MEGA DROPDOWN STYLING --- */
  .has-mega {
    position: static; 
  }

  .mega-menu-dropdown {
    position: absolute;
    top: 105px; 
    left: 0;
    width: 100%;
    background-color: #ffffff;
    border-bottom: 1px solid #cbd6e2;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.06);
    display: none; 
    z-index: 1000;
    border-top: 1px solid #f5f8fa;
  }

  .has-mega:hover .mega-menu-dropdown {
    display: block;
  }

  .has-mega:hover .menu-trigger-btn {
    color: #1a73e2;
  }

  .has-mega:hover .expand-icon {
    color: #1a73e2; 
    transform: rotate(180deg); 
  }

  .mega-menu-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: 1.2fr repeat(2, 1fr);
    gap: 48px;
  }

  .mega-column h4 {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: #576579;
    letter-spacing: 0.08em;
    margin-bottom: 16px;
  }

  .mega-column ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .mega-column ul a {
    font-size: 14px;
    font-weight: 500;
    color: #1e242c;
    transition: color 0.15s ease;
  }

  .mega-column ul a:hover {
    color: #1a73e2;
  }

  .mega-column.featured {
    background-color: #f5f8fa;
    padding: 24px;
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .column-tag {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    background-color: #cbd6e2;
    color: #1e242c;
    padding: 2px 6px;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }

  .featured h3 {
    font-size: 18px;
    font-weight: 800;
    color: #000000;
    letter-spacing: -0.02em;
  }

  .featured p {
    font-size: 13px;
    line-height: 1.5;
    color: #576579;
  }

  .column-cta {
    font-size: 13px;
    font-weight: 600;
    color: #1a73e2;
    margin-top: 4px;
  }

  .column-cta:hover {
    text-decoration: underline;
  }

  /* --- RESPONSIVE MOBILE HANDLES --- */
  .mobile-nav, .mobile-drawer {
    display: none;
  }

  @media (max-width: 950px) {
    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 56px;
      padding: 0 24px;
    }

    .mobile-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .hamburger-btn {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
    }

    .hamburger-svg {
      width: 24px;
      height: 24px;
      color: #1e242c;
    }

    .mobile-fit-btn {
      background-color: #1a73e2;
      color: #ffffff;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 2px;
    }

    .mobile-drawer {
      position: absolute;
      top: 56px;
      left: 0;
      width: 100%;
      background-color: #ffffff;
      border-bottom: 1px solid #cbd6e2;
      box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    }

    .mobile-drawer.hidden {
      display: none;
    }

    .drawer-menu {
      display: flex;
      flex-direction: column;
    }

    .drawer-menu a {
      padding: 14px 32px;
      font-size: 14px;
      font-weight: 600;
      color: #1e242c;
      text-decoration: none;
      border-bottom: 1px solid #f5f8fa;
    }

    .drawer-footer {
      background-color: #f5f8fa;
      display: flex;
      justify-content: space-around;
      padding: 16px;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .drawer-login {
      color: #1a73e2 !important;
      padding: 0 !important;
      border: none !important;
    }
  }
</style>
