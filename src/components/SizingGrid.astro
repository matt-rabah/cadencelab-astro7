---
// src/components/SizingGrid.astro
---
<div data-outer-container class="outer-container">
  <span class="chromatic-ignore label-main">Sizing</span>

  <div data-inner-container class="inner-container-main">
    <!-- Extra-extra-small -->
    <div data-outer-container class="outer-container outer-container--nested">
      <span class="chromatic-ignore label-sub">Extra-extra-small</span>
      <div data-inner-container class="inner-container-row">
        <h2 class="spectrum-Heading spectrum-Heading--sizeXXS">Aliquet mauris eu</h2>
      </div>
    </div>

    <!-- Extra-small -->
    <div data-outer-container class="outer-container outer-container--nested">
      <span class="chromatic-ignore label-sub">Extra-small</span>
      <div data-inner-container class="inner-container-row">
        <h2 class="spectrum-Heading spectrum-Heading--sizeXS">Aliquet mauris eu</h2>
      </div>
    </div>

    <!-- Small -->
    <div data-outer-container class="outer-container outer-container--nested">
      <span class="chromatic-ignore label-sub">Small</span>
      <div data-inner-container class="inner-container-row">
        <h2 class="spectrum-Heading spectrum-Heading--sizeS">Aliquet mauris eu</h2>
      </div>
    </div>

    <!-- Medium -->
    <div data-outer-container class="outer-container outer-container--nested">
      <span class="chromatic-ignore label-sub">Medium</span>
      <div data-inner-container class="inner-container-row">
        <h2 class="spectrum-Heading spectrum-Heading--sizeM">Aliquet mauris eu</h2>
      </div>
    </div>
  </div>
</div>

<style>
  .chromatic-ignore {
    display: block;
    color: CanvasText;
    font-family: adobe-clean, sans-serif;
    line-height: 1.3;
    letter-spacing: .06em;
    text-transform: uppercase;
  }
  .label-main { font-size: 14px; font-weight: 700; }
  .label-sub { font-size: 11px; font-weight: 400; }

  .outer-container {
    z-index: 1;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .outer-container--nested { gap: 12px; }

  .inner-container-main {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 24px;
    border: 1px solid rgba(var(--spectrum-gray-600-rgb, 108, 108, 108), 20%);
    border-radius: 4px;
  }
  .inner-container-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
  }
</style>
