---

<section
  class="relative overflow-hidden bg-gradient-to-br from-indigo-50 via-violet-50/40 to-amber-50/30 py-16 sm:py-24 border-b border-slate-100"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <nav
      class="flex items-center gap-2 text-xs font-medium text-slate-500 mb-6"
      aria-label="Breadcrumb"
    >
      <a href="#" class="hover:text-violet-600 transition-colors">Platform</a>
      <svg
        class="w-3 h-3 text-slate-400"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
      <a href="#" class="hover:text-violet-600 transition-colors"
        >Developer Core</a
      >
      <svg
        class="w-3 h-3 text-slate-400"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 5l7 7-7 7"
        />
      </svg>
      <span class="text-slate-800" aria-current="page">Build Interface</span>
    </nav>

    <div class="max-w-3xl">
      <h1
        class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl"
      >
        Next-generation architecture: Your agile workflow hub
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed">
        Engineered to streamline complex development operations, our environment
        runs natively alongside your local stack from initial concepts to
        deployment.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#"
          class="inline-flex items-center justify-center rounded-md bg-violet-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-violet-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-600 transition-all"
        >
          Get started for free
        </a>
      </div>
    </div>
  </div>
</section>
