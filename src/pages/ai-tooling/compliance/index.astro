      {
        label: "Verification",
        question: "How will the organization know the node worked?",
        title: "Verification",
        description:
          "Test representative and adversarial samples, false negatives, false positives, transformed utility, downstream behavior, access, and residual re-identification risk.",
      },
      {
        label: "Governance",
        question: "Who owns exceptions, change, and response?",
        title: "Governance",
