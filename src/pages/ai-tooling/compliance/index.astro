      {
        label: "Purpose",
        question: "What decision requires this data?",
        title: "Purpose",
        description:
          "Define the use case, affected people, expected outcome, permitted processing, and the specific information necessary to perform the task.",
      },
      {
        label: "Classification",
        question: "Which sensitive information can appear here?",
        title: "Classification",
        description:
          "Identify direct identifiers, linked attributes, free-text disclosures, credentials, financial or health information, confidential business data, and contextual sensitivity.",
