      {
        title: "One masking rule is applied to every use case",
        description:
          "A global pattern removes information some tasks require, misses contextual identifiers, and produces false confidence about what remains exposed.",
      },
      {
        title: "Teams cannot explain where original values persist",
        description:
          "The organization knows a transformed value reached the model but cannot identify which services, logs, stores, vendors, or reviewers retained the source.",
      },
      {
        title: "Compliance language substitutes for operating evidence",
        description:
          "A workflow is called compliant because a detection tool is enabled, without showing purpose, necessity, accuracy, access, retention, review, or individual impact.",
      },
    ],
  },
  framework: {
    eyebrow: "Control design",
    title: "Place each node around a defined processing purpose.",
    introduction:
      "A scrubbing node is useful only when the organization understands the data, the task, the privacy risk, the transformation, and the systems on both sides of the boundary.",
