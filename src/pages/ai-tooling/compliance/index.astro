        phase: "Return",
        question: "Could the output expose or infer sensitive information?",
        evidence:
          "Response, structured output, downstream action, re-identification, display, export, sharing, and human review.",
      },
      {
        phase: "Retain",
        question: "What persists, for how long, and for what purpose?",
