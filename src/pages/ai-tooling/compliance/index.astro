      label: "Review AI Service Readiness",
      href: "/services/ai-service-readiness-review/",
    },
    secondaryCta: {
      label: "Start a fit check",
      href: "/fit-check/",
    },
    trigger: {
      introduction:
        "An AI workflow receives customer, employee, patient, financial, account, or operational data that contains more identifying information than the task requires.",
