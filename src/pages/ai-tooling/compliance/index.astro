      {
        title: "Free text bypasses structured controls",
        description:
          "Agents, customers, employees, and integrated systems place sensitive details in notes, messages, documents, and prompts that field-level rules do not inspect.",
      },
      {
        title: "Redaction occurs only at the final output",
        description:
          "The visible response is cleaned while sensitive data remains in the prompt, retrieved context, logs, traces, tool arguments, caches, or downstream services.",
