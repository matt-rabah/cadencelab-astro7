---
import Footer from "../../../components/Footer.astro";
import NavHeader from "../../../components/NavHeader.astro";
import SectionNav from "../../../components/SectionNav.astro";
import Layout from "../../../layouts/Layout.astro";

const diagnosticQuestions = [
  {
    number: "01",
    question: "Is the proposed use case appropriate and consequential?",
    explanation:
      "Clarify the customer or operating decision AI is expected to support, the people affected, the value of improving it, and whether automation is the right intervention.",
  },
  {
    number: "02",
    question: "Is the underlying workflow ready?",
    explanation:
      "Trace the current work, ownership, exceptions, data, and decision rules to determine whether the process is stable enough to support responsible AI assistance.",
  },
  {
    number: "03",
    question: "What human oversight and guardrails are required?",
    explanation:
      "Define where people must review, approve, correct, override, or escalate AI-supported work and who remains accountable for customer and operating outcomes.",
  },
  {
    number: "04",
    question: "How will readiness and success be judged?",
    explanation:
      "Establish the evidence, adoption conditions, operating measures, risk signals, and review points needed before implementation expands.",
  },
];

const evidenceAreas = [
  {
    title: "Use-case and decision fit",
    description:
      "The customer problem, operating decision, intended users, expected benefit, known alternatives, and whether AI support is proportionate to the consequence.",
  },
  {
    title: "Workflow and process readiness",
    description:
      "Current steps, handoffs, decision rights, exceptions, service rules, failure recovery, and places where the work remains undefined or inconsistent.",
  },
  {
    title: "Data and knowledge dependencies",
    description:
      "Required records, knowledge sources, data quality, access, freshness, provenance, privacy constraints, and the context people use to judge an appropriate response.",
  },
  {
    title: "Human oversight and exceptions",
    description:
      "Review points, approval thresholds, escalation paths, override authority, quality checks, and the responsibilities people retain when AI supports the work.",
  },
  {
    title: "Governance, risk, and trust",
    description:
      "Acceptable-use boundaries, security and privacy needs, customer disclosure, auditability, accountability, failure consequences, and stakeholder concerns.",
  },
  {
    title: "Adoption and measurement",
    description:
      "User readiness, training needs, workflow integration, success measures, risk indicators, feedback paths, and the evidence required to continue, change, or stop.",
  },
];

const deliverables = [
  {
    number: "01",
    title: "Readiness decision",
    description:
      "An evidence-based assessment of whether the proposed use case is ready to proceed, needs operating changes first, should be narrowed, or should not move forward.",
    decision:
      "Whether to proceed now, pause for prerequisites, reshape the use case, or choose a different intervention.",
  },
  {
    number: "02",
    title: "Human-in-the-loop map",
    description:
      "A clear view of where AI can assist, where human judgment remains essential, how exceptions move, and who holds authority and accountability.",
    decision:
      "Which decisions can be supported, which require approval, and how people recover when the system is uncertain or wrong.",
  },
  {
    number: "03",
    title: "Operating constraints and guardrails",
    description:
      "Documented workflow, data, knowledge, governance, privacy, quality, and trust conditions that must shape any implementation.",
    decision:
      "What boundaries and controls must exist before the use case can operate responsibly.",
  },
  {
    number: "04",
    title: "Sequenced implementation priorities",
    description:
      "A practical order for prerequisite operating changes, a bounded pilot, adoption support, measurement, review, and any justified expansion.",
    decision:
      "What to change first, what a responsible initial release should include, and what evidence should govern the next investment.",
  },
];

const strongFit = [
  "An AI proposal has executive support, but workflow, governance, adoption conditions, or success measures remain unclear.",
  "The proposed use case affects customer service, success, or operations across teams, systems, or decision boundaries.",
  "A sponsor can involve process owners, frontline users, data and knowledge owners, risk partners, and technical teams.",
  "The organization is willing to postpone, narrow, or reshape the use case when the evidence shows that prerequisites are missing.",
];

const limitedFit = [
  "The request is limited to vendor selection or implementation of a predetermined solution with no readiness decision.",
  "AI is expected to compensate for an undefined or broken workflow without changing ownership, process, or decision rules.",
  "Process owners, frontline users, data or knowledge owners, governance partners, or accountable leaders cannot participate.",
  "Success measures stop at launch, usage, or automation volume and leave out useful work, responsible adoption, and customer outcomes.",
];
---

<Layout
  title="AI Service Readiness Review | Cadence Lab"
  description="Determine whether a service, success, or operations AI use case has the workflow, data, oversight, governance, adoption, and measurement conditions required to proceed responsibly."
  canonicalURL="/services/ai-service-readiness-review/"
  pageType="website"
>
  <NavHeader />

  <main id="main-content" class="diagnostic-page" tabindex="-1">
    <section class="diagnostic-hero" aria-labelledby="diagnostic-title">
      <div class="page-container hero-layout">
        <div class="hero-copy">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <ol>
              <li><a href="/services/">Services</a></li>
              <li aria-current="page">AI Service Readiness Review</li>
            </ol>
          </nav>

          <p class="eyebrow">Diagnostic 04</p>
          <h1 id="diagnostic-title">
            Decide whether the service AI use case is ready before
            implementation.
          </h1>
          <p class="hero-lead">
            The AI Service Readiness Review examines use-case fit, workflow
            stability, data and knowledge dependencies, human oversight,
            governance, adoption conditions, and measurement so the organization
            can make a responsible implementation decision.
          </p>

          <div
            class="hero-actions"
            aria-label="AI Service Readiness Review actions"
          >
            <a class="button button-primary" href="/fit-check/">
              Start a fit check
            </a>
            <a class="button button-text" href="#questions">
              Review the diagnostic
            </a>
          </div>
        </div>

        <aside class="trigger" aria-labelledby="trigger-title">
          <p id="trigger-title" class="trigger-label">Recognizable trigger</p>
          <p>
            An AI initiative has momentum, but the supporting workflow, data,
            human oversight, governance, adoption conditions, or success
            measures remain unclear.
          </p>
          <p>
            Leaders need to know whether the use case is ready, which
            constraints must shape it, and what must change before
            implementation expands.
          </p>
        </aside>
      </div>
    </section>

    <SectionNav
      items={[
        { label: "Questions", href: "#questions" },
        { label: "Scope", href: "#scope" },
        { label: "Outputs", href: "#outputs" },
        { label: "Fit", href: "#fit" },
        { label: "Next step", href: "#next-step" },
      ]}
    />

    <section
      id="questions"
      class="questions section-block"
      aria-labelledby="questions-title"
    >
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Questions answered</p>
            <h2 id="questions-title">
              Turn AI interest into a bounded operating decision.
            </h2>
          </div>
          <p>
            The review starts with the customer and operating problem. From
            there, it checks whether the conditions for responsible AI support
            exist before comparing platforms or planning automation.
          </p>
        </div>

        <ol class="question-list" role="list">
          {
            diagnosticQuestions.map((item) => (
              <li>
                <article class="question">
                  <p class="item-number" aria-hidden="true">
                    {item.number}
                  </p>
                  <div>
                    <h3>{item.question}</h3>
                    <p>{item.explanation}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section
      id="scope"
      class="scope section-block"
      aria-labelledby="scope-title"
    >
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Scope and evidence</p>
            <h2 id="scope-title">
              Examine the operating conditions around the proposed use case.
            </h2>
          </div>
          <p>
            The exact evidence depends on the decision and what the organization
            can responsibly provide. Cadence Lab compares the proposed AI
            behavior with the real workflow, available context, human judgment,
            risk constraints, and measures required to operate it well.
          </p>
        </div>

        <ul class="evidence-grid" role="list">
          {
            evidenceAreas.map((area, index) => (
              <li>
                <article>
                  <p class="item-number" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </p>
                  <h3>{area.title}</h3>
                  <p>{area.description}</p>
                </article>
              </li>
            ))
          }
        </ul>

        <aside class="scope-note" aria-labelledby="scope-note-title">
          <h3 id="scope-note-title">Readiness before automation</h3>
          <p>
            AI should not automate ambiguity. The review identifies where
            workflow, knowledge, decision rights, or accountability must become
            clearer before a system can support the work responsibly.
          </p>
        </aside>
      </div>
    </section>

    <section id="outputs" class="outputs" aria-labelledby="outputs-title">
      <div class="page-container section-stack">
        <div class="outputs-intro">
          <p class="eyebrow eyebrow-inverse">Deliverables and decisions</p>
          <h2 id="outputs-title">
            Leave with a readiness decision and responsible path forward.
          </h2>
          <p>
            The deliverables connect operating evidence to an implementation
            decision. Each output clarifies whether the use case should proceed,
            what constraints must shape it, and which evidence should govern any
            expansion.
          </p>
        </div>

        <ol class="output-list" role="list">
          {
            deliverables.map((deliverable) => (
              <li>
                <article class="output">
                  <div class="output-heading">
                    <p class="output-number" aria-hidden="true">
                      {deliverable.number}
                    </p>
                    <h3>{deliverable.title}</h3>
                  </div>
                  <p class="output-description">{deliverable.description}</p>
                  <p class="output-decision">
                    <span>Supports the decision</span>
                    {deliverable.decision}
                  </p>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section id="fit" class="fit section-block" aria-labelledby="fit-title">
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Engagement fit</p>
            <h2 id="fit-title">
              Use this review before a service AI initiative becomes an
              implementation commitment.
            </h2>
          </div>
          <p>
            A useful review needs access to the people, workflow, data,
            knowledge, and constraints surrounding the proposed use case. It
            also needs permission to challenge whether AI is appropriate and
            whether the organization is ready to proceed.
          </p>
        </div>

        <div class="fit-grid">
          <article class="fit-panel fit-panel-strong">
            <p class="fit-label">Strong fit</p>
            <h3>Conditions that support a useful readiness decision</h3>
            <ul role="list">
              {strongFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>

          <article class="fit-panel">
            <p class="fit-label fit-label-muted">Limited fit</p>
            <h3>Conditions that point to another path</h3>
            <ul role="list">
              {limitedFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section
      id="next-step"
      class="next-step section-block"
      aria-labelledby="next-step-title"
    >
      <div class="page-container next-step-layout">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 id="next-step-title">Define the proposed use case.</h2>
        </div>

        <div class="next-step-copy">
          <p>
            Share the customer or operating problem, affected workflow and
            users, available data and knowledge, known constraints, accountable
            sponsor, and decision leadership needs to make. Cadence Lab will
            assess whether this review is the right entry point and say directly
            when another path makes more sense.
          </p>

          <dl class="next-step-details">
            <div>
              <dt>Useful context</dt>
              <dd>
                Proposed use case, affected workflow, known constraints, and
                accountable sponsor
              </dd>
            </div>
            <div>
              <dt>Expected outcome</dt>
              <dd>
                A direct recommendation about readiness and the appropriate next
                step
              </dd>
            </div>
          </dl>

          <div class="next-step-actions">
            <a class="button button-accent" href="/fit-check/">
              Start a fit check
            </a>
            <a class="services-link" href="/services/">
              Compare all diagnostics
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .diagnostic-page {
    display: flex;
    width: 100%;
    flex-direction: column;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .page-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .section-block {
    padding-block: var(--section-space);
    border-top: var(--border-width) solid var(--color-border);
  }

  .section-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(2.75rem, 6vw, 5rem);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--color-blue);
  }

  .eyebrow-inverse {
    color: var(--color-green);
  }

  h1,
  h2,
  h3,
  p,
  dl,
  dd {
    margin-block: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-feature-settings: var(--fea-graphik);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  h1 {
    max-width: 17ch;
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
  }

  h2 {
    max-width: 19ch;
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
  }

  h3 {
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
  }

  .diagnostic-hero {
    padding-block: clamp(3rem, 8vw, 6.5rem) clamp(4.5rem, 10vw, 8rem);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.65fr);
    gap: clamp(3rem, 10vw, 8rem);
    align-items: end;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .breadcrumb {
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.6rem;
    margin: 0;
    padding: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-small);
    list-style: none;
  }

  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .breadcrumb li + li::before {
    color: var(--color-border-strong);
    content: "/" / "";
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.2em;
  }

  .breadcrumb a:hover {
    color: var(--color-blue);
    text-decoration-color: currentColor;
  }

  .hero-lead {
    max-width: var(--measure-ui);
    margin-top: 1.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    margin-top: 2rem;
  }

  .trigger {
    padding: clamp(1.5rem, 3vw, 2rem);
    border-top: 0.25rem solid var(--color-blue);
    background: var(--color-surface-subtle);
  }

  .trigger-label {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .trigger > p:not(.trigger-label) {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .trigger > p:nth-child(2) {
    margin-top: 1rem;
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-medium);
    line-height: var(--lh-ui);
  }

  .trigger > p + p {
    margin-top: 1rem;
  }

  .questions,
  .fit {
    background: var(--color-surface-subtle);
  }

  .questions {
    scroll-margin-top: var(--header-offset);
  }

  .section-intro-split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(18rem, 0.75fr);
    gap: clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .section-intro-split > p,
  .next-step-copy > p {
    max-width: var(--measure-ui);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .question-list,
  .evidence-grid,
  .output-list,
  .fit-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .question-list {
    border-top: var(--border-width) solid var(--color-border-strong);
  }

  .question-list > li {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .question {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }

  .item-number,
  .output-number {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    font-feature-settings: var(--fea-tabular);
  }

  .question h3 {
    max-width: 31ch;
  }

  .question div > p {
    max-width: var(--measure-ui);
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: var(--border-width) solid var(--color-border-strong);
    border-left: var(--border-width) solid var(--color-border-strong);
  }

  .evidence-grid > li {
    min-width: 0;
    border-right: var(--border-width) solid var(--color-border-strong);
    border-bottom: var(--border-width) solid var(--color-border-strong);
  }

  .evidence-grid article {
    height: 100%;
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .evidence-grid h3 {
    margin-top: 0.75rem;
  }

  .evidence-grid article > p:last-child {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .scope-note {
    display: grid;
    grid-template-columns: minmax(12rem, 0.45fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-left: 0.25rem solid var(--color-blue);
    background: var(--color-surface-subtle);
  }

  .scope-note p {
    max-width: var(--measure-ui);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .outputs {
    padding-block: var(--section-space);
    background: var(--color-ink);
    color: var(--color-text-inverse);
  }

  .outputs-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.75fr);
    gap: 1rem clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .outputs-intro .eyebrow {
    grid-column: 1 / -1;
  }

  .outputs h2,
  .outputs h3 {
    color: var(--color-text-inverse);
  }

  .outputs-intro > p:last-child {
    max-width: var(--measure-ui);
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .output-list {
    border-top: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output-list > li {
    border-bottom: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output {
    display: grid;
    grid-template-columns: minmax(12rem, 0.65fr) minmax(0, 0.9fr) minmax(
        0,
        1fr
      );
    gap: clamp(1.5rem, 5vw, 4rem);
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
    align-items: start;
  }

  .output-number {
    color: var(--color-green);
  }

  .output-heading h3 {
    margin-top: 0.75rem;
  }

  .output-description,
  .output-decision {
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .output-decision {
    padding-left: clamp(1rem, 3vw, 2rem);
    border-left: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output-decision span {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-green);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .fit-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .fit-panel {
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    border: var(--border-width) solid var(--color-border-strong);
    border-top: 0.25rem solid var(--color-ink);
    border-radius: var(--radius-md);
    background: var(--color-surface-pure);
  }

  .fit-panel-strong {
    border-top-color: var(--color-blue);
  }

  .fit-label {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .fit-label-muted {
    color: var(--color-text-muted);
  }

  .fit-panel h3 {
    max-width: 27ch;
    margin-top: 0.75rem;
  }

  .fit-panel ul {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .fit-panel li {
    position: relative;
