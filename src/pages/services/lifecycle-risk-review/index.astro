---
import Footer from "../../../components/Footer.astro";
import NavHeader from "../../../components/NavHeader.astro";
import Layout from "../../../layouts/Layout.astro";

const diagnosticQuestions = [
  {
    number: "01",
    question: "Where does lifecycle risk first become visible?",
    explanation:
      "Identify the earliest useful signals across onboarding, adoption, service activity, account behavior, and customer feedback, including the signs that appear before a renewal is in danger.",
  },
  {
    number: "02",
    question: "Which signals should trigger action?",
    explanation:
      "Distinguish meaningful changes in customer conditions from routine variation, incomplete data, and measures that describe activity without revealing risk.",
  },
  {
    number: "03",
    question: "Who should respond, and when?",
    explanation:
      "Clarify ownership, intervention rules, escalation paths, and the context each team needs to act before the useful response window closes.",
  },
  {
    number: "04",
    question: "How should the organization judge improvement?",
    explanation:
      "Connect earlier action to customer, adoption, workflow, and business indicators so the organization can review whether the intervention is useful.",
  },
];

const evidenceAreas = [
  {
    title: "Lifecycle stages and expectations",
    description:
      "How the organization defines onboarding, adoption, value realization, renewal readiness, and other meaningful transitions in the customer relationship.",
  },
  {
    title: "Customer and account signals",
    description:
      "Product or service use, engagement changes, support patterns, feedback, stakeholder movement, commercial context, and other available indicators of changing conditions.",
  },
  {
    title: "Handoffs and intervention paths",
    description:
      "How customer context moves across sales, onboarding, success, service, operations, and leadership when a signal requires coordinated action.",
  },
  {
    title: "Health measures and data quality",
    description:
      "The inputs, assumptions, missing data, weighting, freshness, and practical use of current scores, dashboards, alerts, and account-review materials.",
  },
  {
    title: "Ownership and escalation rules",
    description:
      "Who monitors conditions, interprets ambiguity, initiates outreach, resolves blockers, and makes decisions when customer risk crosses team boundaries.",
  },
  {
    title: "Outcomes and review cadence",
    description:
      "How the organization evaluates interventions, learns from preventable loss, and updates signals or operating rules as customer behavior changes.",
  },
];

const deliverables = [
  {
    number: "01",
    title: "Lifecycle risk model",
    description:
      "A shared definition of meaningful lifecycle stages, risk conditions, and the transitions where earlier action can still change the outcome.",
    decision:
      "Where the organization should monitor risk and which lifecycle boundaries require clearer operating attention.",
  },
  {
    number: "02",
    title: "Signal inventory and assessment",
    description:
      "A review of available indicators, their evidence strength, known gaps, freshness, ownership, and usefulness for a specific decision.",
    decision:
      "Which signals can guide action now, which need improvement, and which should not be treated as reliable evidence.",
  },
  {
    number: "03",
    title: "Intervention and ownership map",
    description:
      "A practical view of triggers, responsible roles, escalation paths, required context, and the response expected when risk conditions appear.",
    decision:
      "Who acts, when they act, what information they need, and where cross-functional support is required.",
  },
  {
    number: "04",
    title: "Prioritized improvement plan",
    description:
      "A sequenced set of changes to lifecycle definitions, data, workflows, reviews, and measurement based on consequence and dependency.",
    decision:
      "What to improve first and what conditions should exist before introducing more automation or predictive complexity.",
  },
];

const strongFit = [
  "Onboarding drift, weak adoption, quiet accounts, or renewal risk becomes visible later than the organization can respond effectively.",
  "Customer context and risk signals are fragmented across teams, systems, or account-review practices.",
  "A sponsor can align customer-facing, operational, data, and commercial owners around shared intervention decisions.",
  "The organization is willing to change lifecycle definitions, workflows, and ownership.",
];

const limitedFit = [
  "The only goal is to purchase a predictive tool without changing how teams interpret and act on customer risk.",
  "The immediate need is a recovery plan for one known account.",
  "Relevant customer, account, workflow, or outcome evidence is unavailable and cannot be responsibly examined.",
  "No accountable owner can change intervention rules, escalation paths, or cross-functional customer work.",
];
---

<Layout
  title="Lifecycle Risk Review | Cadence Lab"
  description="Identify lifecycle risk earlier, clarify which customer signals should trigger action, and define who responds before the useful intervention window closes."
  canonicalURL="/services/lifecycle-risk-review/"
  pageType="website"
>
  <NavHeader />

  <main id="main-content" class="diagnostic-page" tabindex="-1">
    <section class="diagnostic-hero" aria-labelledby="diagnostic-title">
      <div class="page-container hero-layout">
        <div class="hero-copy">
          <nav class="breadcrumb" aria-label="Breadcrumb">
            <ol>
              <li><a href="/services/">Services</a></li>
              <li aria-current="page">Lifecycle Risk Review</li>
            </ol>
          </nav>

          <p class="eyebrow">Diagnostic 02</p>
          <h1 id="diagnostic-title">
            See lifecycle risk while there is still time to act.
          </h1>
          <p class="hero-lead">
            The Lifecycle Risk Review examines customer stages, changing account
            conditions, health signals, intervention rules, and ownership so
            teams can respond before preventable risk becomes a late-stage
            surprise.
          </p>

          <div class="hero-actions" aria-label="Lifecycle Risk Review actions">
            <a class="button button-primary" href="/fit-check/">
              Start a fit check
            </a>
            <a class="button button-text" href="#questions">
              Review the diagnostic
            </a>
          </div>
        </div>

        <aside class="trigger" aria-labelledby="trigger-title">
          <p id="trigger-title" class="trigger-label">Recognizable trigger</p>
          <p>
            Onboarding drifts, adoption weakens, important stakeholders
            disengage, or accounts become quiet without creating a clear
            operating response.
          </p>
          <p>
            Risk becomes undeniable only after the useful intervention window
            has narrowed, because signals, ownership, and customer context
            remain fragmented across teams and systems.
          </p>
        </aside>
      </div>
    </section>

    <section
      id="questions"
      class="questions section-block"
      aria-labelledby="questions-title"
    >
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Questions answered</p>
            <h2 id="questions-title">
              Turn late-stage surprises into earlier operating decisions.
            </h2>
          </div>
          <p>
            The review starts with the decisions teams need to make. Available
            signals and workflows are tested against the need for timely,
            accountable action.
          </p>
        </div>

        <ol class="question-list" role="list">
          {
            diagnosticQuestions.map((item) => (
              <li>
                <article class="question">
                  <p class="item-number" aria-hidden="true">
                    {item.number}
                  </p>
                  <div>
                    <h3>{item.question}</h3>
                    <p>{item.explanation}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="scope section-block" aria-labelledby="scope-title">
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Scope and evidence</p>
            <h2 id="scope-title">
              Examine the conditions that reveal and shape lifecycle risk.
            </h2>
          </div>
          <p>
            The exact evidence depends on the customer model and what the
            organization can responsibly provide. Cadence Lab compares intended
            lifecycle practices with actual signals, decisions, and intervention
            behavior.
          </p>
        </div>

        <ul class="evidence-grid" role="list">
          {
            evidenceAreas.map((area, index) => (
              <li>
                <article>
                  <p class="item-number" aria-hidden="true">
                    {String(index + 1).padStart(2, "0")}
                  </p>
                  <h3>{area.title}</h3>
                  <p>{area.description}</p>
                </article>
              </li>
            ))
          }
        </ul>

        <aside class="scope-note" aria-labelledby="scope-note-title">
          <h3 id="scope-note-title">Signals before scores</h3>
          <p>
            A score is useful only when its inputs are understood and its result
            changes a responsible decision. The review separates observable
            conditions from assumptions and states where incomplete data limits
            confidence.
          </p>
        </aside>
      </div>
    </section>

    <section class="outputs" aria-labelledby="outputs-title">
      <div class="page-container section-stack">
        <div class="outputs-intro">
          <p class="eyebrow eyebrow-inverse">Deliverables and decisions</p>
          <h2 id="outputs-title">
            Leave with earlier signals and clearer intervention rules.
          </h2>
          <p>
            The deliverables connect lifecycle evidence to action. Each output
            clarifies which conditions matter, how confidently they can be
            interpreted, who responds, and what the organization should improve
            next.
          </p>
        </div>

        <ol class="output-list" role="list">
          {
            deliverables.map((deliverable) => (
              <li>
                <article class="output">
                  <div class="output-heading">
                    <p class="output-number" aria-hidden="true">
                      {deliverable.number}
                    </p>
                    <h3>{deliverable.title}</h3>
                  </div>
                  <p class="output-description">{deliverable.description}</p>
                  <p class="output-decision">
                    <span>Supports the decision</span>
                    {deliverable.decision}
                  </p>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="fit section-block" aria-labelledby="fit-title">
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Engagement fit</p>
            <h2 id="fit-title">
              Use this review when customer risk appears after the best response
              window.
            </h2>
          </div>
          <p>
            A useful review needs access to the teams, customer context,
            lifecycle data, and decisions surrounding intervention. It also
            needs permission to change how risk is defined, owned, and reviewed.
          </p>
        </div>

        <div class="fit-grid">
          <article class="fit-panel fit-panel-strong">
            <p class="fit-label">Strong fit</p>
            <h3>Conditions that support a useful diagnosis</h3>
            <ul role="list">
              {strongFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>

          <article class="fit-panel">
            <p class="fit-label fit-label-muted">Limited fit</p>
            <h3>Conditions that point to another path</h3>
            <ul role="list">
              {limitedFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="next-step section-block" aria-labelledby="next-step-title">
      <div class="page-container next-step-layout">
        <div>
          <p class="eyebrow">Next step</p>
          <h2 id="next-step-title">
            Show where lifecycle risk appears too late.
          </h2>
        </div>

        <div class="next-step-copy">
          <p>
            Share where risk appears too late, which lifecycle stages are
            affected, the teams and systems involved, and the signals already
            available. Cadence Lab will assess whether this review is the right
            entry point and say directly when another path makes more sense.
          </p>

          <dl class="next-step-details">
            <div>
              <dt>Useful context</dt>
              <dd>
                Lifecycle concern, available signals, affected teams, and
                accountable sponsor
              </dd>
            </div>
            <div>
              <dt>Expected outcome</dt>
              <dd>
                A direct recommendation about fit and the appropriate next step
              </dd>
            </div>
          </dl>

          <div class="next-step-actions">
            <a class="button button-accent" href="/fit-check/">
              Start a fit check
            </a>
            <a class="services-link" href="/services/">
              Compare all diagnostics
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .diagnostic-page {
    display: flex;
    width: 100%;
    flex-direction: column;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .page-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .section-block {
    padding-block: var(--section-space);
    border-top: var(--border-width) solid var(--color-border);
  }

  .section-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(2.75rem, 6vw, 5rem);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--color-blue);
  }

  .eyebrow-inverse {
    color: var(--color-green);
  }

  h1,
  h2,
  h3,
  p,
  dl,
  dd {
    margin-block: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-feature-settings: var(--fea-graphik);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  h1 {
    max-width: 17ch;
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
  }

  h2 {
    max-width: 19ch;
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
  }

  h3 {
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
  }

  .diagnostic-hero {
    padding-block: clamp(3rem, 8vw, 6.5rem) clamp(4.5rem, 10vw, 8rem);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.65fr);
    gap: clamp(3rem, 10vw, 8rem);
    align-items: end;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .breadcrumb {
    margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
  }

  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.6rem;
    margin: 0;
    padding: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    line-height: var(--lh-small);
    list-style: none;
  }

  .breadcrumb li {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .breadcrumb li + li::before {
    color: var(--color-border-strong);
    content: "/" / "";
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 0.2em;
  }

  .breadcrumb a:hover {
    color: var(--color-blue);
    text-decoration-color: currentColor;
  }

  .hero-lead {
    max-width: var(--measure-ui);
    margin-top: 1.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    margin-top: 2rem;
  }

  .trigger {
    padding: clamp(1.5rem, 3vw, 2rem);
    border-top: 0.25rem solid var(--color-blue);
    background: var(--color-surface-subtle);
  }

  .trigger-label {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .trigger > p:not(.trigger-label) {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .trigger > p:nth-child(2) {
    margin-top: 1rem;
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-medium);
    line-height: var(--lh-ui);
  }

  .trigger > p + p {
    margin-top: 1rem;
  }

  .questions,
  .fit {
    background: var(--color-surface-subtle);
  }

  .questions {
    scroll-margin-top: var(--header-offset);
  }

  .section-intro-split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(18rem, 0.75fr);
    gap: clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .section-intro-split > p,
  .next-step-copy > p {
    max-width: var(--measure-ui);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .question-list,
  .evidence-grid,
  .output-list,
  .fit-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .question-list {
    border-top: var(--border-width) solid var(--color-border-strong);
  }

  .question-list > li {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .question {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }

  .item-number,
  .output-number {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    font-feature-settings: var(--fea-tabular);
  }

  .question h3 {
    max-width: 31ch;
  }

  .question div > p {
    max-width: var(--measure-ui);
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .evidence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: var(--border-width) solid var(--color-border-strong);
    border-left: var(--border-width) solid var(--color-border-strong);
  }

  .evidence-grid > li {
    min-width: 0;
    border-right: var(--border-width) solid var(--color-border-strong);
    border-bottom: var(--border-width) solid var(--color-border-strong);
  }

  .evidence-grid article {
    height: 100%;
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .evidence-grid h3 {
    margin-top: 0.75rem;
  }

  .evidence-grid article > p:last-child {
    margin-top: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .scope-note {
    display: grid;
    grid-template-columns: minmax(12rem, 0.45fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-left: 0.25rem solid var(--color-blue);
    background: var(--color-surface-subtle);
  }

  .scope-note p {
    max-width: var(--measure-ui);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .outputs {
    padding-block: var(--section-space);
    background: var(--color-ink);
    color: var(--color-text-inverse);
  }

  .outputs-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.75fr);
    gap: 1rem clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .outputs-intro .eyebrow {
    grid-column: 1 / -1;
  }

  .outputs h2,
  .outputs h3 {
    color: var(--color-text-inverse);
  }

  .outputs-intro > p:last-child {
    max-width: var(--measure-ui);
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .output-list {
    border-top: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output-list > li {
    border-bottom: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output {
    display: grid;
    grid-template-columns: minmax(12rem, 0.65fr) minmax(0, 0.9fr) minmax(
        0,
        1fr
      );
    gap: clamp(1.5rem, 5vw, 4rem);
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
    align-items: start;
  }

  .output-number {
    color: var(--color-green);
  }

  .output-heading h3 {
    margin-top: 0.75rem;
  }

  .output-description,
  .output-decision {
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .output-decision {
    padding-left: clamp(1rem, 3vw, 2rem);
    border-left: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .output-decision span {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--color-green);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .fit-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.25rem, 3vw, 2rem);
  }

  .fit-panel {
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    border: var(--border-width) solid var(--color-border-strong);
    border-top: 0.25rem solid var(--color-ink);
    border-radius: var(--radius-md);
    background: var(--color-surface-pure);
  }

  .fit-panel-strong {
    border-top-color: var(--color-blue);
  }

  .fit-label {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .fit-label-muted {
    color: var(--color-text-muted);
  }

  .fit-panel h3 {
    max-width: 27ch;
    margin-top: 0.75rem;
  }

  .fit-panel ul {
    display: grid;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .fit-panel li {
    position: relative;
    padding-left: 1.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .fit-panel li::before {
    position: absolute;
    top: 0.7em;
    left: 0;
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: var(--color-border-strong);
    content: "";
  }

  .fit-panel-strong li::before {
    background: var(--color-blue);
  }

  .next-step-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.8fr);
    gap: clamp(2.5rem, 9vw, 8rem);
