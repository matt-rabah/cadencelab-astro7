---
// src/pages/thanks.astro
import Layout from '../layouts/Layout.astro';
import NavHeader from '../components/NavHeader.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Profile Received | CadenceLab">
  <NavHeader />

  <main class="success-page">
    <div class="success-container">
      
      <div class="status-badge">
        <svg class="success-check" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        <span>Baseline Profile Logged</span>
      </div>

      <div class="message-block">
        <h1 class="success-heading">Your Fit Check is undergoing structural review.</h1>
        <p class="success-lead">
          Thank you for submitting your enterprise environmental baseline. Because we limit our active advisory practice to ensure deep operational oversight, all operational profiles are evaluated manually against our strict data and stakeholder requirements.
        </p>
      </div>

      <div class="timeline-box">
        <h3>What Happens Next</h3>
        <div class="timeline-steps">
          <div class="timeline-step">
            <div class="step-marker">01</div>
            <div class="step-content">
              <h5>Manual Architecture Review</h5>
              <p>Our engineering team evaluates your stated CRM infrastructure bottlenecks and legacy data silo configurations (Within 24 business hours).</p>
            </div>
          </div>

          <div class="timeline-step">
            <div class="step-marker">02</div>
            <div class="step-content">
              <h5>Alignment Determination</h5>
              <p>You will receive an official digital determination outlining whether your workspace meets our cross-functional adoption baselines.</p>
            </div>
          </div>

          <div class="timeline-step">
            <div class="step-marker">03</div>
            <div class="step-content">
              <h5>Strategic Consultation Invitation</h5>
              <p>If alignment is verified, an encrypted calendar pipeline will be provided to book your 30-minute executive briefing session.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="action-zone">
        <a href="/" class="btn-return">Return to Systems Overview</a>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* --- DESIGN TOKENS (Corporate Tech Palette Harmony) --- */
  .success-page {
    width: 100%;
    background-color: #ffffff;
    padding: 100px 24px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .success-container {
    width: 100%;
    max-width: 650px;
    display: flex;
    flex-direction: column;
    gap: 36px;
  }

  /* --- STATUS INDICATOR --- */
  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    align-self: flex-start;
    background-color: #f5f8fa;
    border: 1px solid #cbd6e2;
    padding: 6px 14px;
    border-radius: 20px;
  }

  .status-badge span {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #425b76;
  }

  .success-check {
    width: 14px;
    height: 14px;
    color: #1a73e2; /* Signature tech blue accent */
  }

  /* --- TYPOGRAPHY SCALE --- */
  .message-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .success-heading {
    font-size: 38px;
    font-weight: 800;
    line-height: 1.2;
    color: #1e242c;
    letter-spacing: -0.02em;
  }

  .success-lead {
    font-size: 16px;
    line-height: 1.6;
    color: #425b76;
  }

  /* --- TIMELINE COMPONENT BOX --- */
  .timeline-box {
    background-color: #f5f8fa;
    border: 1px solid #cbd6e2;
    border-radius: 4px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .timeline-box h3 {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1e242c;
    border-bottom: 1px solid #cbd6e2;
    padding-bottom: 12px;
  }

  .timeline-steps {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .timeline-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px;
    align-items: start;
  }

  .step-marker {
    font-size: 12px;
    font-weight: 800;
    color: #1a73e2;
    background-color: rgba(26, 115, 232, 0.1);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  .step-content h5 {
    font-size: 14px;
    font-weight: 700;
    color: #1e242c;
    margin-bottom: 4px;
  }

  .step-content p {
    font-size: 13.5px;
    line-height: 1.5;
    color: #576579;
  }

  /* --- ACTIONS --- */
  .btn-return {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #1e242c;
    color: #ffffff;
    font-size: 14px;
    font-weight: 600;
    padding: 14px 28px;
    border-radius: 3px;
    transition: background-color 0.15s ease;
  }

  .btn-return:hover {
    background-color: #101419;
  }

  /* --- 📱 MOBILE VIEWPORT MATRIX RE-CALIBRATION --- */
  @media (max-width: 600px) {
    .success-page {
      padding: 64px 16px;
    }

    .success-heading {
      font-size: 28px;
    }

    .timeline-box {
      padding: 20px;
    }
  }
</style>
