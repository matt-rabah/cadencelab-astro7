---
// src/pages/thanks.astro

import Footer from "../components/Footer.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Fit assessment received | Cadence Lab"
  description="Your Cadence Lab fit assessment has been received."
  canonicalURL="/thanks/"
  noindex={true}
>
  <NavHeader />

  <main id="main-content" class="thanks-page">
    <div class="thanks-container">
      <div class="status">
        <svg
          class="status-icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="m5 12 4 4L19 6"></path>
        </svg>

        <p>Assessment received</p>
      </div>

      <header class="thanks-header">
        <h1>Thank you for sharing the context.</h1>

        <p>
          Your fit assessment has been submitted. The information will be
          reviewed to understand the problem, operating environment, and
          organizational readiness.
        </p>
      </header>

      <section class="next-steps" aria-labelledby="next-steps-title">
        <h2 id="next-steps-title">What happens next</h2>

        <ol class="steps">
          <li class="step">
            <span class="step-number" aria-hidden="true">01</span>

            <div>
              <h3>The submission is reviewed</h3>

              <p>
                We look at the customer experience problem, current systems,
                data conditions, stakeholder ownership, and readiness for
                workflow change.
              </p>
            </div>
          </li>

          <li class="step">
            <span class="step-number" aria-hidden="true">02</span>

            <div>
              <h3>You receive a direct response</h3>

              <p>
                We will follow up using the email address provided and explain
                whether a conversation appears useful.
              </p>
            </div>
          </li>

          <li class="step">
            <span class="step-number" aria-hidden="true">03</span>

            <div>
              <h3>The next step is defined</h3>

              <p>
                When there is a reasonable fit, the next step may be a short
                discovery conversation to clarify goals, constraints, and
                expected outcomes.
              </p>
            </div>
          </li>
        </ol>
      </section>

      <div class="thanks-actions">
        <a href="/" class="primary-link"> Return to the home page </a>

        <a href="/contact/" class="secondary-link">
          Contact Cadence Lab
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .thanks-page {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface-subtle);
    color: var(--color-text);
  }

  .thanks-container {
    display: flex;
    width: min(calc(100% - (2 * var(--page-gutter))), 46rem);
    margin-inline: auto;
    flex-direction: column;
    align-items: flex-start;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid
      color-mix(in srgb, var(--color-green) 45%, var(--color-border));
    border-radius: 999px;
    background: color-mix(
      in srgb,
      var(--color-green) 8%,
      var(--color-surface-pure)
    );
    color: var(--color-ink);
  }

  .status-icon {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
    color: var(--color-green);
  }

  .status p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .thanks-header {
    display: flex;
    max-width: 43rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .thanks-header h1 {
    max-width: 13ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: clamp(2.75rem, 2rem + 3vw, 5.25rem);
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .thanks-header p {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1rem + 0.25vw, 1.25rem);
    font-weight: 400;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .next-steps {
    display: flex;
    width: 100%;
    flex-direction: column;
    gap: 1.5rem;
    padding: clamp(1.5rem, 5vw, 2.75rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-pure);
    box-shadow: var(--shadow-sm);
  }

  .next-steps h2 {
    margin: 0;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.015em;
  }

  .steps {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .step {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    padding-block: 1.5rem;
  }

  .step + .step {
    border-top: 1px solid var(--color-border);
  }

  .step-number {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .step div {
    min-width: 0;
  }

  .step h3 {
    margin: 0 0 0.625rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: -0.005em;
  }

  .step p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .thanks-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .primary-link {
    display: inline-flex;
    width: fit-content;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    color: var(--color-light);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .primary-link:hover {
    border-color: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
    background: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
    color: var(--color-light);
    text-decoration: none;
  }

  .primary-link:active {
    transform: translateY(1px);
  }

  .secondary-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .secondary-link:hover {
    color: var(--color-blue);
  }

  .primary-link:focus-visible,
  .secondary-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 40rem) {
    .thanks-page {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .thanks-header h1 {
      max-width: 12ch;
      font-size: clamp(2.5rem, 11vw, 4rem);
    }

    .next-steps {
      padding: 1.25rem;
    }

    .step {
      grid-template-columns: 1fr;
      gap: 0.625rem;
    }

    .thanks-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .primary-link,
    .secondary-link {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .primary-link {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .status,
    .next-steps,
    .primary-link {
      border-color: CanvasText;
    }
  }
</style>
