---
// src/pages/fit-check.astro

import { getEntry } from "astro:content";

import Footer from "../components/Footer.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";

const pageData = await getEntry("page", "fit-check");

if (!pageData) {
  throw new Error(
    "Content entry not found for 'src/content/pages/fit-check.md'. " +
      "Confirm that the file exists and matches the page collection schema.",
  );
}

const { title, subtitle, category } = pageData.data;

const pageTitle = `${title} | Cadence Lab`;

const pageDescription =
  subtitle ??
  "Assess whether your customer experience, CRM, and AI initiative is ready for a productive engagement.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalURL="/fit-check/"
>
  <NavHeader />

  <main id="main-content" class="fit-check-page">
    <div class="fit-check-container">
      <header class="fit-check-header">
        <p class="fit-check-eyebrow">{category}</p>

        <h1 class="fit-check-title">{title}</h1>

        <p class="fit-check-intro">{subtitle}</p>

        <p class="fit-check-context">
          This is not a technical audit or a sales qualification exercise. The
          goal is to understand whether the operating problem is clear enough,
          the conditions are workable, and a consulting engagement would
          actually be useful.
        </p>
      </header>

      <form
        class="fit-check-form"
        method="post"
        action="/thanks/"
        aria-labelledby="fit-check-form-title"
      >
        <h2 id="fit-check-form-title" class="visually-hidden">
          Fit assessment form
        </h2>

        <fieldset class="form-section">
          <legend>
            <span class="section-number" aria-hidden="true">01</span>
            Customer experience problem
          </legend>

          <div class="input-group">
            <label for="challenge">
              What customer experience problem are you trying to solve?
            </label>

            <textarea
              id="challenge"
              name="challenge"
              rows="5"
              autocomplete="off"
              placeholder="Describe the customer friction, affected teams, and business impact."
              required></textarea>
          </div>

          <div class="input-group">
            <label for="impact">
              What outcome would make this work successful?
            </label>

            <textarea
              id="impact"
              name="impact"
              rows="4"
              autocomplete="off"
              placeholder="Examples: improve retention, reduce service effort, increase adoption, or strengthen measurement."
              required></textarea>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>
            <span class="section-number" aria-hidden="true">02</span>
            Operating environment
          </legend>

          <div class="input-group">
            <label for="environment">
              Which description best matches your current environment?
            </label>

            <select id="environment" name="environment" required>
              <option value="" disabled selected>
                Select the closest description
              </option>

              <option value="fragmented">
                Multiple disconnected systems and inconsistent workflows
              </option>

              <option value="transitioning">
                Systems or processes are currently being consolidated
              </option>

              <option value="modern-siloed">
                Modern tools exist, but teams or workflows remain siloed
              </option>

              <option value="established">
                Core systems and workflows are established but need improvement
              </option>

              <option value="uncertain">
                We need help understanding the current state
              </option>
            </select>
          </div>

          <div class="input-group">
            <label for="crm">
              What role does CRM data play in the current workflow?
            </label>

            <select id="crm" name="crm" required>
              <option value="" disabled selected>
                Select the closest description
              </option>

              <option value="measured">
                CRM data is connected to workflows and performance measures
              </option>

              <option value="active-limited">
                Data is collected, but its operational use is limited
              </option>

              <option value="fragmented">
                Data quality or ownership is inconsistent across teams
              </option>

              <option value="early">CRM use is still developing</option>

              <option value="unknown">
                We are not sure how reliable or useful the data is
              </option>
            </select>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>
            <span class="section-number" aria-hidden="true">03</span>
            Readiness and ownership
          </legend>

          <div class="input-group">
            <span class="group-label">
              Is there an accountable leader who can support cross-functional
              decisions?
            </span>

            <div
              class="radio-group"
              role="radiogroup"
              aria-label="Accountable leadership"
            >
              <label class="radio-option">
                <input type="radio" name="leadership" value="yes" required />
                <span>Yes, an accountable sponsor is involved.</span>
              </label>

              <label class="radio-option">
                <input type="radio" name="leadership" value="developing" />
                <span>Support exists, but ownership is still developing.</span>
              </label>

              <label class="radio-option">
                <input type="radio" name="leadership" value="no" />
                <span>No, we are still building internal alignment.</span>
              </label>
            </div>
          </div>

          <div class="input-group">
            <span class="group-label">
              Is the organization willing to change workflows, ownership, or
              operating practices?
            </span>

            <div
              class="radio-group"
              role="radiogroup"
              aria-label="Willingness to change workflows"
            >
              <label class="radio-option">
                <input
                  type="radio"
                  name="change-readiness"
                  value="yes"
                  required
                />
                <span>Yes, workflow changes are within scope.</span>
              </label>

              <label class="radio-option">
                <input type="radio" name="change-readiness" value="limited" />
                <span>Possibly, depending on the recommendation.</span>
              </label>

              <label class="radio-option">
                <input type="radio" name="change-readiness" value="no" />
                <span
                  >No, the current process must remain largely unchanged.</span
                >
              </label>
            </div>
          </div>
        </fieldset>

        <fieldset class="form-section">
          <legend>
            <span class="section-number" aria-hidden="true">04</span>
            Contact information
          </legend>

          <div class="form-grid">
            <div class="input-group">
              <label for="name">Name</label>

              <input
                id="name"
                name="name"
                type="text"
                autocomplete="name"
                required
              />
            </div>

            <div class="input-group">
              <label for="email">Work email</label>

              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                required
              />
            </div>
          </div>

          <div class="form-grid">
            <div class="input-group">
              <label for="organization">Organization</label>

              <input
                id="organization"
                name="organization"
                type="text"
                autocomplete="organization"
                required
              />
            </div>

            <div class="input-group">
              <label for="role">Role</label>

              <input
                id="role"
                name="role"
                type="text"
                autocomplete="organization-title"
              />
            </div>
          </div>

          <div class="input-group">
            <label for="additional-context">
              Anything else we should understand?
              <span class="optional-label">(Optional)</span>
            </label>

            <textarea
              id="additional-context"
              name="additional-context"
              rows="4"
              autocomplete="off"></textarea>
          </div>
        </fieldset>

        <div class="form-footer">
          <p class="form-note">
            Submitting this form does not create a consulting agreement. Your
            information will be used only to review the inquiry and respond.
          </p>

          <button type="submit" class="submit-button">
            Submit fit assessment
          </button>
        </div>
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .fit-check-page {
    width: 100%;
    padding-block: clamp(4rem, 9vw, 7rem);
    background: var(--color-surface-subtle);
    color: var(--color-text);
  }

  .fit-check-container {
    display: grid;
    width: min(calc(100% - (2 * var(--page-gutter))), 52rem);
    margin-inline: auto;
    gap: clamp(3rem, 7vw, 5rem);
  }

  .fit-check-header {
    display: flex;
    max-width: 46rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .fit-check-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--ls-eyebrow);
    font-feature-settings: var(--fea-eyebrow);
    text-transform: uppercase;
  }

  .fit-check-title {
    max-width: 16ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .fit-check-intro {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .fit-check-context {
    max-width: var(--measure-ui);
    margin: 0;
    padding-top: 0.25rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    line-height: 1.6;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .fit-check-form {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
    padding: clamp(1.5rem, 5vw, 3.5rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface-pure);
    box-shadow: var(--shadow-sm);
  }

  .form-section {
    display: grid;
    gap: 1.5rem;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .form-section legend {
    display: flex;
    width: 100%;
    align-items: baseline;
    gap: 0.75rem;
    margin: 0 0 0.25rem;
    padding: 0 0 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h4);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h4);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .section-number {
    color: var(--color-blue);
    font-size: 0.75rem;
    font-weight: var(--fw-medium);
    font-feature-settings: var(--fea-tabular);
  }

  .input-group {
    display: grid;
    gap: 0.625rem;
    min-width: 0;
  }

  .input-group label,
  .group-label {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: var(--fw-medium);
    line-height: 1.45;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .optional-label {
    color: var(--color-text-muted);
    font-weight: var(--fw-regular);
  }

  input[type="text"],
  input[type="email"],
  select,
  textarea {
    width: 100%;
    min-height: 3rem;
    padding: 0.8125rem 0.875rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: var(--fw-regular);
    line-height: 1.5;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      background-color var(--transition-fast);
  }

  textarea {
    min-height: 8rem;
    resize: vertical;
  }

  select {
    cursor: pointer;
  }

  input::placeholder,
  textarea::placeholder {
    color: var(--color-text-subtle);
    opacity: 1;
  }

  input:hover,
  select:hover,
  textarea:hover {
    border-color: var(--color-ink);
  }

  input:focus-visible,
  select:focus-visible,
  textarea:focus-visible {
    border-color: var(--color-focus);
    outline: 0;
    box-shadow: 0 0 0 var(--focus-ring-width)
      color-mix(in srgb, var(--color-focus) 25%, transparent);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .radio-group {
    display: grid;
    gap: 0.75rem;
  }

  .radio-option {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
    padding: 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
  }

  .radio-option:hover {
    border-color: var(--color-border-strong);
  }

  .radio-option:has(input:checked) {
    border-color: var(--color-blue);
    background: color-mix(
      in srgb,
      var(--color-blue) 5%,
      var(--color-surface-pure)
    );
    color: var(--color-ink);
  }

  .radio-option input {
    width: 1rem;
    height: 1rem;
    margin: 0.2rem 0 0;
    accent-color: var(--color-blue);
  }

  .radio-option span {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: var(--fw-regular);
    line-height: 1.5;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .form-note {
    max-width: 34rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-regular);
    line-height: 1.5;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .submit-button {
    display: inline-flex;
    min-height: 3rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    color: var(--color-light);
    font-family: var(--font-sans);
    font-size: var(--fs-cta);
    font-weight: var(--fw-medium);
    line-height: 1.2;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    cursor: pointer;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .submit-button:hover {
    border-color: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
    background: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
  }

  .submit-button:active {
    transform: translateY(1px);
  }

  .submit-button:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 40rem) {
    .fit-check-page {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .fit-check-title {
      max-width: 14ch;
    }

    .fit-check-form {
      padding: 1.25rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .form-footer {
      flex-direction: column;
      align-items: stretch;
    }

    .submit-button {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    input,
    select,
    textarea,
    .submit-button {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .fit-check-form,
    .radio-option,
    input,
    select,
    textarea,
    .submit-button {
      border-color: CanvasText;
    }
  }
</style>
