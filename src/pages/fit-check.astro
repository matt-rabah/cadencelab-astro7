---
// src/pages/fit-check.astro
import Layout from "../layouts/Layout.astro";
import NavHeader from "../components/NavHeader.astro";
import Footer from "../components/Footer.astro";

// 1. Fetch the data file we just created
import { getEntry } from "astro:content";
const pageData = await getEntry("page", "fit-check");

// 2. Extract the editable values
if (!pageData) {
  throw new Error(
    "Could not find content entry 'fit-check' in 'page' collection.",
  );
}
const { title, subtitle, category } = pageData.data;
---

<Layout>
  <NavHeader />

  <main class="fit-check-page">
    <div class="form-container">
      <header class="form-header">
        <!-- 3. Use the dynamic variables here instead of raw text -->
        <span class="form-tag">{category}</span>
        <h1 class="form-heading">{title}</h1>
        <p class="form-subheading">{subtitle}</p>
      </header>

      <form class="assessment-form" method="POST" action="/thanks">
        <!-- Section 1: Environmental Complexity -->
        <fieldset class="form-section">
          <legend>01. Technical & Operational Complexity</legend>

          <div class="input-group">
            <label for="environment-type"
              >Describe the current state of your legacy CX infrastructure.</label
            >
            <select id="environment-type" name="environment-type" required>
              <option value="" disabled selected
                >Select an operational baseline...</option
              >
              <option value="fractured"
                >Highly fractured (Multiple disconnected legacy systems)</option
              >
              <option value="transitioning"
                >In transition (Migrating or attempting to unify tools)</option
              >
              <option value="modern-silo"
                >Modern but siloed (Tools are active, but cross-functional teams
                don't utilize them)</option
              >
            </select>
          </div>

          <div class="input-group">
            <label for="bottleneck"
              >What is your primary system point of failure right now?</label
            >
            <textarea
              id="bottleneck"
              name="bottleneck"
              rows="3"
              placeholder="e.g., Staff is bypassing our new AI routing tool; data isn't clean..."
              required></textarea>
          </div>
        </fieldset>

        <!-- Section 2: Data & Executive Governance -->
        <fieldset class="form-section">
          <legend>02. Data Architecture & Authority</legend>

          <div class="input-group">
            <label for="crm-status"
              >What is the baseline maturity of your Salesforce / CRM data?</label
            >
            <select id="crm-status" name="crm-status" required>
              <option value="" disabled selected>Select data status...</option>
              <option value="mature"
                >Established architecture (Traced to retention metrics)</option
              >
              <option value="dirty"
                >Active data collection, but lacks clear workflow tracing</option
              >
              <option value="undeployed"
                >Basic logging only (Data exists but is underutilized)</option
              >
            </select>
          </div>

          <div class="input-group">
            <label for="mandate"
              >Do you currently have an explicit cross-functional mandate from
              leadership to execute workflow changes?</label
            >
            <div class="radio-group">
              <label
                ><input type="radio" name="mandate" value="yes" required /> Yes, we
                have active executive backing.</label
              >
              <label
                ><input type="radio" name="mandate" value="no" /> No, we are currently
                trying to build internal buy-in.</label
              >
            </div>
          </div>
        </fieldset>

        <!-- Section 3: Professional Profile -->
        <fieldset class="form-section">
          <legend>03. Stakeholder Profile</legend>

          <div class="grid-inputs">
            <div class="input-group">
              <label for="name">Your Name</label>
              <input type="text" id="name" name="name" required />
            </div>
            <div class="input-group">
              <label for="email">Corporate Email</label>
              <input type="email" id="email" name="email" required />
            </div>
          </div>

          <div class="input-group">
            <label for="org">Organization</label>
            <input type="text" id="org" name="org" required />
          </div>
        </fieldset>

        <button type="submit" class="btn-submit"
          >Submit Baseline Profile for Review</button
        >
      </form>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* Keep all your existing CSS exactly the same here */
  .fit-check-page {
    width: 100%;
    background-color: var(--spectrum-background-layer-1, #f4f5f7);
    padding: 80px 24px;
    display: flex;
    justify-content: center;
  }
  .form-container {
    width: 100%;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .form-header {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .form-tag {
    font-family: adobe-clean, sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: var(--spectrum-global-color-accent, #0265dc);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .form-heading {
    font-family: adobe-clean, sans-serif;
    font-size: 44px;
    font-weight: 900;
    color: #161616;
    letter-spacing: -0.03em;
  }

  .form-subheading {
    font-family: adobe-clean, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--spectrum-body-color, #4b4b4b);
  }

  .assessment-form {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .form-section {
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-section legend {
    font-family: adobe-clean, sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    color: #161616;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(22, 22, 22, 0.08);
    width: 100%;
    padding-bottom: 8px;
    margin-bottom: 8px;
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .input-group label {
    font-family: adobe-clean, sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #161616;
    line-height: 1.4;
  }
  input[type="text"],
  input[type="email"],
  select,
  textarea {
    font-family: adobe-clean, sans-serif;
    font-size: 15px;
    padding: 14px;
    background-color: var(--spectrum-background-layer-2, #f4f5f7);
    border: 1px solid rgba(22, 22, 22, 0.06);
    border-radius: 4px;
    color: #161616;
    outline: none;
    transition: border-color 0.2s ease;
  }
  input:focus,
  select:focus,
  textarea:focus {
    border-color: var(--spectrum-global-color-accent, #1823c9);
    background-color: var(--spectrum-background-layer-1, #f4f5f7);
  }
  .grid-inputs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .radio-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 4px;
  }
  .radio-group label {
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
  }
  .btn-submit {
    font-family: adobe-clean, sans-serif;
    font-size: 16px;
    font-weight: 600;
    background-color: #161616;
    color: #f4f5f7;
    padding: 16px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.15s ease;
    text-align: center;
    margin-top: 16px;
  }
  .btn-submit:hover {
    opacity: 0.9;
  }

  @media (max-width: 600px) {
    .grid-inputs {
      grid-template-columns: 1fr;
    }

    .form-heading {
      font-size: 34px;
    }
  }
</style>
