---
// src/pages/blog/[year]/[month]/[slug].astro
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content'; // Import type for compilation safety
import Layout from '../../../../layouts/Layout.astro';
import NavHeader from '../../../../components/NavHeader.astro';
import Footer from '../../../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('post');

  return posts.map((post) => {
    const postDate = new Date(post.data.date);
    const year = postDate.getFullYear().toString();
    const month = String(postDate.getMonth() + 1).padStart(2, '0');

    // Strip any file extension that may leak out from post.id.
    const cleanId = post.id.replace(/\.(md|mdx)$/, '');
    const slug = cleanId.split('/').pop();

    return {
      params: { year, month, slug },
      props: { post },
    };
  });
}

// 📦 Define explicit Props interface for strict Astro 7 compiler environments
interface Props {
  post: CollectionEntry<'post'>;
}

const { post } = Astro.props;

// 🛡️ PRE-RENDER GUARD: Prevents compiler crashes if props evaluate as empty during initial discovery passes
if (!post || !post.data) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);

// Bulletproof Date Normalization Engine
const publishedDate =
  post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
const isValidDate = !isNaN(publishedDate.getTime());

const formattedDate =
  isValidDate ?
    publishedDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
      timeZone: 'UTC',
    })
  : 'Unknown Date';

const isoDate = isValidDate ? publishedDate.toISOString().slice(0, 10) : '';
---

<Layout
  title={`${post.data.title} | CadenceLab Insights`}
  description={post.data.subtitle}>
  <NavHeader />

  <article class="article-canvas">
    <header class="article-hero-header">
      <div class="article-meta-rail">
        <span class="meta-category">{post.data.category}</span>
        <span class="meta-separator">•</span>
        {isValidDate && <time datetime={isoDate}>{formattedDate}</time>}
        <span class="meta-separator">•</span>
        <span>{post.data.readTime}</span>
      </div>

      <h1 class="article-main-title">{post.data.title}</h1>
      <p class="article-lead-abstract">{post.data.subtitle}</p>
    </header>

    <hr class="section-divider" />

    <div class="article-body-stream">
      <Content />
    </div>
  </article>

  <Footer />
</Layout>

<style>
  .article-canvas {
    width: 100%;
    background-color: #ffffff;
    padding: 96px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .article-hero-header {
    width: 100%;
    max-width: 740px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .article-meta-rail {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: #576579;
  }

  .meta-category {
    color: #1a73e2;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-separator {
    color: #cbd6e2;
  }

  .article-main-title {
    font-family: var(--font-serif-fine), Georgia, serif !important;
    font-weight: 700;
    line-height: 1.05 !important;
    letter-spacing: -0.03em !important;
    color: #000000;
  }

  .article-lead-abstract {
    font-family: var(--font-serif-text) !important;
    font-size: 21px !important;
    line-height: 1.5 !important;
    font-weight: 400 !important;
    color: #425b76 !important;
    margin: 8px 0 12px 0;
  }

  .section-divider {
    width: 100%;
    max-width: 740px;
    border: none;
    border-top: 1px solid #cbd6e2;
    margin: 40px 0;
  }

  .article-body-stream {
    width: 100%;
    max-width: 740px;
    display: flex;
    flex-direction: column;
  }

  .article-body-stream :global(p) {
    margin-bottom: 24px;
  }

  .article-body-stream :global(h2) {
    font-family: var(--font-sans) !important;
    font-size: 28px !important;
    font-weight: 700 !important;
    line-height: 1.2 !important;
    letter-spacing: -0.02em !important;
    margin: 40px 0 20px 0;
    color: #000000;
  }

  .article-body-stream :global(h3) {
    font-family: var(--font-sans) !important;
    font-size: 22px !important;
    font-weight: 600 !important;
    line-height: 1.3 !important;
    letter-spacing: -0.01em !important;
    margin: 32px 0 16px 0;
    color: #161616;
  }

  .article-body-stream :global(ul) {
    list-style-type: none;
    padding-left: 16px;
    margin-bottom: 32px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .article-body-stream :global(li) {
    font-family: var(--font-serif-text);
    font-size: 18px;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.85);
    position: relative;
    padding-left: 24px;
  }

  .article-body-stream :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10px;
    width: 6px;
    height: 6px;
    background-color: #1a73e2;
    border-radius: 1px;
  }

  .article-body-stream :global(blockquote) {
    font-family: var(--font-serif-text);
    font-size: 24px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: #1a73e2;
    border-left: 3px solid #1a73e2;
    padding-left: 32px;
    margin: 40px 0;
    max-width: 680px;
    align-self: center;
  }

  @media (max-width: 768px) {
    .article-canvas {
      padding: 64px 16px;
    }
    .article-lead-abstract {
      font-size: 19px !important;
    }
  }
</style>
