---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

import ArticleToc from "../../../../components/blog/ArticleToc.astro";
import AuthorBio from "../../../../components/blog/AuthorBio.astro";
import Footer from "../../../../components/Footer.astro";
import NavHeader from "../../../../components/NavHeader.astro";
import RelatedPosts from "../../../../components/blog/RelatedPosts.astro";
import Layout from "../../../../layouts/Layout.astro";

type BlogPost = CollectionEntry<"blog">;

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  return posts.map((post) => {
    const publishedDate = post.data.date;

    const year = String(publishedDate.getUTCFullYear());
    const month = String(publishedDate.getUTCMonth() + 1).padStart(2, "0");

    const slug = post.id
      .replace(/\.(md|mdx)$/i, "")
      .split("/")
      .filter(Boolean)
      .at(-1);

    if (!slug) {
      throw new Error(`Unable to determine a slug for blog entry: ${post.id}`);
    }

    return {
      params: {
        year,
        month,
        slug,
      },
      props: {
        post,
      },
    };
  });
}

const { post } = Astro.props as { post: BlogPost };
const { Content, headings } = await render(post);

const publishedDate = post.data.date;
const updatedDate = post.data.updatedDate;

const formatDate = (date: Date): string =>
  new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(date);

const publishedDateLabel = formatDate(publishedDate);

const updatedDateLabel = updatedDate ? formatDate(updatedDate) : undefined;

const publishedDateISO = publishedDate.toISOString();
const updatedDateISO = updatedDate?.toISOString();

const description = post.data.description ?? post.data.subtitle;

const author = post.data.author ?? "Cadence Lab";
const canonicalPath = Astro.url.pathname;

const getPostURL = (entry: BlogPost): string => {
  const year = String(entry.data.date.getUTCFullYear());
  const month = String(entry.data.date.getUTCMonth() + 1).padStart(2, "0");
  const slug = entry.id
    .replace(/\.(md|mdx)$/i, "")
    .split("/")
    .filter(Boolean)
    .at(-1);

  if (!slug) {
    throw new Error(`Unable to determine a slug for blog entry: ${entry.id}`);
  }

  return `/blog/${year}/${month}/${slug}/`;
};

const relatedPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((entry) => entry.id !== post.id)
  .sort((a, b) => {
    const aMatchesCategory = a.data.category === post.data.category ? 1 : 0;
    const bMatchesCategory = b.data.category === post.data.category ? 1 : 0;

    return (
      bMatchesCategory - aMatchesCategory ||
      b.data.date.getTime() - a.data.date.getTime()
    );
  })
  .slice(0, 3)
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description ?? entry.data.subtitle,
    category: entry.data.category,
    readTime: entry.data.readTime,
    href: getPostURL(entry),
  }));

const imageSource = post.data.image
  ? post.data.image.startsWith("/")
    ? post.data.image
    : `/${post.data.image}`
  : undefined;

const imageAlt = post.data.imageAlt ?? "";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description,
  datePublished: publishedDateISO,

  ...(updatedDateISO
    ? {
        dateModified: updatedDateISO,
      }
    : {}),

  author: {
    "@type": author === "Cadence Lab" ? "Organization" : "Person",
    name: author,
  },

  publisher: {
    "@type": "Organization",
    name: "Cadence Lab",
    url: "https://cadencelab.co/",
  },

  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(canonicalPath, "https://cadencelab.co").href,
  },

  ...(imageSource
    ? {
        image: new URL(imageSource, "https://cadencelab.co").href,
      }
    : {}),
};
---

<Layout
  title={`${post.data.title} | Cadence Lab`}
  description={description}
  canonicalURL={canonicalPath}
  pageType="article"
>
  <NavHeader />

  <main id="main-content" class="article-page">
    <article class="article">
      <header class="article-header">
        <a href="/blog/" class="article-back-link">
          <span aria-hidden="true">←</span>
          All insights
        </a>

        <div class="article-metadata">
          <span class="article-category">
            {post.data.category}
          </span>

          <span aria-hidden="true">·</span>

          <time datetime={publishedDateISO}>
            {publishedDateLabel}
          </time>

          <span aria-hidden="true">·</span>

          <span>{post.data.readTime}</span>
        </div>

        <h1>{post.data.title}</h1>

        <p class="article-subtitle">
          {post.data.subtitle}
        </p>

        <div class="article-byline">
          <span>By {author}</span>

          {
            updatedDate && updatedDateISO && updatedDateLabel && (
              <>
                <span aria-hidden="true">·</span>

                <span>
                  Updated{" "}
                  <time datetime={updatedDateISO}>{updatedDateLabel}</time>
                </span>
              </>
            )
          }
        </div>
      </header>

      {
        imageSource && (
          <figure class="article-image">
            <img
              src={imageSource}
              alt={imageAlt}
              width="1440"
              height="810"
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </figure>
        )
      }

      <div class="article-content">
        <div class="article-body prose">
          <Content />
        </div>

        <aside class="article-sidebar">
          <ArticleToc headings={headings} />
        </aside>
      </div>

      <AuthorBio author={author} />
      <RelatedPosts posts={relatedPosts} />
    </article>
  </main>

  <Footer />

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(articleSchema)}
  />
</Layout>

<style>
  .article-page {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .article {
    display: flex;
    width: min(calc(100% - (2 * var(--page-gutter))), 72rem);
    margin-inline: auto;
    flex-direction: column;
    align-items: center;
  }

  .article-header {
    display: flex;
    width: min(100%, 52rem);
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .article-back-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-decoration: none;
  }

  .article-back-link:hover {
    color: var(--color-blue);
  }

  .article-metadata,
  .article-byline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: 1.5;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .article-metadata time,
  .article-byline time {
    font-feature-settings: var(--fea-tabular);
  }

  .article-category {
    color: var(--color-blue);
    font-weight: var(--fw-medium);
  }

  .article-header h1 {
    max-width: 18ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-post-title);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-post-title);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .article-subtitle {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .article-image {
    width: 100%;
    margin: clamp(3rem, 7vw, 5rem) 0 0;
  }

  .article-image img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 42rem;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  .article-content {
    display: grid;
    width: 100%;
    grid-template-columns: minmax(0, var(--measure-prose)) minmax(13rem, 16rem);
    justify-content: center;
    gap: clamp(3rem, 6vw, 5rem);
    margin-top: clamp(3rem, 7vw, 5rem);
    align-items: start;
  }

  .article-body {
    width: 100%;
    padding-top: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--color-border);
  }

  .article-sidebar {
    position: sticky;
    inset-block-start: calc(var(--header-offset, 6.5rem) + 2rem);
    min-width: 0;
    padding-top: clamp(2.5rem, 5vw, 4rem);
  }

  .article-body :global(h2) {
    margin-top: 2.75em;
    scroll-margin-top: calc(var(--header-offset, 6.5rem) + 2rem);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-post-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .article-body :global(h3) {
    margin-top: 2.25em;
    scroll-margin-top: calc(var(--header-offset, 6.5rem) + 2rem);
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-post-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
    font-feature-settings: var(--fea-graphik);
  }

  .article-body :global(p),
  .article-body :global(li) {
    color: var(--color-text);
    font-family: var(--ff-serif);
    font-size: var(--fs-post-body);
    font-weight: var(--fw-regular);
    line-height: var(--lh-post-body);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-block: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li + li) {
    margin-top: 0.75rem;
  }

  .article-body :global(blockquote) {
    margin: 2.5rem 0;
    padding-left: clamp(1.25rem, 3vw, 2rem);
    border-left: 0.25rem solid var(--color-blue);
    color: var(--color-ink);
  }

  .article-body :global(blockquote p) {
    margin: 0;
    font-family: var(--ff-serif-display);
    font-size: var(--fs-pullquote);
    font-style: italic;
    font-weight: var(--fw-display-light);
    line-height: 1.45;
  }

  .article-body :global(a) {
    color: var(--color-blue);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .article-body :global(img) {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    margin-block: 2.5rem;
    border-radius: var(--radius-sm);
  }

  .article-body :global(pre) {
    max-width: 100%;
    overflow-x: auto;
  }

  .article-back-link:focus-visible,
  .article-body :global(a:focus-visible) {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 64rem) {
    .article-content {
      grid-template-columns: minmax(0, var(--measure-prose));
      gap: 2rem;
    }

    .article-sidebar {
      position: static;
      grid-row: 1;
      padding-top: 0;
    }
  }

  @media (max-width: 40rem) {
    .article-page {
      padding-block: 3.5rem 5rem;
    }

    .article-header h1 {
      max-width: none;
    }
  }

  @media (forced-colors: active) {
    .article-body,
    .article-body :global(blockquote) {
      border-color: CanvasText;
    }
  }
</style>
