---
// src/pages/blog/index.astro

import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

import Footer from "../../components/Footer.astro";
import NavHeader from "../../components/NavHeader.astro";
import Layout from "../../layouts/Layout.astro";

type BlogPost = CollectionEntry<"blog"> & {
  data: CollectionEntry<"blog">["data"] & {
    date: Date;
    title: string;
    subtitle: string;
    readTime: string;
    category: string;
    draft: boolean;
    description?: string;
    updatedDate?: Date;
    image?: string;
    imageAlt?: string;
  };
};

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .filter(
    (post): post is BlogPost =>
      typeof post.data === "object" &&
      post.data !== null &&
      "date" in post.data,
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const [featuredPost, ...remainingPosts] = posts;

const getPostURL = (post: BlogPost): string => {
  const year = String(post.data.date.getUTCFullYear());
  const month = String(post.data.date.getUTCMonth() + 1).padStart(2, "0");

  const slug = post.id
    .replace(/\.(md|mdx)$/i, "")
    .split("/")
    .filter(Boolean)
    .at(-1);

  if (!slug) {
    throw new Error(`Unable to determine a slug for blog entry: ${post.id}`);
  }

  return `/blog/${year}/${month}/${slug}/`;
};

const formatDate = (date: Date): string =>
  new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(date);

const getDescription = (post: BlogPost): string =>
  post.data.description ?? post.data.subtitle;
---

<Layout
  title="Insights | Cadence Lab"
  description="Perspectives on customer experience systems, CRM workflows, AI adoption, governance, and measurable operational improvement."
  canonicalURL="/blog/"
  pageType="website"
>
  <NavHeader />

  <main id="main-content" class="blog-index">
    <div class="blog-container">
      <header class="blog-header">
        <p class="blog-eyebrow">Insights</p>

        <h1>Practical thinking for complex customer systems.</h1>

        <p class="blog-introduction">
          Analysis and guidance on customer experience operations, CRM data,
          workflow design, responsible AI adoption, and the organizational
          conditions that shape results.
        </p>
      </header>

      {
        featuredPost ? (
          <>
            <section
              class="featured-section"
              aria-labelledby="featured-post-title"
            >
              <article class="featured-post">
                <div class="post-metadata">
                  <span>{featuredPost.data.category}</span>

                  <span aria-hidden="true">·</span>

                  <time datetime={featuredPost.data.date.toISOString()}>
                    {formatDate(featuredPost.data.date)}
                  </time>

                  <span aria-hidden="true">·</span>

                  <span>{featuredPost.data.readTime}</span>
                </div>

                <h2 id="featured-post-title">
                  <a href={getPostURL(featuredPost)}>
                    {featuredPost.data.title}
                  </a>
                </h2>

                <p>{getDescription(featuredPost)}</p>

                <a
                  href={getPostURL(featuredPost)}
                  class="featured-link"
                  aria-label={`Read ${featuredPost.data.title}`}
                >
                  Read the article
                  <span aria-hidden="true">→</span>
                </a>
              </article>
            </section>

            {remainingPosts.length > 0 && (
              <section class="archive-section" aria-labelledby="archive-title">
                <div class="archive-heading">
                  <h2 id="archive-title">More insights</h2>

                  <p>Browse the latest published thinking from Cadence Lab.</p>
                </div>

                <div class="post-grid">
                  {remainingPosts.map((post) => (
                    <article class="post-card">
                      <div class="post-metadata">
                        <span>{post.data.category}</span>

                        <span aria-hidden="true">·</span>

                        <time datetime={post.data.date.toISOString()}>
                          {formatDate(post.data.date)}
                        </time>
                      </div>

                      <h3>
                        <a href={getPostURL(post)}>{post.data.title}</a>
                      </h3>

                      <p>{getDescription(post)}</p>

                      <div class="post-card-footer">
                        <span>{post.data.readTime}</span>

                        <a
                          href={getPostURL(post)}
                          aria-label={`Read ${post.data.title}`}
                        >
                          Read article
                          <span aria-hidden="true">→</span>
                        </a>
                      </div>
                    </article>
                  ))}
                </div>
              </section>
            )}
          </>
        ) : (
          <section class="empty-state" aria-labelledby="empty-state-title">
            <h2 id="empty-state-title">No articles are published yet.</h2>

            <p>
              New perspectives on customer experience systems and responsible AI
              adoption will appear here as they are published.
            </p>

            <a href="/" class="return-link">
              Return to the home page
            </a>
          </section>
        )
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .blog-index {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .blog-container {
    display: flex;
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
    flex-direction: column;
    gap: clamp(4rem, 9vw, 7rem);
  }

  .blog-header {
    display: flex;
    max-width: 58rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .blog-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--ls-eyebrow);
    font-feature-settings: var(--fea-eyebrow);
    text-transform: uppercase;
  }

  .blog-header h1 {
    max-width: 17ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .blog-introduction {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .featured-section {
    padding-block: clamp(2.5rem, 6vw, 4.5rem);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .featured-post {
    display: flex;
    max-width: 60rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .post-metadata {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .post-metadata span:first-child {
    color: var(--color-blue);
    font-weight: var(--fw-medium);
  }

  .post-metadata time {
    font-feature-settings: var(--fea-tabular);
  }

  .featured-post h2 {
    max-width: 20ch;
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--fs-post-title);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-post-title);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .featured-post h2 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .featured-post h2 a:hover {
    color: var(--color-blue);
  }

  .featured-post > p {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .featured-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-cta);
    font-weight: var(--fw-medium);
    line-height: 1.2;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .featured-link:hover {
    color: var(--color-ink);
  }

  .archive-section {
    display: flex;
    flex-direction: column;
    gap: clamp(2rem, 5vw, 3.5rem);
  }

  .archive-heading {
    display: flex;
    max-width: 42rem;
    flex-direction: column;
    gap: 0.75rem;
  }

  .archive-heading h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
  }

  .archive-heading p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--color-border);
  }

  .post-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:not(:nth-child(3n + 1)) {
    border-left: 1px solid var(--color-border);
  }

  .post-card h3 {
    margin: 0;
    font-family: var(--font-sans);
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .post-card h3 a {
    color: var(--color-ink);
    text-decoration: none;
  }

  .post-card h3 a:hover {
    color: var(--color-blue);
  }

  .post-card > p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: var(--fw-regular);
    line-height: 1.6;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .post-card-footer {
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: auto;
    padding-top: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--fw-regular);
    line-height: 1.4;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .post-card-footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-blue);
    font-weight: var(--fw-medium);
    text-decoration: none;
  }

  .post-card-footer a:hover {
    text-decoration: underline;
  }

  .empty-state {
    display: flex;
    max-width: 42rem;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding-block: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .empty-state h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
  }

  .empty-state p {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .return-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-cta);
    font-weight: var(--fw-medium);
    line-height: 1.2;
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .featured-post a:focus-visible,
  .post-card a:focus-visible,
  .return-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 64rem) {
    .post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .post-card:not(:nth-child(3n + 1)) {
      border-left: 0;
    }

    .post-card:nth-child(even) {
      border-left: 1px solid var(--color-border);
    }
  }

  @media (max-width: 40rem) {
    .blog-index {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .blog-header h1 {
      max-width: 14ch;
    }

    .featured-post h2 {
      max-width: 18ch;
    }

    .post-grid {
      grid-template-columns: 1fr;
    }

    .post-card,
    .post-card:nth-child(even) {
      padding-inline: 0;
      border-left: 0;
    }
  }

  @media (forced-colors: active) {
    .featured-section,
    .post-grid,
    .post-card,
    .empty-state {
      border-color: CanvasText;
    }
  }
</style>
