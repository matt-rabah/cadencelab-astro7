---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import NavHeader from '../../components/NavHeader.astro';
import Footer from '../../components/Footer.astro';

// Premium Institutional Taxonomy Tags
const categories = ["All Insights", "Workflows", "Advisory", "AI Tooling", "Governance Solutions"];

// File-Based Post Target Registry
const featuredPost = {
  title: "The Hidden Operational Cost of User Adoption Fatigue in Enterprise Architecture",
  excerpt: "An empirical investigation into why cross-functional automation systems collapse when human adoption drop-offs outpace raw computing capability.",
  date: "June 23, 2026",
  readTime: "9 min read",
  category: "Advisory",
  url: "/blog/2026/06/adoption-fatigue" // Points directly to your folder directory location
};

const archivalPosts = [
  {
    title: "Salesforce Pipe Cracking: Preserving State Under Heavy Workload Spikes",
    excerpt: "How real-time data tracing avoids systemic telemetry drop-offs across modern omni-channel contact center handoffs.",
    date: "June 15, 2026",
    readTime: "6 min read",
    category: "Workflows",
    url: "#"
  },
  {
    title: "Deploying Local Prompt Firewalls within Regulated CRM Instances",
    excerpt: "A tactical guide to orchestrating low-latency PII containment matrices without crippling model execution velocity.",
    date: "June 08, 2026",
    readTime: "11 min read",
    category: "AI Tooling",
    url: "#"
  },
  {
    title: "Neutralizing Executive Misalignment Across Multi-Platform Rollouts",
    excerpt: "Constructing objective governance frameworks that bind long-term stakeholder metrics straight to baseline core workflows.",
    date: "May 29, 2026",
    readTime: "7 min read",
    category: "Governance Solutions",
    url: "#"
  }
];
---

<Layout title="Insights & Research Archive | CadenceLab" description="Rigorous strategic analysis regarding human workflow adoption, automation governance, and enterprise customer experience platforms.">
  <NavHeader />

  <main class="archive-canvas-wrapper">
    <div class="archive-layout-container">
      
      <!-- Page Header Node[cite: 1, 2] -->
      <header class="archive-introduction-block">
        <h1 class="archive-main-heading">Insights</h1>
        <p class="archive-lead-paragraph">
          Rigorous perspective on workflow alignment, technical deployment safety, and enterprise customer experience automation loops.
        </p>
      </header>

      <!-- Category Filter Track[cite: 1, 2] -->
      <nav class="taxonomy-filter-track" aria-label="Filter research categories">
        {categories.map((category, index) => (
          <a href="#" class={`taxonomy-link ${index === 0 ? 'is-active' : ''}`}>{category}</a>
        ))}
      </nav>

      <!-- 👑 Asymmetrical Featured Insight Display Canvas[cite: 1, 2] -->
      <section class="featured-insight-stage" aria-label="Featured Insight">
        <div class="featured-insight-card">
          <div class="entry-metadata-rail">
            <span class="metadata-tag">{featuredPost.category}</span>
            <span class="metadata-separator">•</span>
            <time datetime="2026-06-23">{featuredPost.date}</time>
            <span class="metadata-separator">•</span>
            <span>{featuredPost.readTime}</span>
          </div>
          <!-- Explicitly calls var(--font-serif-fine) to assert high-contrast editorial presence -->
          <h2 class="featured-entry-title">
            <a href={featuredPost.url}>{featuredPost.title}</a>
          </h2>
          <p class="featured-entry-excerpt">{featuredPost.excerpt}</p>
          <a href={featuredPost.url} class="featured-action-anchor">Read Research Paper &rarr;</a>
        </div>
      </section>

      <!-- Secondary Archival Stream Matrix[cite: 1, 2] -->
      <section class="archival-grid-matrix" aria-label="Archival Research Stream">
        {archivalPosts.map((post) => (
          <article class="archival-stream-card">
            <div class="entry-metadata-rail">
              <span class="metadata-tag">{post.category}</span>
              <span class="metadata-separator">•</span>
              <time>{post.date}</time>
            </div>
            <h3 class="archival-entry-title">
              <a href={post.url}>{post.title}</a>
            </h3>
            <p class="archival-entry-excerpt">{post.excerpt}</p>
            <span class="archival-read-metric">{post.readTime}</span>
          </article>
        ))}
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* --- BASE ARCHIVE CANVAS GRID STRUCTURE[cite: 1, 2] --- */
  .archive-canvas-wrapper {
    width: 100%;
    background-color: #ffffff; /* Clean pristine canvas layout foundation[cite: 1, 2] */
    padding: 80px 24px;
    display: flex;
    justify-content: center;
  }

  .archive-layout-container {
    width: 100%;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  /* --- ARCHIVE INTRODUCTION HEADER BLOCK[cite: 1, 2] --- */
  .archive-introduction-block {
    max-width: 760px;
    display: flex;
    flex-direction: column;
  }

  .archive-main-heading {
    /* Inherits your global 0.90x h1 configuration seamlessly */
    margin-bottom: 12px;
  }

  .archive-lead-paragraph {
    font-family: var(--font-serif-text);
    font-size: 20px; /* Slightly elevated intro line sizing[cite: 1, 2] */
    font-weight: 300;
    line-height: 1.5;
    color: #425b76; /* Soft corporate blue-grey ink[cite: 1, 2] */
    margin-top: 8px;
  }

  /* --- TAXONOMY CATEGORY SCROLL TRACK --- */
  .taxonomy-filter-track {
    display: flex;
    gap: 28px;
    border-bottom: 1px solid #cbd6e2;
    padding-bottom: 16px;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none; /* Hide scrollbar traces across Firefox */
  }

  .taxonomy-filter-track::-webkit-scrollbar {
    display: none; /* Hide scrollbar traces across Webkit engines */
  }

  .taxonomy-link {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: #576579;
    padding-bottom: 16px;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease-in-out;
    letter-spacing: 0.01em;
  }

  .taxonomy-link:hover {
    color: #1a73e2;
  }

  .taxonomy-link.is-active {
    color: #1a73e2;
    border-bottom-color: #1a73e2;
  }

  /* --- ASYMMETRICAL FEATURED INSIGHT BLOCK[cite: 1, 2] --- */
  .featured-insight-stage {
    width: 100%;
    border-bottom: 1px solid #f5f8fa;
    padding-bottom: 56px;
  }

  .featured-insight-card {
    max-width: 960px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 18px;
  }

  /* Forcing Tiempos Fine optimization values for structural visual dominance */
  .featured-entry-title {
    font-family: var(--font-serif-fine), Georgia, serif !important;
    font-size: calc(24px + 2.2vw) !important; /* Continuous fluid scaling step[cite: 1, 2] */
    line-height: 1.05 !important;
    font-weight: 700;
    letter-spacing: -0.035em !important;
    transform: translateX(-0.06em); /* Core optical edge balance correction[cite: 1, 2] */
  }

  .featured-entry-title a {
    color: #000000;
    transition: color 0.15s ease;
  }

  .featured-entry-title a:hover {
    color: #1a73e2;
  }

  .featured-entry-excerpt {
    font-family: var(--font-serif-text);
    font-size: 18px;
    font-weight: 300;
    line-height: 1.55;
    color: rgba(0, 0, 0, 0.85); /* Premium soft institutional charcoal[cite: 1, 2] */
    max-width: 820px;
  }

  .featured-action-anchor {
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: 600;
    color: #1a73e2;
    margin-top: 6px;
    transition: opacity 0.15s ease;
  }

  .featured-action-anchor:hover {
    text-decoration: underline;
  }

  /* --- METADATA ARCHITECTURE TOKENS --- */
  .entry-metadata-rail {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    color: #576579;
  }

  .metadata-tag {
    color: #1a73e2;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .metadata-separator {
    color: #cbd6e2;
  }

  /* --- SECONDARY ARCHIVAL MATRIX GRID[cite: 1, 2] --- */
  .archival-grid-matrix {
    display: grid;
    grid-template-columns: repeat(3, 1fr); /* 3-Column horizontal matrix distribution[cite: 1, 2] */
    gap: 48px;
  }

  .archival-stream-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .archival-entry-title {
    /* Inherits your global 0.90x h3 specification perfectly[cite: 1, 2] */
    line-height: 1.2 !important;
  }

  .archival-entry-title a {
    color: #000000;
    transition: color 0.15s ease;
  }

  .archival-entry-title a:hover {
    color: #1a73e2;
  }

  .archival-entry-excerpt {
    font-family: var(--font-serif-text);
    font-size: 15px; /* Tighter baseline scale for side-grid card blocks[cite: 1, 2] */
    line-height: 1.5;
    color: #425b76;
    margin: 0;
  }

  .archival-read-metric {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #88a0ba;
    font-weight: 500;
    margin-top: auto; /* Pin metric to lower card bound */
    padding-top: 12px;
  }

  /* --- HIGH-DENSITY RESPONSIVE SCALE MAPPING --- */
  @media (max-width: 1440px) {
    .featured-entry-title {
      font-size: 52px !important; /* Clamps step smoothly prior to breakpoint triggers */
    }
  }

  @media (max-width: 992px) {
    .archival-grid-matrix {
      grid-template-columns: repeat(2, 1fr); /* Drop to dual-column structures on tablets[cite: 1, 2] */
      gap: 36px;
    }
  }

  @media (max-width: 680px) {
    .archive-canvas-wrapper {
      padding: 48px 16px;
    }
    .archive-layout-container {
      gap: 40px;
    }
    .featured-entry-title {
      font-size: 32px !important;
    }
    .archival-grid-matrix {
      grid-template-columns: 1fr; /* Force stack single-stream on mobile form factors[cite: 1, 2] */
    }
  }
</style>
