---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import NavHeader from '../../components/NavHeader.astro';
import Footer from '../../components/Footer.astro';

// Premium Mock Repository Data
const tags = ["All Insights", "Workflows", "Advisory", "AI Tooling", "Governance Solutions"];

const featuredPost = {
  title: "The Hidden Operational Cost of User Adoption Fatigue in Enterprise Architecture",
  excerpt: "An empirical investigation into why cross-functional automation systems collapse when human adoption drop-offs outpace raw computing capability.",
  date: "June 23, 2026",
  readTime: "9 min read",
  tag: "Advisory"
};

const secondaryPosts = [
  {
    title: "Salesforce Pipe Cracking: Preserving State Under Heavy Workload Spikes",
    excerpt: "How real-time data tracing avoids systemic telemetry drop-offs across modern omni-channel contact center handoffs.",
    date: "June 15, 2026",
    readTime: "6 min read",
    tag: "Workflows"
  },
  {
    title: "Deploying Local Prompt Firewalls within Regulated CRM Instances",
    excerpt: "A tactical guide to orchestrating low-latency PII containment matrices without crippling model execution velocity.",
    date: "June 08, 2026",
    readTime: "11 min read",
    tag: "AI Tooling"
  },
  {
    title: "Neutralizing Executive Misalignment Across Multi-Platform Rollouts",
    excerpt: "Constructing objective governance frameworks that bind long-term stakeholder metrics straight to baseline core workflows.",
    date: "May 29, 2026",
    readTime: "7 min read",
    tag: "Governance Solutions"
  }
];
---

<Layout title="Insights Archive | CadenceLab">
  <NavHeader />

  <main class="blog-canvas-wrapper">
    <div class="blog-grid-container">
      
      <header class="blog-header-block">
        <h1 class="display-h1">Insights</h1>
        <p class="blog-lead">Rigorous perspective on workflow alignment, technical deployment safety, and enterprise customer experience automation loops.</p>
      </header>

      <nav class="tag-filter-bar" aria-label="Filter insights by category">
        {tags.map((tag, index) => (
          <a href="#" class={`tag-link ${index === 0 ? 'active' : ''}`}>{tag}</a>
        ))}
      </nav>

      <section class="featured-insight-section">
        <div class="featured-card">
          <div class="card-meta">
            <span class="card-tag">{featuredPost.tag}</span>
            <span class="meta-divider">•</span>
            <time>{featuredPost.date}</time>
            <span class="meta-divider">•</span>
            <span>{featuredPost.readTime}</span>
          </div>
          <h2 class="featured-title"><a href="/blog/adoption-fatigue">{featuredPost.title}</a></h2>
          <p>{featuredPost.excerpt}</p>
          <a href="/blog/adoption-fatigue" class="read-more-link">Read Research Paper &rarr;</a>
        </div>
      </section>

      <section class="insights-grid-matrix">
        {secondaryPosts.map((post) => (
          <article class="insight-article-card">
            <div class="card-meta">
              <span class="card-tag">{post.tag}</span>
              <span class="meta-divider">•</span>
              <time>{post.date}</time>
            </div>
            <h3 class="article-title"><a href="#">{post.title}</a></h3>
            <p>{post.excerpt}</p>
            <span class="article-footer-time">{post.readTime}</span>
          </article>
        ))}
      </section>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* --- BASE CANVAS WRAPPER GRIDS --- */
  .blog-canvas-wrapper {
    width: 100%;
    background-color: #ffffff;
    padding: 80px 24px;
  }

  .blog-grid-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* --- HEADER BLOCK --- */
  .blog-header-block {
    max-width: 750px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Shifting left margin spacing for clean vertical layout tracking alignment */
  .blog-header-block h1 {
    margin-bottom: 8px;
  }

  .blog-lead {
    font-size: 18px !important;
    color: #425b76 !important;
  }

  /* --- TAG NAVIGATION BAR --- */
  .tag-filter-bar {
    display: flex;
    gap: 24px;
    border-bottom: 1px solid #cbd6e2;
    padding-bottom: 16px;
    overflow-x: auto;
    white-space: nowrap;
  }

  .tag-link {
    font-size: 13px;
    font-weight: 600;
    color: #576579;
    padding-bottom: 16px;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease;
  }

  .tag-link:hover {
    color: #1a73e2;
  }

  .tag-link.active {
    color: #1a73e2;
    border-bottom-color: #1a73e2;
  }

  /* --- FEATURED INSIGHT SECTION --- */
  .featured-insight-section {
    width: 100%;
    border-bottom: 1px solid #f5f8fa;
    padding-bottom: 48px;
  }

  .featured-card {
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  /* Using Tiempos Fine for maximum stroke-weight hierarchy on large titles */
  .featured-title {
    font-family: var(--font-serif-fine), Georgia, serif !important;
    font-size: calc(26px + 2vw) !important;
    line-height: 1.1 !important;
    font-weight: 700;
    letter-spacing: -0.03em !important;
  }

  .featured-title a {
    color: #000000;
  }

  .featured-title a:hover {
    color: #1a73e2;
  }

  /* --- CORE ARTICLE METADATA BLOCKS --- */
  .card-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: #576579;
    font-weight: 500;
  }

  .card-tag {
    color: #1a73e2;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .meta-divider {
    color: #cbd6e2;
  }

  .read-more-link {
    font-size: 14px;
    font-weight: 600;
    color: #1a73e2;
    margin-top: 8px;
  }

  .read-more-link:hover {
    text-decoration: underline;
  }

  /* --- SECONDARY MATRIX LAYOUT GRID --- */
  .insights-grid-matrix {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .insight-article-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }

  .article-title {
    font-size: 22px !important; /* Locks beautifully to proportional sub-header metrics */
    line-height: 1.25 !important;
  }

  .article-title a {
    color: #000000;
  }

  .article-title a:hover {
    color: #1a73e2;
  }

  /* Tiempos text copy properties remain perfectly scoped for dense paragraph consumption */
  .insight-article-card p {
    font-size: 15.5px !important;
    line-height: 1.5 !important;
    color: #425b76;
    margin: 0;
  }

  .article-footer-time {
    font-size: 11px;
    color: #88a0ba;
    font-weight: 500;
    margin-top: auto;
  }

  /* --- RESPONSIVE CALIBRATION --- */
  @media (max-width: 950px) {
    .insights-grid-matrix {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 650px) {
    .blog-canvas-wrapper {
      padding: 48px 16px;
    }
    .insights-grid-matrix {
      grid-template-columns: 1fr;
    }
    .featured-title {
      font-size: 28px !important;
    }
  }
</style>
