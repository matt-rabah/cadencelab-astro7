---
import Footer from "../components/Footer.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";

const diagnostics = [
  {
    number: "01",
    name: "CX Systems Diagnostic",
    trigger:
      "Customers repeat themselves, issues cross team boundaries, and leaders receive conflicting explanations for where the experience is breaking.",
    examines:
      "Customer and team touchpoints, handoffs, ownership, CRM signals, service rules, and the systems influencing the experience.",
    output:
      "A friction map, ownership analysis, and a sequenced decision brief for the operating changes that matter first.",
    href: "/services/cx-systems-diagnostic/",
  },
  {
    number: "02",
    name: "Lifecycle Risk Review",
    trigger:
      "Onboarding drifts, accounts go quiet, adoption weakens, or renewal risk becomes visible after the useful intervention window has narrowed.",
    examines:
      "Lifecycle stages, risk signals, handoffs, intervention rules, and the data used to identify preventable loss.",
    output:
      "A lifecycle risk model that defines which signals should trigger action, when, and by whom.",
    href: "/services/lifecycle-risk-review/",
  },
  {
    number: "03",
    name: "CRM Workflow Audit",
    trigger:
      "The CRM contains activity and dashboards, but teams still rely on workarounds and do not trust it to guide coordinated customer action.",
    examines:
      "Data quality, process design, automation, decision rights, reporting, and the gap between configured and actual work.",
    output:
      "A current-state workflow map and prioritized remediation plan for cleaner signals, clearer ownership, and more usable work.",
    href: "/services/crm-workflow-audit/",
  },
  {
    number: "04",
    name: "AI Service Readiness Review",
    trigger:
      "An AI use case has momentum, but the supporting workflow, human oversight, adoption conditions, or success measures remain unresolved.",
    examines:
      "Use-case fit, process readiness, human oversight, data dependencies, trust, adoption risk, and measurement design.",
    output:
      "A readiness decision, human-in-the-loop model, required guardrails, and a responsible path to implementation.",
    href: "/services/ai-service-readiness-review/",
  },
];

const consequences = [
  {
    title: "Context decays at every handoff",
    description:
      "The customer repeats the story while ownership, history, and urgency weaken as work moves between teams.",
  },
  {
    title: "Risk appears after the intervention window",
    description:
      "Teams can see the churn, escalation, or failed adoption event, but not the earlier signals that could have changed the outcome.",
  },
  {
    title: "AI accelerates an unresolved process",
    description:
      "Automation increases volume without resolving weak data, unclear decision rights, or the points where human judgment is required.",
  },
];

const operatingStages = [
  {
    number: "01",
    title: "Diagnose the operating environment",
    description:
      "Trace the customer problem through teams, systems, data, decisions, and frontline work before prescribing a solution.",
  },
  {
    number: "02",
    title: "Align the decisions",
    description:
      "Define the outcome, accountable owners, decision rights, constraints, and sequence of changes before implementation begins.",
  },
  {
    number: "03",
    title: "Rebuild the workflow",
    description:
      "Translate the decision into usable handoffs, CRM requirements, governance, team practices, and appropriate AI support.",
  },
  {
    number: "04",
    title: "Measure and adapt",
    description:
      "Connect customer, workflow, adoption, and performance signals to the change, then refine the system as evidence develops.",
  },
];

const strongFit = [
  "Customer friction materially affects retention, revenue, service quality, or team capacity.",
  "The problem spans functions, systems, or decision layers and cannot be solved by one team in isolation.",
  "Leadership can sponsor cross-functional decisions and assign accountable owners.",
  "The organization is willing to change workflows instead of placing new technology on top of a broken process.",
];

const limitedFit = [
  "The goal is to install a tool without changing ownership, decisions, or frontline work.",
  "The initiative is isolated within one technical team while business and customer operations remain outside the process.",
  "No sponsor can resolve competing priorities or make cross-functional workflow decisions.",
  "Success measures stop at delivery activity and leave out adoption, operating performance, and customer impact.",
];
---

<Layout
  title="Cadence Lab | Customer experience operating systems for the AI era"
  description="Cadence Lab diagnoses onboarding drift, lifecycle risk, unreliable CRM workflows, and AI service readiness, then turns evidence into practical operating change."
  canonicalURL="/"
  pageType="website"
>
  <NavHeader />

  <main id="main-content" class="home-page" tabindex="-1">
    <section class="hero" aria-labelledby="hero-title">
      <div class="page-container hero-layout">
        <div class="hero-copy">
          <p class="eyebrow">Customer experience systems</p>

          <h1 id="hero-title">
            Customer experience operating systems for the AI era.
          </h1>

          <p class="hero-lead">
            Cadence Lab helps organizations resolve onboarding drift, quiet
            accounts, unreliable CRM signals, and service handoffs, then build
            the operating conditions required for responsible AI adoption.
          </p>

          <div class="hero-actions" aria-label="Homepage actions">
            <a class="button button-primary" href="/fit-check/">
              Start a fit check
            </a>

            <a class="button button-text" href="#diagnostics">
              Review the diagnostic offers
            </a>
          </div>
        </div>

        <div class="hero-visual-rail">
          <figure
            class="image-slot image-slot-hero"
            data-image-slot="homepage-hero"
            aria-hidden="true"
          >
            <div class="image-slot-frame">
              <p class="image-slot-label">Future image</p>
              <p class="image-slot-direction">
                A physical operating system viewed through its handoffs,
                routing, and points of decision.
              </p>
            </div>
            <figcaption>Vertical crop · 4:5</figcaption>
          </figure>

          <dl class="hero-scope" aria-label="Cadence Lab operating scope">
            <div>
              <dt>Diagnose</dt>
              <dd>Friction, lifecycle risk, and signal gaps</dd>
            </div>
            <div>
              <dt>Rebuild</dt>
              <dd>Ownership, handoffs, and CRM workflows</dd>
            </div>
            <div>
              <dt>Prepare</dt>
              <dd>Human oversight, adoption, and measurement</dd>
            </div>
          </dl>
        </div>
      </div>
    </section>

    <section
      id="diagnostics"
      class="diagnostics section-block"
      aria-labelledby="diagnostics-title"
    >
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Diagnostic offers</p>
            <h2 id="diagnostics-title">
              Choose the operating problem before choosing the technology.
            </h2>
          </div>

          <p>
            Each diagnostic starts with one consequential operating question,
            builds a shared evidence base, and ends with a practical decision
            about what should happen next.
          </p>
        </div>

        <figure
          class="image-slot image-slot-wide"
          data-image-slot="diagnostic-evidence"
          aria-hidden="true"
        >
          <div class="image-slot-frame">
            <p class="image-slot-label">Future image</p>
            <p class="image-slot-direction">
              Evidence under review: plans, annotations, process records, or an
              operational map that makes the system visible.
            </p>
          </div>
          <figcaption>Wide crop · 3:1</figcaption>
        </figure>

        <ol class="diagnostic-grid" role="list">
          {
            diagnostics.map((diagnostic) => (
              <li>
                <article class="diagnostic-card">
                  <div class="diagnostic-heading">
                    <p class="diagnostic-number" aria-hidden="true">
                      {diagnostic.number}
                    </p>

                    <h3>{diagnostic.name}</h3>
                  </div>

                  <dl class="diagnostic-details">
                    <div>
                      <dt>Recognizable trigger</dt>
                      <dd>{diagnostic.trigger}</dd>
                    </div>
                    <div>
                      <dt>What we examine</dt>
                      <dd>{diagnostic.examines}</dd>
                    </div>
                    <div>
                      <dt>Decision or output</dt>
                      <dd>{diagnostic.output}</dd>
                    </div>
                  </dl>

                  <a class="diagnostic-link" href={diagnostic.href}>
                    Review {diagnostic.name}
                    <span aria-hidden="true">→</span>
                  </a>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="consequences" aria-labelledby="consequences-title">
      <div class="page-container section-stack">
        <div class="consequences-intro">
          <p class="eyebrow eyebrow-inverse">What the work prevents</p>
          <h2 id="consequences-title">
            Visible customer problems usually begin as operating failures.
          </h2>
          <p>
            Churn, escalations, CRM distrust, and stalled AI adoption are late
            signals. The earlier failure is usually unclear ownership, missing
            context, or a workflow that cannot support the required decision.
          </p>
        </div>

        <ul class="consequence-grid" role="list">
          {
            consequences.map((consequence) => (
              <li>
                <article>
                  <h3>{consequence.title}</h3>
                  <p>{consequence.description}</p>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section
      id="operating-model"
      class="operating-model section-block"
      aria-labelledby="operating-model-title"
    >
      <div class="page-container operating-layout">
        <div class="operating-intro">
          <p class="eyebrow">Operating model</p>
          <h2 id="operating-model-title">
            Let the evidence determine the recommendation.
          </h2>
          <p>
            Cadence Lab connects strategy to the way work is owned, performed,
            governed, and measured. Technology should support that operating
            model and make the work easier to manage.
          </p>

          <figure
            class="image-slot image-slot-operating"
            data-image-slot="operating-model"
            aria-hidden="true"
          >
            <div class="image-slot-frame">
              <p class="image-slot-label">Future image</p>
              <p class="image-slot-direction">
                Decision architecture: a circulation plan, control schematic,
                or system diagram with visible sequence and constraints.
              </p>
            </div>
            <figcaption>Landscape crop · 4:3</figcaption>
          </figure>
        </div>

        <ol class="stage-list" role="list">
          {
            operatingStages.map((stage) => (
              <li>
                <article class="stage">
                  <p class="stage-number" aria-hidden="true">
                    {stage.number}
                  </p>
                  <div>
                    <h3>{stage.title}</h3>
                    <p>{stage.description}</p>
                  </div>
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="fit section-block" aria-labelledby="fit-title">
      <div class="page-container section-stack">
        <div class="section-intro section-intro-split">
          <div>
            <p class="eyebrow">Engagement fit</p>
            <h2 id="fit-title">
              Useful change requires permission to change the work.
            </h2>
          </div>

          <p>
            A productive engagement needs a consequential operating problem, an
            accountable sponsor, and room to change ownership, decisions, or
            workflows. The fit check establishes that before either side commits
            to more.
          </p>
        </div>

        <div class="fit-grid">
          <article class="fit-panel fit-panel-strong">
            <p class="fit-label">Strong fit</p>
            <h3>Conditions that support useful change</h3>
            <ul role="list">
              {strongFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>

          <article class="fit-panel">
            <p class="fit-label fit-label-muted">Limited fit</p>
            <h3>Conditions that limit the work</h3>
            <ul role="list">
              {limitedFit.map((criterion) => <li>{criterion}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="fit-check" aria-labelledby="fit-check-title">
      <div class="page-container fit-check-layout">
        <div>
          <p class="eyebrow">Fit check</p>
          <h2 id="fit-check-title">
            Decide whether the problem is ready for a diagnostic.
          </h2>
        </div>

        <div class="fit-check-copy">
          <p>
            Share the operating problem, the teams and systems involved, and the
            outcome that needs to change. Cadence Lab will assess fit, recommend
            the most useful starting point, and tell you directly when a
            diagnostic is not the right next step.
          </p>

          <a class="button button-accent" href="/fit-check/">
            Start a fit check
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .home-page {
    display: flex;
    width: 100%;
    flex-direction: column;
    background: var(--color-surface);
    color: var(--color-text);
  }

  .page-container {
    width: min(calc(100% - (2 * var(--page-gutter))), var(--container-page));
    margin-inline: auto;
  }

  .section-block {
    padding-block: var(--section-space);
    border-top: var(--border-width) solid var(--color-border);
  }

  .section-stack {
    display: flex;
    flex-direction: column;
    gap: clamp(2.75rem, 6vw, 5rem);
  }

  .eyebrow {
    margin: 0 0 1rem;
    color: var(--color-blue);
  }

  .eyebrow-inverse {
    color: var(--color-green);
  }

  h1,
  h2,
  h3,
  p,
  dl,
  dd {
    margin-block: 0;
  }

  h1,
  h2,
  h3 {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  h1 {
    max-width: 15ch;
    font-size: var(--fs-display);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
  }

  h2 {
    max-width: 19ch;
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
  }

  h3 {
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
  }

  .hero {
    padding-block: clamp(5rem, 11vw, 9rem);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.75fr);
    gap: clamp(3rem, 9vw, 8rem);
    align-items: start;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: clamp(1rem, 5vw, 4rem);
  }

  .hero-lead {
    max-width: var(--measure-ui);
    margin-top: 1.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    align-items: center;
    margin-top: 2rem;
  }

  .hero-visual-rail {
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 1.5rem;
  }

  .image-slot {
    min-width: 0;
    margin: 0;
  }

  .image-slot-frame {
    display: flex;
    min-height: 15rem;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.75rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: var(--border-width) solid var(--color-border-strong);
    background: var(--color-surface-subtle);
  }

  .image-slot-label,
  .image-slot-direction,
  .image-slot figcaption {
    font-family: var(--font-sans);
  }

  .image-slot-label {
    color: var(--color-blue);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
  }

  .image-slot-direction {
    max-width: 34rem;
    color: var(--color-ink);
    font-size: var(--fs-small);
    line-height: 1.5;
    text-wrap: pretty;
  }

  .image-slot figcaption {
    margin-top: 0.625rem;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    line-height: var(--lh-small);
  }

  .image-slot-hero .image-slot-frame {
    min-height: 25rem;
    aspect-ratio: 4 / 5;
    background: var(--color-surface-pure);
  }

  .image-slot-wide .image-slot-frame {
    min-height: 14rem;
    aspect-ratio: 3 / 1;
    background: var(--color-surface-pure);
  }

  .image-slot-operating {
    margin-top: 2rem;
  }

  .image-slot-operating .image-slot-frame {
    min-height: 14rem;
    aspect-ratio: 4 / 3;
  }

  .hero-scope {
    border-top: var(--border-width) solid var(--color-border-strong);
  }

  .hero-scope div {
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    gap: 1rem;
    padding-block: 1rem;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .hero-scope dt {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
  }

  .hero-scope dd {
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: var(--lh-small);
  }

  .diagnostics {
    scroll-margin-top: var(--header-offset);
    background: var(--color-surface-subtle);
  }

  .section-intro-split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(18rem, 0.75fr);
    gap: clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .section-intro-split > p,
  .operating-intro > p:last-child,
  .fit-check-copy > p {
    max-width: var(--measure-ui);
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .diagnostic-grid,
  .consequence-grid,
  .stage-list,
  .fit-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .diagnostic-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: var(--border-width) solid var(--color-border-strong);
    border-left: var(--border-width) solid var(--color-border-strong);
  }

  .diagnostic-grid > li {
    min-width: 0;
    border-right: var(--border-width) solid var(--color-border-strong);
    border-bottom: var(--border-width) solid var(--color-border-strong);
  }

  .diagnostic-card {
    display: flex;
    height: 100%;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    background: var(--color-surface-pure);
  }

  .diagnostic-heading {
    display: grid;
    width: 100%;
    grid-template-columns: 2.5rem minmax(0, 1fr);
    gap: clamp(0.75rem, 2vw, 1.25rem);
    align-items: start;
    padding-bottom: 1.5rem;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .diagnostic-number,
  .stage-number {
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
    font-feature-settings: var(--fea-tabular);
  }

  .diagnostic-details {
    display: grid;
    gap: 0;
    width: 100%;
    margin-top: 0.5rem;
  }

  .diagnostic-details div {
    display: grid;
    grid-template-columns: minmax(7.5rem, 0.42fr) minmax(0, 1fr);
    gap: 1rem;
    padding-block: 1.25rem;
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .diagnostic-details div:last-child {
    margin-inline: -0.75rem;
    padding-inline: 0.75rem;
    border-bottom: 0;
    background: var(--color-surface-subtle);
  }

  .diagnostic-details dt {
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-weight: var(--fw-medium);
    line-height: var(--lh-small);
  }

  .diagnostic-details dd {
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .diagnostic-link {
    display: inline-flex;
    min-height: var(--control-min-size);
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 1.75rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    font-weight: var(--fw-medium);
    line-height: 1.3;
    text-decoration: underline;
    text-decoration-color: var(--color-blue);
    text-decoration-thickness: 0.1em;
    text-underline-offset: 0.25em;
    transition:
      color var(--transition-fast),
      text-decoration-color var(--transition-fast);
  }

  .diagnostic-link:hover {
    color: var(--color-blue);
  }

  .consequences {
    padding-block: var(--section-space);
    background: var(--color-ink);
    color: var(--color-text-inverse);
  }

  .consequences-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.7fr);
    gap: 1rem clamp(2rem, 8vw, 7rem);
    align-items: end;
  }

  .consequences-intro .eyebrow {
    grid-column: 1 / -1;
  }

  .consequences h2,
  .consequences h3 {
    color: var(--color-text-inverse);
  }

  .consequences h2 {
    max-width: 16ch;
  }

  .consequences-intro > p:last-child {
    max-width: var(--measure-ui);
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    line-height: var(--lh-ui);
    text-wrap: pretty;
  }

  .consequence-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: var(--border-width) solid rgb(252 254 255 / 28%);
    border-bottom: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .consequence-grid li {
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .consequence-grid li + li {
    border-left: var(--border-width) solid rgb(252 254 255 / 28%);
  }

  .consequence-grid h3 {
    max-width: 21ch;
  }

  .consequence-grid p {
    margin-top: 1rem;
    color: var(--color-text-inverse-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-small);
    line-height: 1.6;
    text-wrap: pretty;
  }

  .operating-layout {
    display: grid;
    grid-template-columns: minmax(16rem, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(3rem, 10vw, 9rem);
    align-items: start;
  }

  .operating-intro {
    position: sticky;
    top: calc(var(--header-offset) + 2rem);
  }

  .operating-intro > p:last-child {
    margin-top: 1.25rem;
  }

  .stage-list {
    border-top: var(--border-width) solid var(--color-border-strong);
  }

  .stage-list > li {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .stage {
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
