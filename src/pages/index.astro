---
// src/pages/index.astro

import Approach from "../components/Approach.astro";
import ContactCTA from "../components/ContactCTA.astro";
import FitCriteria from "../components/FitCriteria.astro";
import Footer from "../components/Footer.astro";
import Framework from "../components/Framework.astro";
import Hero from "../components/Hero.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Cadence Lab | Customer experience systems and AI adoption"
  description="Cadence Lab helps organizations connect customer experience strategy, CRM data, workflow design, and responsible AI adoption to measurable operating outcomes."
  canonicalURL="/"
  pageType="website"
>
  <NavHeader />

  <main id="main-content" class="home-page">
    <Hero />

    <Approach />

    <div id="framework" class="framework-anchor">
      <Framework />
    </div>

    <FitCriteria />

    <ContactCTA />
  </main>

  <Footer />
</Layout>

<style>
  .home-page {
    display: flex;
    width: 100%;
    flex-direction: column;
  }

  .framework-anchor {
    width: 100%;
    scroll-margin-top: var(--header-offset);
  }
</style>
