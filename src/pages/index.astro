---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import NavHeader from '../components/NavHeader.astro';
import Hero from '../components/Hero.astro';
import Approach from '../components/Approach.astro';
import FitCriteria from '../components/FitCriteria.astro';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="CadenceLab | Enterprise CX Architecture">
  <NavHeader />
  
  <!-- Removed the max-width restriction so component backgrounds stretch full-width -->
  <main class="page-canvas">
    <Hero />
    <Approach />
    <FitCriteria />
    <ContactCTA />
  </main>

  <!-- The true-black footer stretches edge-to-edge natively -->
  <Footer />
</Layout>

<style is:global>
  /* --- GLOBAL OVERRIDES --- */
  /* This completely purges the default Astro template's dark theme backgrounds */
  html, 
  body {
    margin: 0;
    padding: 0;
    background-color: #ffffff !important; /* Forces a pristine enterprise canvas */
    color: #1e242c;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    overflow-x: hidden; /* Prevents unwanted horizontal structural shaking */
  }

  .page-canvas {
    width: 100%;
    display: flex;
    flex-direction: column;
  }
</style>
