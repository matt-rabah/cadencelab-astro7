      {
        phase: "Trace",
        question: "How is the experience produced today?",
        evidence:
          "Customer goals, moments, research, service signals, workflows, policies, systems, handoffs, ownership, measures, and frontline behavior.",
      },
      {
        phase: "Define",
        question: "Which shared decisions should guide the experience?",
        evidence:
          "Experience intent, principles, priority moments, service rules, ownership, measures, constraints, and unresolved questions.",
      },
      {
        phase: "Apply",
        question: "Does the foundation improve a real decision?",
        evidence:
          "Priority use cases, journey changes, policy choices, concepts, workflow requirements, channel implications, and stakeholder review.",
      },
      {
        phase: "Embed",
        question: "How will teams maintain and use it?",
        evidence:
          "Stewards, governance, templates, decision forums, operating cadence, measures, evidence updates, onboarding, and change triggers.",
      },
    ],
  },
  evidence: {
    eyebrow: "Evidence",
    title:
      "Build the foundation from observed experience and operating reality.",
    introduction:
      "A credible foundation distinguishes what customers experience, what teams believe, what systems record, and what the organization still needs to learn. It should show the strength and limits of the available evidence.",
    items: [
      {
        title: "Customer goals and context",
        description:
          "Needs, expectations, circumstances, accessibility, language, trust, prior history, desired progress, and the consequences of delay, failure, or repeated effort.",
      },
      {
        title: "Journey and interaction evidence",
        description:
          "Research, observation, analytics, contact reasons, feedback, complaints, behavioral patterns, drop-off, exceptions, recovery, and cross-channel transitions.",
      },
      {
        title: "Workflow and service reality",
        description:
          "Queues, handoffs, approvals, service rules, workarounds, capacity, frontline judgment, escalation, and the difference between intended and actual work.",
      },
      {
        title: "Ownership and decision rights",
        description:
          "Accountabilities, authority, competing incentives, funding, dependencies, governance, and the points where customer outcomes cross organizational boundaries.",
      },
      {
        title: "Systems and information",
        description:
          "CRM records, product data, knowledge, content, identity, integration, automation, reporting, permissions, signal quality, and context available at each moment.",
      },
      {
        title: "Measures and outcomes",
        description:
          "Customer effort, service quality, adoption, completion, retention, trust, accessibility, operating performance, cost, risk, and evidence that change caused improvement.",
      },
    ],
    note: {
      label: "Shared model, not false certainty",
      description:
        "A foundation should make evidence, assumptions, gaps, and competing needs visible. Its purpose is to improve coordinated decisions—not to imply that one journey map or set of principles can permanently represent every customer and context.",
    },
  },
  failures: {
    eyebrow: "Common failure patterns",
    title: "A foundation fails when it cannot change a decision.",
    introduction:
      "Experience artifacts often create temporary alignment but lose authority when delivery begins. The risk is highest when the work describes customers without connecting their needs to ownership, constraints, and operating choices.",
    items: [
      {
        title: "The journey map becomes the final deliverable",
        description:
          "The organization visualizes stages and pain points but does not assign decisions, owners, dependencies, measures, or a practical sequence for changing the experience.",
      },
      {
        title: "One persona stands in for customer diversity",
        description:
          "A simplified profile hides differences in context, ability, language, history, risk, intent, and support needs that materially change the experience.",
      },
      {
        title: "Principles avoid the difficult tradeoff",
        description:
          "Statements such as simple, seamless, or customer-first sound agreeable but do not guide a decision when policy, cost, capacity, risk, and customer need conflict.",
      },
      {
        title: "Ownership stops at the channel boundary",
        description:
          "A web, app, service, or location team is accountable for the visible interaction but cannot change the workflow, policy, data, or upstream decision causing the problem.",
      },
      {
        title: "The foundation reflects leadership assumptions",
        description:
          "Executive intent and internal workshops substitute for customer evidence, frontline reality, system behavior, and the experience of people most affected by failure.",
      },
      {
        title: "Governance preserves the artifact instead of learning",
        description:
          "Teams protect approved language and diagrams while customer behavior, business conditions, technology, policy, and evidence continue to change.",
      },
    ],
  },
  outputs: {
    eyebrow: "Practical outputs",
    title: "Create a foundation teams can use in delivery and operations.",
    introduction:
      "The outputs should give different teams a shared account of the experience while making ownership, decisions, evidence, and next actions specific enough to guide real work.",
    items: [
      {
        title: "Experience foundation model",
        description:
          "A shared view of customer goals, priority moments, experience intent, operating dependencies, constraints, and the evidence supporting the model.",
      },
      {
        title: "Principles and decision guidance",
        description:
          "A bounded set of principles with practical implications, tradeoffs, examples, exclusions, and questions teams can use during policy, design, and delivery.",
      },
      {
        title: "Ownership and operating map",
        description:
          "Roles, decision rights, workflows, systems, handoffs, governance, and the changes required for accountable teams to deliver the intended experience.",
      },
      {
        title: "Measurement and activation plan",
        description:
          "Priority use cases, sequence, owners, customer and operating measures, evidence gaps, review cadence, and triggers for refining the foundation.",
      },
    ],
  },
  fit: {
    eyebrow: "Engagement fit",
    title:
      "Use Experience Foundations when several initiatives need one operating base.",
    introduction:
      "This work is useful when experience decisions span teams, channels, systems, or delivery programs and leadership can sponsor shared choices. It is a limited fit when the need is one isolated interface improvement or when the organization wants a vision without changing ownership, policy, workflow, or measurement.",
    items: [
      "Several teams or channels influence the same customer outcome.",
      "Research and experience artifacts exist but do not consistently guide priorities or delivery.",
      "A transformation, platform, service, digital, location, or AI initiative needs a shared experience direction.",
      "An accountable sponsor can resolve cross-functional decisions and assign owners.",
      "The organization is willing to change operating conditions when customer evidence requires it.",
    ],
  },
  diagnostics: {
    eyebrow: "Related paths",
    title: "Choose the next path based on where the foundation is weakest.",
    items: [
      {
        title: "CX Systems Diagnostic",
        href: "/services/cx-systems-diagnostic/",
        useWhen:
          "Recurring customer friction crosses teams, systems, service rules, ownership boundaries, or handoffs and the operating cause is not yet trusted.",
      },
      {
        title: "Digital Experiences",
        href: "/product/digital-experiences/",
        useWhen:
          "The foundation needs to become a coherent website, portal, service interface, or cross-channel digital experience.",
      },
      {
        title: "AI Experience",
        href: "/product/ai-experience/",
        useWhen:
          "The intended experience includes AI assistance, automation, recommendations, or agent behavior that requires explicit human and operating boundaries.",
      },
    ],
  },
};
---

<StructuredCapabilityPage {...page} />
