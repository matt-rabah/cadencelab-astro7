---
import StructuredCapabilityPage from "../../../components/StructuredCapabilityPage.astro";

const page = {
  meta: {
    title: "Experience Foundations | Cadence Lab",
    description:
      "Establish the customer understanding, ownership, workflow, service principles, evidence, and measurement that digital, physical, and AI-enabled experiences depend on.",
    canonicalURL: "/product/experience-foundations/",
  },
  hero: {
    breadcrumb: "Experience Foundations",
    eyebrow: "Product · Experience Foundations",
    title: "Build the conditions every experience depends on.",
    lead: "Experience Foundations turns a broad experience ambition into a shared operating base: who the organization serves, which moments matter, how work and decisions move, what good service requires, and how teams will know whether the experience improved. It creates enough coherence for digital, physical, and AI-enabled work to reinforce rather than contradict one another.",
    primaryCta: {
      label: "Start a fit check",
      href: "/fit-check/",
    },
    secondaryCta: {
      label: "Review diagnostic offers",
      href: "/services/",
    },
    trigger: {
      introduction:
        "The organization is investing in channels, platforms, automation, or transformation, but teams do not share a reliable definition of the customer problem, the intended experience, or the operating changes required to deliver it.",
      items: [
        {
          label: "Visible symptom",
          value: "Experience work fragments across initiatives",
        },
        {
          label: "Foundation",
          value: "Purpose, journey, decisions, ownership, evidence",
        },
        {
          label: "Decision",
          value: "What must be true before delivery expands",
        },
      ],
    },
  },
  signals: {
    eyebrow: "Visible signals",
    title: "Experience inconsistency usually begins before the interface.",
    introduction:
      "Customers encounter the consequences of decisions made across strategy, policy, operations, data, technology, and frontline work. A foundation is needed when those decisions are locally reasonable but collectively incoherent.",
    items: [
      {
        title: "Every team describes the customer differently",
        description:
          "Segments, needs, journeys, priorities, and success measures change across departments, leaving each initiative to invent its own version of the experience.",
      },
      {
        title: "Channels solve the same problem in different ways",
        description:
          "Web, service, sales, product, location, and lifecycle teams create conflicting expectations, language, policies, and routes to resolution.",
      },
      {
        title: "Research accumulates without changing decisions",
        description:
          "Interviews, surveys, analytics, and journey maps are available, but their findings are not connected to ownership, funding, workflow, or delivery priorities.",
      },
      {
        title: "Teams debate solutions before bounding the problem",
        description:
          "Projects begin with a platform, feature, campaign, or automation request rather than a shared account of the customer and operating outcome.",
      },
      {
        title: "Experience principles remain aspirational",
        description:
          "Values and service promises are visible in presentations but do not guide policy, handoffs, exceptions, interface behavior, or tradeoffs.",
      },
      {
        title: "Success ends at launch",
        description:
          "Delivery activity is measured while customer effort, service quality, adoption, operating performance, and cross-channel consequences remain disconnected.",
      },
    ],
  },
  framework: {
    eyebrow: "Foundation system",
    title: "Connect experience intent to the way the organization works.",
    introduction:
      "A useful foundation is not a static map or vision statement. It is a set of shared decisions that teams can use when prioritizing, designing, operating, and measuring experiences.",
    items: [
      {
        label: "Purpose",
        question: "Which customer and operating outcome matters?",
        title: "Purpose",
        description:
          "Define the people, situation, problem, consequence, strategic reason, and evidence that make the experience worth changing.",
      },
      {
        label: "Journey",
        question: "Which moments shape the outcome?",
        title: "Journey",
        description:
          "Identify the goals, expectations, decisions, interactions, transitions, dependencies, and breakdowns that matter across the complete experience.",
      },
      {
        label: "Decisions",
        question: "What must the organization decide consistently?",
        title: "Decisions",
        description:
          "Clarify service rules, priorities, tradeoffs, exceptions, promises, and principles that should guide teams when the ordinary path does not fit.",
      },
      {
        label: "Ownership",
        question: "Who can change the work behind each moment?",
        title: "Ownership",
        description:
          "Connect journey responsibility to roles, decision rights, workflows, systems, handoffs, and the authority required to resolve a cross-functional problem.",
      },
      {
        label: "Evidence",
        question: "What will make the experience observable?",
        title: "Evidence",
        description:
          "Combine customer, behavioral, service, workflow, financial, adoption, and qualitative signals without reducing the experience to one score.",
      },
      {
        label: "Governance",
        question: "How will the foundation remain useful?",
        title: "Governance",
        description:
          "Define stewards, review rhythms, decision forums, change triggers, documentation, and how teams resolve new evidence or competing needs.",
      },
    ],
  },
  path: {
    eyebrow: "Foundation path",
    title: "Move from competing interpretations to shared action.",
