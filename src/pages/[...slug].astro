---
// src/pages/[...slug].astro

import { getCollection } from "astro:content";
import TinaMarkdown from "@tinacms/astro";
import { tinaField } from "@tinacms/astro/tina-field";

import { client } from "../../tina/__generated__/client.js";
import Footer from "../components/Footer.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";

export async function getStaticPaths() {
  const pages = await getCollection("page");

  return pages.map((entry) => {
    const slug = entry.id
      .replace(/\.(md|mdx)$/i, "")
      .split("/")
      .filter(Boolean)
      .join("/");

    if (!slug) {
      throw new Error(`Unable to determine a slug for page entry: ${entry.id}`);
    }

    return {
      params: {
        slug,
      },
      props: {
        slug,
      },
    };
  });
}

interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;

const response = await client.queries.page({
  relativePath: `${slug}.md`,
});

const page = response.data.page;

if (!page) {
  throw new Error(
    `Unable to load Tina page content for "src/content/pages/${slug}.md".`,
  );
}

const title = page.title?.trim();

if (!title) {
  throw new Error(`Page "src/content/pages/${slug}.md" is missing a title.`);
}

const description =
  page.subtitle?.trim() ||
  "Customer experience systems, workflow design, CRM strategy, and responsible AI adoption from Cadence Lab.";

const canonicalURL = `/${slug}/`;
---

<Layout
  title={`${title} | Cadence Lab`}
  description={description}
  canonicalURL={canonicalURL}
>
  <NavHeader />

  <main id="main-content" class="content-page">
    <article class="content-container">
      <header class="content-header">
        {
          page.category && (
            <p
              class="content-eyebrow"
              data-tina-field={tinaField(page, "category")}
            >
              {page.category}
            </p>
          )
        }

        <h1 class="content-title" data-tina-field={tinaField(page, "title")}>
          {page.title}
        </h1>

        {
          page.subtitle && (
            <p
              class="content-subtitle"
              data-tina-field={tinaField(page, "subtitle")}
            >
              {page.subtitle}
            </p>
          )
        }
      </header>

      {
        page.body && (
          <div class="content-body" data-tina-field={tinaField(page, "body")}>
            <TinaMarkdown content={page.body} />
          </div>
        )
      }
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .content-page {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .content-container {
    display: grid;
    width: min(calc(100% - (2 * var(--page-gutter))), 48rem);
    margin-inline: auto;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .content-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .content-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: var(--fs-eyebrow);
    font-style: normal;
    font-weight: var(--fw-medium);
    line-height: 1.4;
    letter-spacing: var(--ls-eyebrow);
    font-feature-settings: var(--fea-eyebrow);
    text-transform: uppercase;
  }

  .content-title {
    max-width: 17ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-display);
    font-style: normal;
    font-weight: var(--fw-semibold);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .content-subtitle {
    max-width: var(--measure-ui);
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-style: normal;
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
    text-wrap: pretty;
  }

  .content-body {
    padding-top: clamp(2rem, 5vw, 3.5rem);
    border-top: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .content-body :global(h2) {
    margin-top: 2.5em;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h2);
    font-weight: var(--fw-semibold);
    line-height: var(--lh-h2);
    letter-spacing: var(--ls-h2);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .content-body :global(h3) {
    margin-top: 2em;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h3);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h3);
    letter-spacing: var(--ls-h3);
    font-feature-settings: var(--fea-graphik);
    text-wrap: balance;
  }

  .content-body :global(h4) {
    margin-top: 1.75em;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: var(--fs-h4);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h4);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .content-body :global(p),
  .content-body :global(li) {
    max-width: var(--measure-ui);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: var(--fs-body-ui);
    font-weight: var(--fw-regular);
    line-height: var(--lh-ui);
    letter-spacing: 0;
    font-feature-settings: var(--fea-graphik);
  }

  .content-body :global(p) {
    text-wrap: pretty;
  }

  .content-body :global(ul),
  .content-body :global(ol) {
    margin-block: 1.5rem;
    padding-left: 1.5rem;
  }

  .content-body :global(li + li) {
    margin-top: 0.625rem;
  }

  .content-body :global(strong) {
    color: var(--color-ink);
    font-weight: var(--fw-medium);
  }

  .content-body :global(blockquote) {
    margin: 2.5rem 0;
    padding-left: clamp(1.25rem, 3vw, 2rem);
    border-left: 0.25rem solid var(--color-blue);
    color: var(--color-ink);
  }

  .content-body :global(blockquote p) {
    margin: 0;
    font-size: var(--fs-h4);
    font-weight: var(--fw-medium);
    line-height: var(--lh-h4);
  }

  .content-body :global(a) {
    color: var(--color-blue);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .content-body :global(img) {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    margin-block: 2.5rem;
    border-radius: var(--radius-sm);
  }

  .content-body :global(pre) {
    max-width: 100%;
    overflow-x: auto;
  }

  .content-body :global(a:focus-visible) {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 40rem) {
    .content-page {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .content-title {
      max-width: 15ch;
    }
  }

  @media (forced-colors: active) {
    .content-body,
    .content-body :global(blockquote) {
      border-color: CanvasText;
    }
  }
</style>
