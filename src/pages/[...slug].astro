---
// src/pages/[...slug].astro

import TinaMarkdown from "@tinacms/astro";
import { tinaField } from "@tinacms/astro/tina-field";

import { client } from "../../tina/__generated__/client.js";
import Footer from "../components/Footer.astro";
import NavHeader from "../components/NavHeader.astro";
import Layout from "../layouts/Layout.astro";

export function getStaticPaths() {
  const paths = [
    "workflows",
    "workflows/salesforce",
    "workflows/cross-functional",
    "workflows/escalation",
    "workflows/agent-routing",
    "workflows/legacy",
    "workflows/omnichannel",
    "workflows/telephony",
    "solutions",
    "solutions/adoption-fatigue",
    "solutions/dirty-data",
    "solutions/misalignment",
    "solutions/enterprise",
    "solutions/mid-market",
    "solutions/governance",
    "ai-tooling",
    "ai-tooling/prompt-guard",
    "ai-tooling/hallucination",
    "ai-tooling/compliance",
    "ai-tooling/co-pilot",
    "ai-tooling/feedback",
    "governance",
    "advisory",
    "support",
    "contact",
    "privacy",
    "terms",
  ];

  return paths.map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

interface Props {
  slug: string;
}

const { slug } = Astro.props as Props;

let page: {
  title?: string | null;
  subtitle?: string | null;
  category?: string | null;
  body?: unknown;
} | null = null;

try {
  const response = await client.queries.page({
    relativePath: `${slug}.md`,
  });

  page = response.data.page;
} catch {
  page = null;
}

const segment = slug.split("/").filter(Boolean).at(-1) ?? "page";

const fallbackTitle = segment
  .split("-")
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join(" ");

const title = page?.title?.trim() || fallbackTitle;

const description =
  page?.subtitle?.trim() ||
  "This Cadence Lab page is being prepared and is not yet available.";

const canonicalURL = `/${slug}/`;
---

<Layout
  title={`${title} | Cadence Lab`}
  description={description}
  canonicalURL={canonicalURL}
  noindex={!page}
>
  <NavHeader />

  {
    page ? (
      <main id="main-content" class="content-page">
        <article class="content-container">
          <header class="content-header">
            {page.category && (
              <p
                class="content-eyebrow"
                data-tina-field={tinaField(page, "category")}
              >
                {page.category}
              </p>
            )}

            <h1
              class="content-title"
              data-tina-field={tinaField(page, "title")}
            >
              {page.title}
            </h1>

            {page.subtitle && (
              <p
                class="content-subtitle"
                data-tina-field={tinaField(page, "subtitle")}
              >
                {page.subtitle}
              </p>
            )}
          </header>

          {page.body && (
            <div
              class="content-body prose"
              data-tina-field={tinaField(page, "body")}
            >
              <TinaMarkdown content={page.body} />
            </div>
          )}
        </article>
      </main>
    ) : (
      <main id="main-content" class="missing-page">
        <div class="missing-container">
          <p class="missing-eyebrow">Page in progress</p>

          <h1>{fallbackTitle}</h1>

          <p>
            This page is part of the planned Cadence Lab site, but its final
            content has not been published yet.
          </p>

          <div class="missing-actions">
            <a href="/" class="primary-link">
              Return to the home page
            </a>

            <a href="/contact/" class="secondary-link">
              Contact Cadence Lab
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </main>
    )
  }

  <Footer />
</Layout>

<style>
  .content-page,
  .missing-page {
    width: 100%;
    padding-block: clamp(4rem, 10vw, 8rem);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .content-container,
  .missing-container {
    width: min(calc(100% - (2 * var(--page-gutter))), 48rem);
    margin-inline: auto;
  }

  .content-container {
    display: grid;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .content-header,
  .missing-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .content-header {
    gap: 1rem;
  }

  .content-eyebrow,
  .missing-eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-style: normal;
    font-weight: 600;
    line-height: 1.4;
    letter-spacing: 0;
    text-transform: none;
  }

  .content-title,
  .missing-container h1 {
    max-width: 15ch;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: clamp(2.75rem, 2rem + 3vw, 5.25rem);
    font-style: normal;
    font-weight: 600;
    line-height: 0.98;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .content-subtitle,
  .missing-container > p:not(.missing-eyebrow) {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: clamp(1.0625rem, 1rem + 0.3vw, 1.25rem);
    font-style: normal;
    font-weight: 400;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .content-body {
    padding-top: clamp(2rem, 5vw, 3.5rem);
    border-top: 1px solid var(--color-border);
  }

  .missing-container {
    max-width: 44rem;
    gap: 1.25rem;
  }

  .missing-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    margin-top: 1rem;
  }

  .primary-link {
    display: inline-flex;
    width: fit-content;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
    border: 1px solid var(--color-ink);
    border-radius: var(--radius-sm);
    background: var(--color-ink);
    color: var(--color-light);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .primary-link:hover {
    border-color: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
    background: color-mix(in srgb, var(--color-ink) 86%, var(--color-light));
    color: var(--color-light);
    text-decoration: none;
  }

  .primary-link:active {
    transform: translateY(1px);
  }

  .secondary-link {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.2em;
  }

  .secondary-link:hover {
    color: var(--color-blue);
  }

  .primary-link:focus-visible,
  .secondary-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  @media (max-width: 40rem) {
    .content-page,
    .missing-page {
      padding-block: clamp(3.5rem, 14vw, 5rem);
    }

    .content-title,
    .missing-container h1 {
      max-width: 12ch;
      font-size: clamp(2.5rem, 11vw, 4rem);
    }

    .missing-actions {
      width: 100%;
      flex-direction: column;
      align-items: stretch;
    }

    .primary-link,
    .secondary-link {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .primary-link {
      transition: none;
    }
  }

  @media (forced-colors: active) {
    .content-body,
    .primary-link {
      border-color: CanvasText;
    }
  }
</style>
