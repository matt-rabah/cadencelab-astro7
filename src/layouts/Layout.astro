---
// src/layouts/Layout.astro

import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: URL | string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  pageType?: "website" | "article";
}

const {
  title = "Cadence Lab | Customer experience systems and AI adoption",
  description = "Cadence Lab helps organizations diagnose customer experience friction, improve workflow adoption, integrate AI responsibly, and build measurable operating systems.",
  canonicalURL,
  image = "/og/cadencelab-default.png",
  imageAlt = "Cadence Lab",
  noindex = false,
  pageType = "website",
} = Astro.props;

const siteName = "Cadence Lab";
const siteURL = Astro.site ?? new URL("https://cadencelab.co");

const canonical = canonicalURL
  ? new URL(canonicalURL, siteURL)
  : new URL(Astro.url.pathname, siteURL);

const socialImage = new URL(image, siteURL);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteURL.toString(),
  logo: new URL(
    "/brand/cadencelab-wordmark-dark-color.svg",
    siteURL,
  ).toString(),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta name="generator" content={Astro.generator} />

    <!--
      Astro 7 Fonts API

      Graphik is the primary site and interface family, so preload it.
      Tiempos families remain available for editorial article body copy
      and selective editorial accents without forcing unnecessary preload.
    -->
    <Font cssVariable="--font-graphik" preload />
    <Font cssVariable="--font-tiempos-text" />
    <Font cssVariable="--font-tiempos-headline" />

    <title>{title}</title>

    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex, nofollow, noarchive" />}

    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <meta
      name="theme-color"
      content="#FCFEFF"
      media="(prefers-color-scheme: light)"
    />

    <meta
      name="theme-color"
      content="#010302"
      media="(prefers-color-scheme: dark)"
    />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={pageType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(organizationSchema)}
    />
  </head>

  <body>
    <a class="skip-link" href="#main-content"> Skip to main content </a>

    <slot />
  </body>
</html>
