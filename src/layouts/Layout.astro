---
// src/layouts/Layout.astro
interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "CadenceLab | Enterprise CX Architecture", 
  description = "Architecting workflow adoption, trust, and alignment frameworks for enterprise customer experience automation." 
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* --- SANITIZED SYSTEM BASELINE RESET --- */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    width: 100%;
    min-height: 100vh;
    background-color: #ffffff;
    color: rgba(0, 0, 0, 0.85); /* Premium soft ink-charcoal instead of raw harsh black */
    font-family: var(--font-sans, -apple-system, BlinkMacSystemFont, sans-serif);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  body {
    display: flex;
    flex-direction: column;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* --- 👑 THE EXPORTED EDITORIAL TYPOGRAPHY RULES --- */

  /* H1: Ultra-bold Primary Title Node */
  h1, .display-h1 {
    font-family: var(--font-sans), sans-serif;
    font-weight: 700;
    line-height: 1.0;
    letter-spacing: -0.04em;
    transform: translateX(-0.06em); /* Perfect edge margin tracking */
    margin: 0;
    
    /* Fluid calculation curve: Glides between 300px and 1440px viewports */
    font-size: calc(33.0526px + 3.98246vw);
  }

  /* H2: Secondary Heading Matrix */
  h2, .display-h2 {
    font-family: var(--font-sans), sans-serif;
    font-weight: 600;
    line-height: 1.0;
    letter-spacing: -0.04em;
    transform: translateX(-0.06em);
    margin: 2px 0 12px 0;
    
    font-size: calc(23.5768px + 2.80439vw);
  }

  /* H3: Accordion Headers & Feature Group Dividers */
  h3, .display-h3 {
    font-family: var(--font-sans), sans-serif;
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.035em;
    transform: translateX(-0.06em);
    margin: 0;
    
    font-size: calc(18.4737px + 1.84211vw);
  }

  /* H5 / H6: Small Sub-headings, Footers, and Category Group Tags */
  h5, .display-h5, h6, .display-h6 {
    font-family: var(--font-sans), sans-serif;
    line-height: 1.2;
    margin: 0;
  }

  h5, .display-h5 {
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: calc(14.9474px + 0.35088vw);
  }

  h6, .display-h6 {
    font-weight: 400;
    letter-spacing: 0em;
    font-size: calc(14.9474px + 0.35088vw);
  }

  /* P: Deep Reading Editorial Paragraph Copy Block */
  p, .body-copy {
    font-family: var(--font-serif-text), Georgia, serif; /* Enforces the reading serif loop */
    font-size: 20px;
    font-weight: 300; /* Crisp, elegant ultra-light weight */
    line-height: 1.55; /* Open spacing reduces cognitive loading */
    letter-spacing: normal;
    margin: 8px 0 20px 0;
    color: rgba(0, 0, 0, 0.85);
  }

  /* Cap the maximum sizes securely once the viewport hits standard 1440px desktop width */
  @media screen and (min-width: 1440px) {
    h1, .display-h1 { font-size: 90.4px !important; }
    h2, .display-h2 { font-size: 63.96px !important; }
    h3, .display-h3 { font-size: 45px !important; }
    h5, .display-h5 { font-size: 20px !important; }
    h6, .display-h6 { font-size: 20px !important; }
  }
</style>
